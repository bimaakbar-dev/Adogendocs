---
// src/components/Footer.astro
import { SITE, NAV, ROUTES } from "@/consts";
import Icon from "@/components/ui/icons/Icon.astro";
import Container from "./ui/Container.astro";
import Section from "./ui/Section.astro";

const currentYear = new Date().getFullYear();
const copyrightYear =
  currentYear > SITE.foundingYear
    ? `${SITE.foundingYear}–${currentYear}`
    : SITE.foundingYear;
---

<footer
  class="mt-auto mb-(--pb-safe-bottom) shrink-0 border-t border-(--border-subtle)/40 bg-(--bg) font-medium"
>
  <Section size="sm">
    <Container size="xl">
      <div class="mb-12 grid grid-cols-1 gap-8 md:grid-cols-4 lg:gap-12">
        <div class="flex flex-col gap-3">
          <a
            href={ROUTES.home}
            class="flex w-fit items-center gap-2 no-underline"
            aria-label={SITE.name}
          >
            <Icon name="logo" className="h-6 w-6" />
            <span class="hidden font-semibold text-(--fg-strong)"
              >{SITE.name}</span
            >
          </a>
        </div>
        {
          NAV.footerBar.map((section) => (
            <div class="flex flex-col gap-4">
              <span class="text-[11px] font-bold tracking-widest text-(--fg-strong) uppercase">
                {section.title}
              </span>
              <nav class="flex flex-col items-start gap-2.5">
                {section.items.map((item) => (
                  <a
                    href={item.href}
                    class="w-fit text-[13px] text-(--fg-muted) transition-colors hover:text-(--fg-strong)"
                    target={item.isExternal ? "_blank" : undefined}
                    rel={item.isExternal ? "noopener noreferrer" : undefined}
                  >
                    {item.label}
                  </a>
                ))}
              </nav>
            </div>
          ))
        }
      </div>
      <div
        class="hidden flex-col items-center justify-between gap-4 pt-8 sm:flex-row"
      >
        <p class="text-[13px] text-(--fg-muted)">
          &copy; {copyrightYear}
          {SITE.name}. All rights reserved.
        </p>

        <div class="flex gap-6 text-sm text-(--fg-muted)">
          <a href={SITE.url} class="transition-colors hover:text-(--fg-strong)">
            {SITE.url.replace(/^https?:\/\//, "")}
          </a>
          <span>{SITE.lang.toUpperCase()}</span>
        </div>
      </div>
    </Container>
  </Section>
</footer>
