---
// src/components/Footer.astro
import { 
  SITE, 
  NAV 
} from "@/consts";

import Icon from "@ui/Icon.astro";
import Button from "@ui/Button.astro";
import Theme from "./Theme.astro";

const socials = NAV.Social || [];

const currentYear = new Date().getFullYear();
const copyrightYear =
  currentYear > SITE.foundingYear
    ? `${SITE.foundingYear}–${currentYear}`
    : SITE.foundingYear;
---

<footer class="mt-auto shrink-0 pt-4 pb-2 mb-(--safe-bottom)">
  <div class="flex items-center justify-between rounded-md border border-(--border-subtle) bg-(--bg) px-2 py-1.5">
    <div class="flex items-center gap-1">
      {socials.map((item) => (
        <Button
          href={item.href}
          target={item.isExternal ? "_blank" : undefined}
          rel={item.isExternal ? "noopener noreferrer" : undefined}
          variant="icon"
          size="sm"
          aria-label={item.label}
        >
          <Icon name={item.icon as any} className="h-4 w-4" />
        </Button>
      ))}
    </div>
    <Theme />
  </div>

  <div class="mt-3 text-center font-mono text-[11px] uppercase tracking-wider text-(--fg-muted)/70">
    &copy; {copyrightYear} {SITE.name}
  </div>
</footer>