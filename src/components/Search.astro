---
import Button from "./ui/Button.astro";
import Icon from "./ui/Icons.astro";
import Spinner from "./ui/Spinner.astro";

const $ = {
  overlay: "fixed inset-0 z-9999 hidden bg-black/50 backdrop-blur-sm transition-opacity duration-200 dark:bg-black/70",
  modal: "fixed left-1/2 top-0 w-[95%] max-w-2xl -translate-x-1/2 rounded-lg border border-(--border-strong) bg-(--bg-subtle) shadow-2xl transition-all duration-(--duration-fast) scale-95 opacity-0",
  searchBar: "flex items-center gap-2 px-3 py-3",
  searchIcon: "relative inline-flex shrink-0 items-center justify-center transition-opacity duration-(--duration)",
  close: "px-1! h-auto! font-mono rounded-md!",
  closeMobile: "",
  spinner: "absolute inset-0 hidden text-(--fg-strong)",
  searchInput: "w-full bg-transparent text-md text-(--fg) outline-none placeholder:text-(--fg-muted)",
  searchResult: "max-h-[65vh] overflow-y-auto",
  searchResultList: "hidden space-y-2 p-2",
  emptyNote: "p-8 text-center text-base text-(--fg-muted)",
  loadMoreWrap: "hidden p-2 pt-2",
  loadMoreBtn: "w-full",
  iconSize: "w-4 h-4",
};

const $$ = {
  resultWrapper: "result-group rounded-md bg-(--bg) overflow-hidden",
  resultItem: "result-item flex items-start gap-3 px-3 py-2 text-sm transition-opacity hover:bg-(--bg-muted) active:bg-(--bg-muted)",
  resultImage: "aspect-video h-10 w-auto shrink-0 rounded object-cover hidden",
  resultList: "flex min-w-0 flex-col gap-0.5",
  resultTitle: "truncate text-(--fg-strong) font-medium",
  resultMetaGroup: "flex gap-2 text-[10px] text-(--fg-muted)",
  resultDescription: "result-excerpt line-clamp-1 text-xs text-(--fg-muted)",
  subResultList: "sub-results-list border-t border-(--border-subtle)/40",
  subResultWrapper: "sub-result flex justify-start pl-6 pr-3 hover:bg-(--bg-muted) active:bg-(--bg-muted)",
  subResultItem: "sub-result-item flex items-start gap-2 py-1.5 pl-2 text-xs",
  subResultMeta: "flex min-w-0 flex-col gap-1",
  subResultTitle: "truncate text-(--fg)",
  subResultDescription: "result-excerpt line-clamp-1 text-(--fg-muted)",
};

const SEARCH_PAGE_SIZE = 8;
---

<div id="search-overlay" class={$.overlay}>
  <div id="search-modal" class={$.modal}>
    <div class={$.searchBar}>
      <div class:list={[$.iconSize, $.searchIcon]}>
        <Icon id="search-icon-wrap" name="search" fill class="h-full w-full text-(--fg-muted)" />
        <Spinner id="search-spinner" size="sm" class={$.spinner} />
      </div>
      <input id="search-input" type="text" placeholder="Ketik untuk mencari..." class={$.searchInput} autofocus />
      <Button data-action="close-search" aria-label="Tutup" variant="secondary" size="sm" class:list={[$.close, "hidden! sm:inline-flex!"]}>
        ESC
      </Button>
      <Button data-action="close-search" aria-label="Tutup" variant="icon" size="sm" thisIcon class:list={[$.closeMobile, "inline-flex! sm:hidden!"]}>
        <Icon name="remove" class={$.iconSize} />
      </Button>
    </div>
    <div id="search-results" class={$.searchResult}>
      <div id="search-empty" class="hidden"></div>
      <ul id="search-list" class={$.searchResultList}></ul>
    </div>
    <div id="search-load-more-wrap" class={$.loadMoreWrap}>
      <Button id="search-load-more" variant="secondary" size="sm" block class={$.loadMoreBtn}>
        Muat lebih banyak
      </Button>
    </div>
  </div>
</div>

<template id="search-result-template">
  <li class={$$.resultWrapper}>
    <a class={$$.resultItem}>
      <img data-slot="image" class={$$.resultImage} src="" alt="" />
      <div class={$$.resultList}>
        <span data-slot="title" class={$$.resultTitle}></span>
        <div class={$$.resultMetaGroup}>
          <span data-slot="author"></span>
          <span data-slot="date"></span>
        </div>
        <span data-slot="description" class={$$.resultDescription}></span>
      </div>
    </a>
    <ul data-slot="sub-results" class={$$.subResultList}></ul>
  </li>
</template>

<template id="search-subresult-template">
  <li class={$$.subResultWrapper}>
    <a class={$$.subResultItem}>
      <div class={$$.subResultMeta}>
        <span data-slot="sub-title" class={$$.subResultTitle}></span>
        <span data-slot="sub-excerpt" class={$$.subResultDescription}></span>
      </div>
    </a>
  </li>
</template>

<template id="search-empty-template">
  <p class={$.emptyNote}>Tidak ada hasil</p>
</template>

<script is:inline define:vars={{ SEARCH_PAGE_SIZE }}>
  (() => {
    const overlay = document.getElementById("search-overlay"),
      modal = document.getElementById("search-modal"),
      input = document.getElementById("search-input"),
      list = document.getElementById("search-list"),
      empty = document.getElementById("search-empty"),
      iconWrap = document.getElementById("search-icon-wrap"),
      spinner = document.getElementById("search-spinner"),
      resultTemplate = document.getElementById("search-result-template"),
      subResultTemplate = document.getElementById("search-subresult-template"),
      emptyTemplate = document.getElementById("search-empty-template"),
      loadMoreWrap = document.getElementById("search-load-more-wrap"),
      loadMoreBtn = document.getElementById("search-load-more");

    const closeBtns = document.querySelectorAll('[data-action="close-search"]');
    const PAGE_SIZE = SEARCH_PAGE_SIZE || 8;

    let isOpen = false,
      pagefind = null,
      pagefindLoading = null;
    let currentRawResults = [];
    let renderedCount = 0;
    let searchToken = 0;

    async function loadPagefind() {
      if (pagefindLoading) return pagefindLoading;
      pagefindLoading = (async () => {
        pagefind = await import("/pagefind/pagefind.js");
        await pagefind.init();
      })();
      return pagefindLoading;
    }

    function setLoading(isLoading) {
      if (!iconWrap || !spinner) return;
      iconWrap.classList.toggle("opacity-0", isLoading);
      spinner.classList.toggle("hidden", !isLoading);
    }

    function clearList() {
      if (list) {
        list.classList.add("hidden");
        list.innerHTML = "";
      }
      hideLoadMore();
      currentRawResults = [];
      renderedCount = 0;
    }

    function clearEmpty() {
      if (empty) {
        empty.classList.add("hidden");
        empty.innerHTML = "";
      }
    }

    function showNoResults() {
      if (!empty || !emptyTemplate) return;
      empty.innerHTML = "";
      empty.appendChild(emptyTemplate.content.cloneNode(true));
      empty.classList.remove("hidden");
    }

    function showLoadMore() {
      loadMoreWrap?.classList.remove("hidden");
    }

    function hideLoadMore() {
      loadMoreWrap?.classList.add("hidden");
    }

    function openSearch() {
      if (!overlay || !modal) return;
      loadPagefind();
      overlay.classList.remove("hidden");
      isOpen = true;
      document.body.style.overflow = "hidden";
      requestAnimationFrame(() => {
        modal.classList.remove("scale-95", "opacity-0");
        modal.classList.add("scale-100", "opacity-100");
      });
      setTimeout(() => input?.focus(), 150);
      clearList();
      clearEmpty();
    }

    function closeSearch() {
      if (!overlay || !modal) return;
      modal.classList.remove("scale-100", "opacity-100");
      modal.classList.add("scale-95", "opacity-0");
      setTimeout(() => {
        overlay.classList.add("hidden");
        isOpen = false;
        document.body.style.overflow = "";
      }, 150);
      if (input) input.value = "";
      clearList();
      clearEmpty();
      setLoading(false);
    }

    document.addEventListener("open-search", openSearch);

    closeBtns.forEach((btn) => btn.addEventListener("click", closeSearch));

    overlay?.addEventListener("click", (e) => {
      if (e.target === overlay) closeSearch();
    });

    document.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        isOpen ? closeSearch() : openSearch();
      }
      if (e.key === "Escape" && isOpen) closeSearch();
    });

    function buildSubResult(sub) {
      const node = subResultTemplate.content.cloneNode(true);
      node.querySelector("a").href = sub.url;
      node.querySelector('[data-slot="sub-title"]').textContent = sub.title || "";
      if (sub.excerpt) node.querySelector('[data-slot="sub-excerpt"]').innerHTML = sub.excerpt;
      else node.querySelector('[data-slot="sub-excerpt"]').remove();
      return node;
    }

    function buildResultItem(item) {
      const node = resultTemplate.content.cloneNode(true);
      node.querySelector("a.result-item").href = item.url;
      node.querySelector('[data-slot="title"]').textContent = item.meta?.title ?? item.url;
      const img = node.querySelector('[data-slot="image"]');
      if (item.meta?.image) {
        img.src = item.meta.image;
        img.classList.remove("hidden");
      }
      if (item.meta?.author) node.querySelector('[data-slot="author"]').textContent = `by ${item.meta.author}`;
      if (item.meta?.date) node.querySelector('[data-slot="date"]').textContent = new Date(item.meta.date).toLocaleDateString();
      const desc = item.excerpt || item.meta?.description || "";
      if (desc) node.querySelector('[data-slot="description"]').innerHTML = desc;
      else node.querySelector('[data-slot="description"]').remove();
      const subs = (item.sub_results || []).filter((s) => s.url !== item.url).slice(0, 3);
      if (subs.length) subs.forEach((s) => node.querySelector('[data-slot="sub-results"]').appendChild(buildSubResult(s)));
      else node.querySelector('[data-slot="sub-results"]').remove();
      return node;
    }

    async function renderNextPage(token) {
      const nextBatch = currentRawResults.slice(renderedCount, renderedCount + PAGE_SIZE);
      if (!nextBatch.length) {
        hideLoadMore();
        return;
      }
      const items = await Promise.all(nextBatch.map((r) => r.data()));
      if (token !== searchToken) return;
      const frag = document.createDocumentFragment();
      items.forEach((i) => frag.appendChild(buildResultItem(i)));
      list.appendChild(frag);
      renderedCount += nextBatch.length;
      if (renderedCount < currentRawResults.length) showLoadMore();
      else hideLoadMore();
    }

    loadMoreBtn?.addEventListener("click", () => renderNextPage(searchToken));

    async function performSearch() {
      const token = ++searchToken;
      const query = input?.value?.trim() || "";

      if (!query) {
        clearList();
        clearEmpty();
        setLoading(false);
        return;
      }
      clearEmpty();
      setLoading(true);
      await loadPagefind();

      const res = await pagefind.debouncedSearch(query);
      if (token !== searchToken) return;

      currentRawResults = res.results || [];
      renderedCount = 0;
      list.innerHTML = "";

      if (!currentRawResults.length) {
        clearList();
        showNoResults();
        setLoading(false);
        return;
      }

      clearEmpty();
      list.classList.remove("hidden");
      await renderNextPage(token);
      if (token === searchToken) setLoading(false);
    }

    input?.addEventListener("input", performSearch);
  })();
</script>

<style is:global>
  #search-modal {
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.25s ease-out;
  }
  #search-overlay {
    transition: opacity 0.25s ease-out;
  }
  .sub-result {
    position: relative;
  }
  .sub-result::before {
    content: "";
    position: absolute;
    top: 0;
    left: 12px;
    width: 12px;
    height: 20px;
    border-left: 1.5px solid var(--border-strong);
    border-bottom: 1.5px solid var(--border-strong);
    border-bottom-left-radius: 0px;
  }
  .sub-result:not(:last-of-type)::after {
    content: "";
    position: absolute;
    top: 20px;
    bottom: 0;
    left: 12px;
    border-left: 1.5px solid var(--border-strong);
  }
  .result-excerpt mark {
    background-color: color-mix(in srgb, var(--color-chart-2) 10%, transparent) !important;
    color: var(--accent);
    border-radius: 0 !important;
    padding: 0 4px !important;
  }
</style>