---
import Icon from "@ui/Icons.astro";
---

<div class="feedback-bar relative border border-(--border-subtle) bg-(--bg) rounded-md mt-8 p-2">
  <svg viewBox="0 0 16 8" fill="var(--bg)" stroke="currentColor" stroke-width="1" preserveAspectRatio="none" class="absolute -top-2 left-6 w-4 h-2 overflow-visible text-(--border-subtle)">
    <path d="M0 8 L8 0 L16 8" />
  </svg>

  <div id="feedback-initial" class="flex items-center justify-between">
    <span class="text-sm text-(--fg-muted)">Apakah ini membantu?</span>
    <div class="flex gap-2">
      <button data-sentiment="positive" class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium border border-(--border-subtle) rounded-full hover:bg-(--bg-subtle) transition-all">
        <Icon name="thumbs-up" class="w-4 h-4" /> Yes
      </button>
      <button data-sentiment="negative" class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium border border-(--border-subtle) rounded-full hover:bg-(--bg-subtle) transition-all">
        <Icon name="thumbs-down" class="w-4 h-4" /> No
      </button>
    </div>
  </div>

  <div id="feedback-form" class="hidden flex-col gap-3">
    <textarea 
      id="feedback-text"
      rows="3" 
      placeholder="Masukan Anda sangat membantu..."
      class="w-full text-sm bg-(--bg-subtle) border border-(--border-subtle) rounded-md p-3 focus:outline-none focus:border-(--accent)"
    ></textarea>
    <div class="flex justify-end gap-2">
      <button id="submit-feedback" class="px-3 py-1.5 text-xs font-medium bg-(--accent) text-white rounded-md">Kirim</button>
    </div>
  </div>

  <div id="feedback-thanks" class="hidden text-sm text-(--accent) font-medium">
    Terima kasih atas masukannya!
  </div>
</div>

<script>
  function setupFeedback() {
    const bar = document.querySelector('.feedback-bar');
    if (!bar) return;

    const initial = bar.querySelector('#feedback-initial');
    const form = bar.querySelector('#feedback-form');
    const thanks = bar.querySelector('#feedback-thanks');
    let userSentiment = '';

    bar.querySelectorAll('[data-sentiment]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        userSentiment = (e.currentTarget as HTMLElement).getAttribute('data-sentiment') || '';
        
        initial?.classList.add('hidden');
        form?.classList.remove('hidden');
      });
    });

    bar.querySelector('#submit-feedback')?.addEventListener('click', () => {
      const text = (bar.querySelector('#feedback-text') as HTMLTextAreaElement).value;
      
      console.log(`Sentiment: ${userSentiment}, Feedback: ${text}`);
      
      form?.classList.add('hidden');
      thanks?.classList.remove('hidden');
    });
  }

  setupFeedback();
</script>