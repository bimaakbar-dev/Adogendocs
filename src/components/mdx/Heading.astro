---
// src/components/mdx/Heading.astro
interface Props {
  id?: string;
  class?: string;
  level: number;
}

const { id, class: className, level } = (Astro.props || {}) as Props;
const Tag = `h${level}` as any;

const anchorLabel = "Link to this heading";

const headingClasses: Record<string, string> = {
  h1: "text-heading-32 md:text-heading-48 lg:text-heading-56",
  h2: "text-heading-24 md:text-heading-32",
  h3: "text-heading-20 md:text-heading-24",
  h4: "text-heading-16 md:text-heading-20",
  h5: "text-label-14",
  h6: "text-label-12",
};
const classes = headingClasses[`h${level}`] || "text-heading-20";
---

<Tag
  id={id}
  class:list={[
    "heading-group has-anchor",
    classes,
    className,
  ]}
>
  <span data-pagefind-meta="title" class="heading-text-wrapper">
    <slot />
    {id && (level === 2 || level === 3) && (
      <a
        href={`#${id}`}
        data-pagefind-ignore
        aria-label={anchorLabel}
        class="anchor-link"
      />
    )}
  </span>
</Tag>

<style is:global>
  html {
    scroll-behavior: auto !important;
  }

  .heading-group.has-anchor {
    cursor: pointer;
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
  }

  .heading-text-wrapper {
    display: inline;
    word-break: break-word;
  }

  .anchor-link {
    display: inline-flex;
    align-items: center;
    width: 0.75em;
    height: 0.75em;
    margin-left: 0.35rem;
    opacity: 0;
    transform: translateX(-4px);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease,
      background-image 0.15s ease;
    text-decoration: none;
    pointer-events: auto;
    background-image: url("data:image/svg+xml;base64,");
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
  }

  h3 .anchor-link {
    width: 0.7em;
    height: 0.7em;
    align-items: center;
  }

  @media (hover: hover) {
    .heading-group.has-anchor:hover .anchor-link {
      opacity: 1;
      transform: translateX(0);
    }

    .anchor-link:hover {
      background-image: url("data:image/svg+xml;base64,");
    }
  }

  @media (hover: none) {
    .heading-group.is-tapped .anchor-link {
      opacity: 1;
      transform: translateX(0);
    }

    .anchor-link:active {
      transform: scale(0.9);
      background-image: url("data:image/svg+xml;base64,");
    }
  }
</style>

<script>
  function initHeadingTap() {
    if (window.matchMedia("(hover: hover)").matches) return;

    document.querySelectorAll(".heading-group.has-anchor").forEach((heading) => {
      heading.addEventListener("click", (e) => {
        const anchor = heading.querySelector(".anchor-link") as HTMLAnchorElement | null;
        if (!anchor) return;

        if (!anchor.contains(e.target as Node)) {
          e.preventDefault();

          const isAlreadyTapped = heading.classList.contains("is-tapped");

          document.querySelectorAll(".heading-group.is-tapped").forEach((el) => {
            el.classList.remove("is-tapped");
          });

          if (!isAlreadyTapped) {
            heading.classList.add("is-tapped");
          }
        }
      });
    });

    document.addEventListener("click", (e) => {
      const target = e.target as Node;
      const clickedHeading = (target as Element).closest?.(".heading-group");
      if (!clickedHeading) {
        document.querySelectorAll(".heading-group.is-tapped").forEach((el) => {
          el.classList.remove("is-tapped");
        });
      }
    });
  }
  
  initHeadingTap();
  document.addEventListener("astro:page-load", initHeadingTap);
</script>
