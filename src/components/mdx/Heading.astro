---
// src/components/mdx/Heading.astro
import Icon from "@/components/ui/icons/Icon.astro";

interface Props {
  id?: string;
  class?: string;
  level: number;
}

const { id, class: className, level } = (Astro.props || {}) as Props;
const Tag = `h${level}` as any;

const anchorLabel = "Link to this heading";

const headingClasses: Record<string, string> = {
  h1: "text-heading-32 md:text-heading-40 lg:text-heading-56",
  h2: "text-heading-24 md:text-heading-32",
  h3: "text-heading-20 md:text-heading-24",
  h4: "text-heading-16 md:text-heading-20",
  h5: "text-label-14",
  h6: "text-label-12",
};
const classes = headingClasses[`h${level}`] || "text-heading-20";
---

<Tag
  id={id}
  class:list={[
    "heading-group has-anchor", 
    "relative flex flex-wrap items-baseline gap-x-1",
    classes,
    className,
  ]}
>
  <span class="heading-text-content"><slot /></span>
  {
    id && (
      <a
        href={`#${id}`}
        class="anchor-link"
        aria-label={anchorLabel}
      >
        <Icon name="link" className="w-4 h-4" />
      </a>
    )
  }
</Tag>

<style>
  .heading-group.has-anchor {
    cursor: pointer;
    width: 100%;
    max-width: 100%;
    line-height: 1.2;
    text-decoration: none;
    scroll-margin-top: var(--scroll-padding);
  }

  .heading-text-content {
    display: inline;
    word-break: break-word;
  }

  .anchor-link {
    display: inline-flex;
    position: relative;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    vertical-align: baseline;
    transform: translateX(-6px);
    opacity: 0;
    transition:
      opacity 0.15s var(--prose-ease, ease-out),
      transform 0.15s var(--prose-ease, ease-out),
      color 0.15s var(--prose-ease, ease-out);
    margin-left: 0.375rem;
    width: 1.125rem;
    height: 1.125rem;
    pointer-events: none;
    color: var(--fg-subtle, #888);
    text-decoration: none;
  }

  .anchor-link :global(svg) {
    pointer-events: none;
  }

  @media (max-width: 767px) {
    .anchor-link {
      transform: translateX(0);
      opacity: 1;
      pointer-events: auto;
      color: var(--fg-subtle, #a3a3a3);
    }

    .anchor-link:active {
      color: var(--fg-strong, #111);
      transform: scale(0.95);
      transition: transform 0.1s ease-out, color 0.1s ease-out;
    }
  }

  @media (min-width: 1024px) {
    .heading-group.has-anchor:hover .anchor-link {
      transform: translateX(0);
      opacity: 1;
      pointer-events: auto;
      color: var(--fg-subtle, #888);
    }

    .anchor-link:hover {
      color: var(--fg-strong, #111);
    }
  }
</style>