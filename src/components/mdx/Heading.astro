---
// src/components/mdx/Heading.astro
import Icon from "@/components/ui/icons/Icon.astro";

interface Props {
  id?: string;
  class?: string;
  level: number;
}

const { id, class: className, level } = (Astro.props || {}) as Props;
const Tag = `h${level}` as any;

const anchorLabel = "Link to this heading";

const headingClasses: Record<string, string> = {
  h1: "text-heading-32 md:text-heading-48 lg:text-heading-56",
  h2: "text-heading-24 md:text-heading-32",
  h3: "text-heading-20 md:text-heading-24",
  h4: "text-heading-16 md:text-heading-20",
  h5: "text-label-14",
  h6: "text-label-12",
};
const classes = headingClasses[`h${level}`] || "text-heading-20";
---

<Tag
  id={id}
  class:list={[
    "heading-group has-anchor",
    "relative flex flex-wrap items-baseline shrink-0",
    classes,
    className,
  ]}
>
  <span class="heading-text-content"><slot /></span>
  {id && (level === 2 || level === 3) && (
    <a
      href={`#${id}`}
      aria-label={anchorLabel}
      class="anchor-link"
    >
      <Icon name="link" className="w-full h-full" />
    </a>
    <span class="sr-only" set:text={anchorLabel} />
  )}
</Tag>

<style>
  .heading-group.has-anchor {
    cursor: pointer;
    width: 100%;
    max-width: 100%;
    line-height: 1.2;
    text-decoration: none;
    scroll-margin-top: var(--scroll-padding);
  }

  .heading-text-content {
    display: inline;
    word-break: break-word;
  }

  .anchor-link {
    display: inline-flex;
    position: relative;
    flex-shrink: 0;
    justify-content: center;
    align-items: center;
    vertical-align: baseline;
    opacity: 0;
    transform: translateX(-6px);
    transition:
      opacity 0.15s var(--ease-snappy, ease-out),
      transform 0.15s var(--ease-snappy, ease-out),
      color 0.15s var(--ease-snappy, ease-out);
    margin-left: 0.375rem;
    width: 1rem;
    height: 1rem;
    pointer-events: none;
    color: var(--fg-subtle, #888);
    text-decoration: none;
  }

  .anchor-link :global(svg) {
    pointer-events: none;
  }

  @media (hover: hover) {
    .heading-group.has-anchor:hover .anchor-link {
      transform: translateX(0);
      opacity: 1;
      pointer-events: auto;
      color: var(--fg-subtle, #888);
    }

    .anchor-link:hover {
      color: var(--fg-strong, #111);
    }
  }

  @media (hover: none) {
    .heading-group.is-tapped .anchor-link {
      transform: translateX(0);
      opacity: 1;
      pointer-events: auto;
      color: var(--fg-subtle, #a3a3a3);
    }

    .anchor-link:active {
      color: var(--fg-strong, #111);
      transform: scale(0.95);
      transition: transform 0.1s ease-out, color 0.1s ease-out;
    }
  }

  :global(html:has(:target)) {
    scroll-behavior: auto !important;
  }
</style>

<script>
  function initHeadingTap() {
    if (window.matchMedia("(hover: hover)").matches) return;

    document.querySelectorAll(".heading-group.has-anchor").forEach((heading) => {
      heading.addEventListener("click", (e) => {
        const anchor = heading.querySelector(".anchor-link") as HTMLAnchorElement | null;
        if (!anchor) return;

        if (!anchor.contains(e.target as Node)) {
          e.preventDefault();

          const isAlreadyTapped = heading.classList.contains("is-tapped");

          document.querySelectorAll(".heading-group.is-tapped").forEach((el) => {
            el.classList.remove("is-tapped");
          });

          if (!isAlreadyTapped) {
            heading.classList.add("is-tapped");
          }
        }
      });
    });

    document.addEventListener("click", (e) => {
      const target = e.target as Node;
      const clickedHeading = (target as Element).closest?.(".heading-group");
      if (!clickedHeading) {
        document.querySelectorAll(".heading-group.is-tapped").forEach((el) => {
          el.classList.remove("is-tapped");
        });
      }
    });
  }
  initHeadingTap();
</script>