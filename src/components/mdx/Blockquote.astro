---
//src/components/mdx/blockuote.astro
import Icon from "@/components/ui/icons/Icon.astro";

const { 
  cite, 
  citeLabel 
} = Astro.props;

const showCredit = cite || citeLabel;
---

<blockquote class="quote" cite={cite}>
  <div class="quote-body text-body-20">
    <slot />
  </div>
  {showCredit && (
    <div class="quote-footer">
      {cite && (
        <div class="quote-cite">
          <a href={cite} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5">
            {citeLabel || "Source"}
            <Icon name="external" className="w-4 h-4" />
          </a>
        </div>
      )}
      {!cite && citeLabel && (
        <div class="quote-cite">
          <cite>{citeLabel}</cite>
        </div>
      )}
    </div>
  )}
</blockquote>
