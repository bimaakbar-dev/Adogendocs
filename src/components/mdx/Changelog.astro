---
// src/components/mdx/Changelog.astro
const html =
  typeof Astro !== "undefined" && Astro.slots
    ? await Astro.slots.render("default")
    : "";

const releaseRegex =
  /(<h[234][^>]*>[\s\S]*?<\/h[234]>)\s*([\s\S]*?)(?=<h[234][^>]*>[\s\S]*?<\/h[234]>|$)/gi;
const releases: { heading: string; content: string }[] = [];
let match;

if (html) {
  while ((match = releaseRegex.exec(html)) !== null) {
    releases.push({
      heading: match[1].trim(),
      content: match[2].trim(),
    });
  }
}

if (releases.length === 0) {
  releases.push({ heading: "", content: html });
}
---

<div class="my-6 md:my-8 pl-6 sm:pl-11">
  {
    releases.map((release) => (
      <div class="changelog-item relative pb-8 last:pb-0">
        {release.heading && (
          <div class="relative mb-1.5 flex items-center">
            <div class="changelog-bullet absolute -left-6 z-10 h-2.5 w-2.5 rounded-full border border-(--accent)/40 bg-(--accent) sm:-left-9" />
            <div
              class="changelog-version mt-0! font-medium text-(--fg-strong)"
              set:html={release.heading}
            />
          </div>
        )}
        {release.content && (
          <div class="mt-1 space-y-1" set:html={release.content} />
        )}
      </div>
    ))
  }
</div>

<style is:global>
  .changelog-item :first-child {
    margin-top: 0 !important;
  }
  .changelog-item :last-child {
    margin-bottom: 0 !important;
  }
  .changelog-item:not(:last-child)::before {
    content: "";
    position: absolute;
    left: calc(-1.5rem + 0.3125rem);
    top: 0.3125rem;
    bottom: 0;
    width: 1px;
    border-left: 1px dashed var(--border);
  }

  @media (min-width: 640px) {
    .changelog-item:not(:last-child)::before {
      left: calc(-2.25rem + 0.3125rem);
    }
  }

  .changelog-item :global(h2),
  .changelog-item :global(h3),
  .changelog-item :global(h4) {
    margin-top: 0 !important;
    margin-bottom: 0 !important;
  }
</style>
