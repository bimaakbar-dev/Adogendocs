---
// src/components/mdx/Changelog.astro
const html =
  typeof Astro !== "undefined" && Astro.slots
    ? await Astro.slots.render("default")
    : "";

const releaseRegex =
  /(<h[234][^>]*>[\s\S]*?<\/h[234]>)\s*([\s\S]*?)(?=<h[234][^>]*>[\s\S]*?<\/h[234]>|$)/gi;
const releases: { heading: string; content: string }[] = [];
let match;

if (html) {
  while ((match = releaseRegex.exec(html)) !== null) {
    releases.push({
      heading: match[1].trim(),
      content: match[2].trim(),
    });
  }
}

if (releases.length === 0) {
  releases.push({ heading: "", content: html });
}
---

<div class="changelog-wrapper relative my-6 pl-6 sm:pl-11 md:my-8">
  <div
    class="changelog-line absolute left-1 w-px border-l border-dashed border-(--border) sm:left-3"
    style="top:0; bottom:0;"
  >
  </div>
  <div class="space-y-8">
    {
      releases.map((release) => (
        <div class="changelog-item relative">
          {release.heading && (
            <div class="relative mb-1.5 flex items-center">
              <div class="changelog-bullet absolute -left-6 z-10 h-2.5 w-2.5 rounded-full border border-(--accent)/40 bg-(--accent) sm:-left-9" />
              <div
                class="changelog-version mt-0! font-medium text-(--prose-fg-strong)"
                set:html={release.heading}
              />
            </div>
          )}
          {release.content && (
            <div
              class="changelog-items mt-1 space-y-1"
              set:html={release.content}
            />
          )}
        </div>
      ))
    }
  </div>
</div>

<style>
  .changelog-item :global(h2),
  .changelog-item :global(h3),
  .changelog-item :global(h4) {
    margin-top: 0 !important;
    margin-bottom: 0 !important;
  }
</style>

<script>
  function adjustChangelogLines() {
    const wrappers = document.querySelectorAll(".changelog-wrapper");

    wrappers.forEach((wrapper) => {
      const line = wrapper.querySelector(
        ".changelog-line",
      ) as HTMLElement | null;
      const bullets = wrapper.querySelectorAll(
        ".changelog-item .changelog-bullet",
      );
      if (!line || bullets.length === 0) return;

      const firstBullet = bullets[0] as HTMLElement;
      const lastBullet = bullets[bullets.length - 1] as HTMLElement;

      const wrapperRect = wrapper.getBoundingClientRect();
      const firstBulletRect = firstBullet.getBoundingClientRect();
      const lastBulletRect = lastBullet.getBoundingClientRect();

      const top =
        firstBulletRect.top - wrapperRect.top + firstBullet.offsetHeight / 2;
      const bottom =
        wrapperRect.bottom -
        (lastBulletRect.bottom - lastBullet.offsetHeight / 2);

      line.style.top = `${top}px`;
      line.style.bottom = `${bottom}px`;
    });
  }

  document.addEventListener("astro:page-load", adjustChangelogLines);
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", adjustChangelogLines);
  } else {
    adjustChangelogLines();
  }
  window.addEventListener("resize", adjustChangelogLines);
</script>
