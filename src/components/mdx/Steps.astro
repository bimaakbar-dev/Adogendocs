---
// src/components/mdx/Steps.astro
import Icon from "@ui/icons/Icon.astro";

const html =
  typeof Astro !== "undefined" && Astro.slots
    ? await Astro.slots.render("default")
    : "";

const stepRegex = /(<h[234][^>]*>[\s\S]*?<\/h[234]>)([\s\S]*?)(?=<h[234]|$)/gi;
const steps: { heading: string; content: string }[] = [];

let match;

if (html) {
  while ((match = stepRegex.exec(html)) !== null) {
    steps.push({ heading: match[1], content: match[2].trim() });
  }
}

if (steps.length === 0) {
  steps.push({
    heading: "",
    content: html,
  });
}
---

<div class="steps-wrapper relative my-6 pl-6 sm:pl-11 md:my-8">
  <div
    class="steps-line absolute left-1 w-px rounded-full bg-(--border) sm:left-3"
    style="top:0; bottom:0;"
  >
  </div>
  <div class="space-y-7 md:space-y-8">
    {
      steps.map((step, idx) => {
        return (
          <div class="step-item relative">
            {step.heading ? (
              <div class="relative mb-1.5 flex items-center">
                <div class="step-bullet absolute -left-8 z-10 flex h-6 w-6 items-center justify-center rounded-full border border-(--border) bg-(--bg-subtle) p-0.5 font-semibold ring-4 ring-(--bg) sm:-left-11">
                  <span class="text-[13px] text-(--fg-strong) items-center justify-center">
                    {idx + 1}
                  </span>
                </div>
                <div
                  class="steps-heading-content mt-0!"
                  set:html={step.heading}
                />
              </div>
            ) : null}
            {step.content ? (
              <div
                class="steps-body-content space-y-1"
                set:html={step.content}
              />
            ) : null}
          </div>
        );
      })
    }
  </div>
</div>

<style>
  .step-item :global(h2),
  .step-item :global(h3),
  .step-item :global(h4) {
    margin-top: 0 !important;
    margin-bottom: 0 !important;
  }
</style>

<script>
  function adjustLines() {
    const wrappers = document.querySelectorAll(".steps-wrapper");

    wrappers.forEach((wrapper) => {
      const line = wrapper.querySelector(".steps-line") as HTMLElement | null;
      const bullets = wrapper.querySelectorAll(".step-item .step-bullet");
      if (!line || bullets.length === 0) return;

      const firstBullet = bullets[0] as HTMLElement;
      const lastBullet = bullets[bullets.length - 1] as HTMLElement;

      const wrapperRect = wrapper.getBoundingClientRect();
      const firstBulletRect = firstBullet.getBoundingClientRect();
      const lastBulletRect = lastBullet.getBoundingClientRect();

      const top =
        firstBulletRect.top - wrapperRect.top + firstBullet.offsetHeight / 2;
      const bottom =
        wrapperRect.bottom -
        (lastBulletRect.bottom - lastBullet.offsetHeight / 2);

      line.style.top = `${top}px`;
      line.style.bottom = `${bottom}px`;
    });
  }

  document.addEventListener("astro:page-load", adjustLines);
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", adjustLines);
  } else {
    adjustLines();
  }
  window.addEventListener("resize", adjustLines);
</script>
