---
// src/components/mdx/Callout.astro
import Icon from "@/components/ui/icons/Icon.astro";

interface Props {
  type?:
    | "note"
    | "info"
    | "tip"
    | "warning"
    | "danger"
    | "important"
    | "caution";
}

const props = typeof Astro !== "undefined" && Astro.props ? Astro.props : {};
const { type = "note" } = props as Props;

const icons = {
  note: "note",
  info: "info",
  tip: "tip",
  warning: "warning",
  danger: "danger",
  important: "important",
  caution: "caution",
} as const;

const label = type.charAt(0).toUpperCase() + type.slice(1);
---

<aside class="callout" data-callout={type} role="note" aria-label={label}>
  <div class="callout-aside">
    <span class="callout-icon" aria-hidden="true">
      <Icon name={icons[type] as any} className="h-5 w-5" />
    </span>
  </div>
  <div class="callout-body">
    <div class="callout-content">
      <slot />
    </div>
  </div>
</aside>
