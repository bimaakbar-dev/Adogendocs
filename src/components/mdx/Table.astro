---
// src/components/mdx/Table.astro

const s = {
  tableWrapper: 'my-6 md:my-8 overflow-hidden rounded-md border border-(--border) '
}
---

<div class={s.tableWrapper}>
  <div class="overflow-x-auto">
    <table class="min-w-full border-collapse">
      <slot />
    </table>
  </div>
</div>

<style is:global>
  .table-wrapper th,
  .table-wrapper td {
    padding: 0.75rem 1rem;
    white-space: nowrap;
  }
</style>
