---
// src/components/mdx/Link.astro

interface Props {
  href?: string;
  class?: string;
  [key: string]: any;
}

const { href, ...props } = (Astro.props || {}) as Props;

const siteUrl = Astro.site?.href || import.meta.env.SITE || "";
const isExternal = href?.startsWith("http") && !href?.startsWith(siteUrl);
---

<a
  href={href}
  target={isExternal ? "_blank" : undefined}
  rel={isExternal ? "nofollow noopener noreferrer" : undefined}
  class:list={[
    "inline-link", 
    isExternal && "is-external", 
    props.class
  ]}
  {...props}
>
  <slot />
</a>

<style>
  .inline-link.is-external {
    display: inline !important; 
  }

  .inline-link.is-external::after {
    content: "";
    display: inline-block;
    vertical-align: middle;

    width: 0.85em;
    height: 0.85em;
    margin-left: 0.25rem;

    background-image: url("data:image/svg+xml;base64,");
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    
    transition: opacity var(--duration, 150ms) var(--ease-out, ease);
    opacity: 0.8;
  }

  @media (hover: hover) {
    .inline-link.is-external:hover::after {
      opacity: 1;
    }
  }

  @media (max-width: 767px) {
    .inline-link.is-external::after {
      opacity: 1; 
    }
    
    .inline-link.is-external:active::after {
      opacity: 0.7;
      transform: scale(0.92);
    }
  }
</style>
