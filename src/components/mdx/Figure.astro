---
// src/components/mdx/FileTree.astro
import { fileIcons } from "@/components/ui/icons/file";

const svg = fileIcons;
const extIcons = fileIcons;

const s = {
  wrapper: 'my-6 md:my-8 border border-(--border-subtle)/80 rounded-md bg-(--bg-subtle) px-4 py-2 overflow-x-auto font-mono',
  fileTree: 'file-tree text-code-14'
}
---
<div class={s.wrapper}>
  <div class={s.fileTree}>
    <slot />
  </div>
</div>

<script define:vars={{ svg, extIcons }}>
  (() => {
    function getIcon(filename) {
      const ext = filename.split(".").pop()?.toLowerCase() || "";
      return extIcons[ext] ?? svg.file;
    }

    const initFileTreeEngine = () => {
      const trees = document.querySelectorAll(".file-tree:not(.is-processed)");

      trees.forEach((root) => {
        root.classList.add("is-processed");

        function processList(list) {
          list.classList.add("file-tree-list");

          for (const item of list.children) {
            if (!(item instanceof HTMLLIElement)) continue;

            let rawText = "";
            const childNodesToRemove = [];

            for (const node of item.childNodes) {
              if (node.nodeName === "UL" || node.nodeName === "OL") break;
              rawText += node.textContent;
              childNodesToRemove.push(node);
            }

            rawText = rawText.trim();
            if (!rawText) continue;

            const isFolder = rawText.endsWith("/");
            const name = isFolder ? rawText.slice(0, -1) : rawText;
            childNodesToRemove.forEach((n) => n.remove());

            if (isFolder) {
              const details = document.createElement("details");
              details.className = "file-tree-folder open";
              details.open = true;

              const summary = document.createElement("summary");
              summary.className = "file-tree-label";
              summary.innerHTML = `
                <span class="icon folder-icon">${svg["folder-open"]}</span>
                <span class="file-name">${name}</span>
              `;
              
              details.addEventListener("toggle", () => {
                const iconEl = summary.querySelector(".folder-icon");
                iconEl.innerHTML = details.open ? (svg["folder-open"] || svg.folder) : svg.folder;
              });

              details.appendChild(summary);

              while (item.firstChild) {
                const child = item.firstChild;
                if (child.nodeName === "UL" || child.nodeName === "OL") {
                  const div = document.createElement("div");
                  div.className = "file-tree-children";
                  div.appendChild(child);
                  details.appendChild(div);
                } else {
                  details.appendChild(child);
                }
              }
              item.appendChild(details);
            } else {
              item.classList.add("file-tree-file");
              item.innerHTML = `
                <div class="file-tree-label">
                  <span class="icon file-icon">${getIcon(rawText)}</span>
                  <span class="file-name">${rawText}</span>
                </div>
              `;
            }
          }
        }
        root.querySelectorAll("ul, ol").forEach(processList);
      });
    };

    document.addEventListener("astro:page-load", initFileTreeEngine);
    initFileTreeEngine();
  })();
</script>
