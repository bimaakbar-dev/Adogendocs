---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import { formatDateCompact } from "@lib/utils";
import { IMAGE, SITE } from "@/consts";
import Button from "@ui/Button.astro";

interface Props {
  entry: CollectionEntry<"blog">;
}

const { entry } = Astro.props;

const {
  title,
  description,
  slug,
  category,
  pubDate,
  author,
} = entry.data;

const href = `/blog/${slug || entry.id}`;

const Author = {
  avatar: author.avatar ?? IMAGE.avatar.placeholder,
  alt: author.name ?? SITE.name,
  width: IMAGE.avatar.width,
  height: IMAGE.avatar.height
}

const $ = {
  card: "flex flex-col rounded-md border border-(--border-subtle)/80 bg-(--bg-subtle)",
  body: "flex flex-1 flex-col p-4",
  meta: "mb-2 flex items-center justify-between text-label-14 text-(--fg-muted)",
  metaRight: "flex items-center gap-1.5",
  avatar: "flex size-6 shrink-0 items-center justify-center overflow-hidden rounded-full border border-(--border-subtle)",
  avatarImage: "size-full object-cover",
  content: "flex flex-1 flex-col gap-4",
  title: "line-clamp-3 text-heading-18 font-semibold text-(--fg-strong)",
  description: "line-clamp-4 text-body-14 text-(--fg-muted)",
  footer: "mt-auto flex items-center justify-between",
};
---

<article class={$.card}>
  <div class={$.body}>
    <div class={$.meta}>
      <span>{category}</span>
      <div class={$.metaRight}>
        <p>
          {pubDate && (
            <time data-pagefind-sort="date" datetime={pubDate.toISOString()}>
              {formatDateCompact(pubDate)}
            </time>
          )}
        </p>
        {author.avatar && (
          <div class={$.avatar}>
            <Image
              data-pagefind-meta="image[src], image_alt[alt]"
              src={Author.avatar}
              alt={Author.alt}
              width={Author.width}
              height={Author.height}
              loading="lazy"
              decoding="async"
              fetchpriority="auto"
              class={$.avatarImage}
            />
          </div>
        )}
      </div>
    </div>
    <div class={$.content}>
      <h3 data-pagefind-meta="title" class={$.title}>
        {title}
      </h3>
      <p data-pagefind-meta="description" class={$.description}>
        {description}
      </p>
      <div class={$.footer}>
        <Button
          href={href}
          variant="primary"
          size="sm"
          block>
          Read More
        </Button>
      </div>
    </div>
  </div>
</article>