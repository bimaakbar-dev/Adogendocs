---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import { formatDateCompact } from "@lib/utils";
import { IMAGE, SITE } from "@/consts";
import Button from "@ui/Button.astro";
import Card from "../ui/Card.astro";

interface Props {
  entry: CollectionEntry<"blog">;
  index?: number;
}

const { entry, index = 3 } = Astro.props;

const {
  title,
  description,
  slug,
  category,
  pubDate,
  author,
} = entry.data;

const href = `/blog/${slug || entry.id}`;

const Author = {
  avatar: author.avatar ?? IMAGE.avatar.placeholder,
  alt: author.name ?? SITE.name,
  width: IMAGE.avatar.width,
  height: IMAGE.avatar.height
}

const isCritical = index === 0;
const imageLoading = isCritical ? "eager" : "lazy";
const imagePriority = isCritical ? "high" : "low";

const $ = {
  wrapper: "flex flex-col",
  body: "flex flex-1 flex-col",
  meta: "mb-2 flex items-center justify-between text-label-14 text-(--fg-muted)",
  metaRight: "flex items-center gap-1.5",
  avatar: "flex size-6 shrink-0 items-center justify-center overflow-hidden rounded-full border border-(--border-subtle)",
  avatarImage: "size-full object-cover",
  content: "flex flex-1 flex-col gap-4",
  title: "line-clamp-2 text-heading-18 font-semibold text-(--fg-strong)",
  description: "line-clamp-4 text-body-14 text-(--fg-muted)",
  footer: "mt-auto flex items-center justify-between",
};
---

<article class={$.wrapper}>
  <Card padding="md" radius="sm" variant="secondary" class={$.body}>
    <div class={$.meta}>
      <span>{category}</span>
      <div class={$.metaRight}>
        <p>
          {pubDate && (
            <time datetime={pubDate.toISOString()}>
              {formatDateCompact(pubDate)}
            </time>
          )}
        </p>
        {author.avatar && (
          <div class={$.avatar}>
            <Image
              src={Author.avatar}
              alt={Author.alt}
              width={Author.width}
              height={Author.height}
              loading={imageLoading}
              fetchpriority={imagePriority}
              decoding="async"
              class={$.avatarImage}
            />
          </div>
        )}
      </div>
    </div>
    <div class={$.content}>
      <h3 class={$.title}>
        {title}
      </h3>
      <p class={$.description}>
        {description}
      </p>
      <div class={$.footer}>
        <Button
          href={href}
          variant="primary"
          size="sm"
          block
          class="rounded!">
          Read More
        </Button>
      </div>
    </div>
  </Card>
</article>
