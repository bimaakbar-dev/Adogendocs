---
import {
  formatDate,
  getReadingTime,
} from "@lib/utils";

import Breadcrumb from "@components/Breadcrumb.astro";
import Icon from "@ui/Icon.astro";
import ActionCopy from "@components/ActionCopy.astro";

interface Props {
  title: string;
  description?: string;
  cover?: {
    src: string;
    alt: string;
  };
  pubDate?: Date;
  content?: string;
  author: {
    name: string;
    role?: string;
    avatar?: string;
  };
  breadcrumb?: {
    label: string;
    href: string;
  }[];
}

const {
  title,
  description,
  cover,
  pubDate,
  content = "",
  author,
  breadcrumb = [],
} = Astro.props;

const readingTime = getReadingTime(content);

const Header = "space-y-6";
const Cover =
  "prose overflow-hidden";
const CoverImage =
  "aspect-video w-full object-cover";
const Title =
  "text-heading-32 md:text-heading-40 font-semibold tracking-tight leading-tight text-(--fg-strong)";
const Description =
  "max-w-3xl text-body-16 leading-relaxed text-(--fg-muted)";
const Meta =
  "flex flex-wrap items-center gap-2 text-body-14 text-(--fg-muted)";
const Item =
  "inline-flex items-center gap-1.5";
const Divider =
  "text-(--fg-muted)/50";
const IconClass =
  "size-4 text-(--fg-muted)";
---

<header class={Header}>
  <div class="flex items-center justify-between gap-4">
    {breadcrumb.length > 0 && (
      <Breadcrumb items={breadcrumb} separator="chevron" />
    )}
    <ActionCopy />
  </div>
  <div class="space-y-4">
    <div class={Meta}>
      <span class={Item}>
        <span>Writen by </span>
        <span>{author.name}</span>
      </span>
    </div>
    <h1 class={Title}>
      {title}
    </h1>
    <div class={Meta}>
      {pubDate && (
        <>
          <span class={Item}>
            <time datetime={pubDate.toISOString()}>
              {formatDate(pubDate)}
            </time>
          </span>
        </>
      )}
      <span class={Divider}>/</span>
      <span class={Item}>
        <span>{readingTime}</span>
      </span>
    </div>
    {description && (
      <p class={Description}>
        {description}
      </p>
    )}
    {cover && (
    <figure class={Cover}>
      <img
        src={cover.src}
        alt={cover.alt}
        class={CoverImage}
        loading="eager"
        decoding="async"
      />
    </figure>
  )}
  </div>
</header>