---
import {
  formatDate,
  getReadingTime,
} from "@lib/utils";

import { Image } from "astro:assets";
import { IMAGE, SITE } from "@/consts"

import Breadcrumb from "@components/Breadcrumb.astro";
import ActionShare from "../ActionShare.astro";

interface Props {
  title: string;
  description?: string;
  cover?: {
    src: string;
    alt: string;
  };
  pubDate?: Date;
  content?: string;
  author: {
    name: string;
    role?: string;
    avatar?: string;
  };
  breadcrumb?: {
    label: string;
    href: string;
  }[];
}

const {
  title,
  description,
  cover,
  pubDate,
  content = "",
  author,
  breadcrumb = [],
} = Astro.props;

const HeroImage = {
 src: cover?.src ?? IMAGE.thumbnail.placeholder,
 alt: cover?.alt ?? title,
 width: IMAGE.thumbnail.width,
 height: IMAGE.thumbnail.height
}

const Author = {
  name: author.name ?? SITE.name
}

const readingTime = getReadingTime(content);

const Header = "space-y-6";
const Cover = "prose overflow-hidden";
const CoverImage = "aspect-video w-full h-auto object-cover";
const Title = "text-heading-32 md:text-heading-40 font-semibold tracking-tight leading-tight text-balance text-(--fg-strong)";
const Description = "max-w-3xl text-body-16 leading-relaxed text-(--fg-muted)";
const Meta = "flex flex-wrap items-center gap-2 text-body-14 text-(--fg-muted)";
const Item = "inline-flex items-center gap-1.5";
const Divider = "text-(--fg-muted)/50";
---

<header data-pagefind-ignore class={Header}>
  <div class="flex items-center justify-between gap-4">
    {breadcrumb.length > 0 && (
      <Breadcrumb items={breadcrumb} separator="chevron" />
    )}
    <ActionShare />
  </div>
  <div class="space-y-4">
    <div class={Meta}>
      <span class={Item}>
        <span class="text-(--fg-muted)">Written by </span>
        <span data-pagefind-meta="author" class="text-(--fg-strong)">{Author.name}</span>
      </span>
    </div>
    <h1 data-pagefind-meta="title" class={Title}>{title}</h1>
    <div class={Meta}>
      {pubDate && (
        <p class={Item}>
          <time data-pagefind-sort="date" datetime={pubDate.toISOString()}>
            {formatDate(pubDate)}
          </time>
        </p>
      )}
      <span data-pagefind-ignore aria-hidden="true" class={Divider}>/</span>
      <span data-pagefind-ignore class={Item}>{readingTime}</span>
    </div>
    <p data-pagefind-meta="description" class={Description}>{description}</p>
    {cover && (
      <figure class={Cover}>
        <Image
          data-pagefind-meta="image[src], image_alt[alt]"
          src={HeroImage.src}
          alt={HeroImage.alt}
          class={CoverImage}
          width={HeroImage.width}
          height={HeroImage.height}
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </figure>
    )}
  </div>
</header>
