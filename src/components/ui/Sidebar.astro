---
// src/components/Sidebar.astro
import Icon from "./Icon.astro";

export interface SidebarItem {
  id: string;
  title: string;
  href: string;
  category: string;
  order: number;
}

interface Props {
  items: SidebarItem[];
  currentPath: string;
  storagePrefix: string;
  id?: string;
}

const { items, currentPath, storagePrefix, id = "sidebar" } = Astro.props;

const groupedItems = items.reduce(
  (acc, item) => {
    const category = item.category || "General";
    if (!acc[category]) acc[category] = [];
    acc[category].push(item);
    acc[category].sort((a, b) => a.order - b.order);
    return acc;
  },
  {} as Record<string, SidebarItem[]>,
);

const s = {
  wrapper: 'h-full overflow-y-auto',
  nav: 'w-full flex-1',
  categoryWrapper: 'mb-4 last:mb-0',
  categoryHeader: 'flex items-center justify-between mb-2 gap-1.5',
  categoryLogo: 'w-4 h-4 text-(--fg-muted) items-center',
  categoryTitle: 'font-mono text-[12px] font-medium uppercase tracking-wider text-(--fg-muted) flex-1',
  details: 'group',
  summary: 'flex items-center justify-between list-none cursor-pointer select-none rounded-md hover:bg-(--bg-subtle) px-2 py-1.5 [&::-webkit-details-marker]:hidden',
  toggleIcon: 'w-4 h-4 transition-transform duration-200 group-open:rotate-90',
  ul: 'relative flex flex-col mt-1 overflow-hidden transition-all duration-300 ease-in-out',
  li: 'relative border-l border-(--border) px-2 ml-4',
  liChild: 'relative flex justify-between items-center rounded-md px-3 py-1.5 text-[13px] font-medium transition-opacity duration-200',
  childActive: 'bg-(--bg-muted) text-(--fg-strong)',
  childNotActive: 'text-(--fg-muted) hover:bg-(--bg-subtle) hover:text-(--fg-strong)',
}
---

<div id={id} data-prefix={storagePrefix} class={s.wrapper}>
  <nav class={s.nav}>
    {Object.entries(groupedItems).map(([category, categoryItems]) => {
      const categoryId = `category-${category}`;
      const hasActiveChild = categoryItems.some(item => item.href === currentPath || currentPath.startsWith(item.href + '/'));
      
      return (
        <div class={s.categoryWrapper}>
          <details
            id={categoryId}
            class={s.details}
            data-category={category}
            open={hasActiveChild} 
          >
            <summary class={s.summary}>
              <div class="flex items-center gap-1.5">
                <Icon name="logo" className={s.categoryLogo} />
                <span class={s.categoryTitle}>
                  {category.replace(/-/g, " ")}
                </span>
              </div>
              <Icon name="chevron-right" className={s.toggleIcon} />
            </summary>
            <ul class={s.ul}>
              {categoryItems.map((item) => {
                const isActive = item.href === currentPath;
                return (
                  <li class:list={[s.li]}>
                    <a
                      href={item.href}
                      class:list={[
                        s.liChild,
                        "pl-3", 
                        isActive ? s.childActive : s.childNotActive,
                      ]}
                      aria-current={isActive ? "page" : undefined}
                    >
                      {item.title}
                    </a>
                  </li>
                );
              })}
            </ul>
          </details>
        </div>
      );
    })}
  </nav>
</div>

<style is:global>
  #universal-sidebar-desktop {
    scrollbar-width: thin;
    scrollbar-color: var(--border-subtle) transparent;
  }
  #universal-sidebar-desktop::-webkit-scrollbar {
    width: 4px;
  }
  #universal-sidebar-desktop::-webkit-scrollbar-track {
    background: transparent;
  }
  #universal-sidebar-desktop::-webkit-scrollbar-thumb {
    background: var(--border-subtle);
    border-radius: 9999px;
  }

  #universal-sidebar-desktop details[data-category] > ul {
    max-height: 0;
    opacity: 0;
    transition: max-height 0.3s ease-in-out, opacity 0.3s ease-in-out, margin 0.3s ease-in-out;
    margin-top: 0;
  }

  #universal-sidebar-desktop details[data-category][open] > ul {
    max-height: 2000px;
    opacity: 1;
    margin-top: 0.25rem;
  }

  #universal-sidebar-desktop details[data-category] > ul > li {
    transition: opacity 0.2s ease-in-out;
  }

  #universal-sidebar-desktop details[data-category]:not([open]) > ul > li {
    opacity: 0;
  }

  #universal-sidebar-desktop details[data-category][open] > ul > li {
    opacity: 1;
  }
</style>

<script>
  (function() {
    function scrollSidebarToActiveItem(): void {
      const sidebar = document.getElementById("universal-sidebar-desktop");
      if (!sidebar) return;

      const activeLink = sidebar.querySelector('[aria-current="page"]') as HTMLElement | null;
      if (!activeLink) return;
      
      const sidebarRect = sidebar.getBoundingClientRect();
      const linkRect = activeLink.getBoundingClientRect();
      if (linkRect.top >= sidebarRect.top && linkRect.bottom <= sidebarRect.bottom) {
        return;
      }
      const offset = linkRect.top - sidebarRect.top - sidebarRect.height / 3;
      sidebar.scrollBy({ top: offset, behavior: "instant" });
    }

    function initCategoryStates(): void {
      const sidebar = document.getElementById("universal-sidebar-desktop");
      if (!sidebar) return;
      
      const prefix = sidebar.dataset.prefix || 'default';
      const detailsElements = sidebar.querySelectorAll('details[data-category]') as NodeListOf<HTMLDetailsElement>;

      detailsElements.forEach((details) => {
        const category = details.dataset.category;
        if (!category) return;

        const storageKey = `${prefix}-sidebar-category-${category}`;
        const stored = localStorage.getItem(storageKey);
        
        if (stored === 'collapsed' && !details.querySelector('[aria-current="page"]')) {
          details.open = false;
        } else if (stored === 'expanded') {
          details.open = true;
        }

        details.addEventListener('toggle', function(this: HTMLDetailsElement) {
          const isOpen = this.open;
          const cat = this.dataset.category;
          if (cat) {
            localStorage.setItem(`${prefix}-sidebar-category-${cat}`, isOpen ? 'expanded' : 'collapsed');
          }
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        initCategoryStates();
        scrollSidebarToActiveItem();
      });
    } else {
      initCategoryStates();
      scrollSidebarToActiveItem();
    }
  })();
</script>
