---
// src/components/ui/Select.astro
import Icon from "./Icon.astro";

interface SelectOption {
  label: string;
  value: string;
  icon?: string;
  href?: string;
  isExternal?: boolean;
}

interface Props {
  options: SelectOption[];
  selectedValue?: string;
  placeholder?: string;
  id?: string;
}

const { options, selectedValue, placeholder = "Pilih...", id = "select-" + Math.random().toString(36).slice(2, 7) } = Astro.props;
---

<label class="select-wrapper relative block w-full cursor-pointer">
  <span class="sr-only">Select option</span>
  <div class="select-trigger flex w-full items-center justify-between rounded-md border border-(--border-subtle) bg-(--bg) px-3 py-2 text-sm text-(--fg)">
    <span class="flex items-center gap-2">
      <span data-label-text>{placeholder}</span>
    </span>
    <Icon name="select" className="w-4 h-4 text-(--fg-muted)" />
  </div>

  <select id={id} class="absolute inset-0 w-full opacity-0 cursor-pointer">
    <option value="" disabled selected>{placeholder}</option>
    {options.map(opt => (
      <option value={opt.value} data-href={opt.href}>{opt.label}</option>
    ))}
  </select>
</label>

<script is:inline define:vars={{ id }}>
  const select = document.getElementById(id);
  const label = select.parentElement.querySelector('[data-label-text]');

  select.addEventListener('change', (e) => {
    const selectedOption = e.target.options[e.target.selectedIndex];
    label.textContent = selectedOption.text;

    if (selectedOption.dataset.href) {
      window.location.href = selectedOption.dataset.href;
    }
  });
</script>