---
// src/components/ui/Badge.astro
import type { HTMLAttributes } from 'astro/types';

type BadgeVariant = 
  'default' | 
  'accent'  | 
  'success' | 
  'warning' | 
  'error';

interface Props extends HTMLAttributes<'span'> {
  variant?: BadgeVariant;
  class?: string;
}

const { 
  variant = 'default', 
  class: className, 
} = Astro.props;

const baseClasses = [
  "inline-flex items-center px-2 py-0.5",
  "border rounded-full",
  "text-sm font-medium"
].join(" ");

const variantClasses: Record<BadgeVariant, string> = {
  default: [
    "text-(--fg-strong)",
    "bg-(--bg-subtle) border-(--border-subtle)/40"
  ].join(" "),

  accent:  [
    "text-(--accent)",
    "bg-(--accent-soft)/80 border-(--accent-soft)"
  ].join(" "),

  success: [
    "text-(--success)",
    "bg-(--success-soft) border-(--success-soft)"
  ].join(" "),

  warning: [
    "text-(--warning)",
    "bg-(--warning-soft) border-(--warning-soft)"
  ].join(" "),

  error: [
    "text-(--error)",
    "bg-(--error-soft) border-(--error-soft)"
  ].join(" "),
};
---

<span class:list={[
  baseClasses,
  variantClasses[variant], 
  className
]}>
  <slot />
</span>