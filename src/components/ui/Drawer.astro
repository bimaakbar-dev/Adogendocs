---
// src/components/ui/Drawer.astro
interface Props {
  id: string;
}
const { id } = Astro.props;
---

{/* Kita gunakan DIV biasa, ini 100% lebih mudah dikontrol CSS-nya */}
<div 
  id={id} 
  class="drawer-overlay fixed inset-0 z-[9999] hidden items-end justify-center"
>
  {/* Backdrop */}
  <div 
    data-drawer-backdrop 
    class="absolute inset-0 bg-(--bg-strong)/80 backdrop-blur-sm transition-opacity duration-300 opacity-0"
  ></div>

  {/* Panel */}
  <aside 
    data-drawer-panel 
    class="relative flex h-[75vh] w-full flex-col rounded-t-2xl border-t border-(--border-subtle) bg-(--bg) shadow-2xl transition-transform duration-300 ease-out translate-y-full"
  >
    <div data-drag-handle class="flex w-full cursor-grab items-center justify-center pb-6 pt-4 touch-none">
      <div class="h-1.5 w-12 rounded-full bg-(--border-strong)"></div>
    </div>
    
    <div data-drawer-content class="flex flex-1 flex-col overflow-y-auto px-4 pb-4">
      <slot />
    </div>
  </aside>
</div>

<script>
  // Menggunakan fungsi standar yang dipanggil di akhir halaman
  const initDrawers = () => {
    const triggers = document.querySelectorAll('[data-drawer-trigger]');
    
    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const targetId = trigger.getAttribute('data-drawer-trigger');
        const drawer = document.getElementById(targetId || "");
        if (!drawer) return;

        const backdrop = drawer.querySelector('[data-drawer-backdrop]') as HTMLElement;
        const panel = drawer.querySelector('[data-drawer-panel]') as HTMLElement;

        // 1. Tampilkan Overlay
        drawer.classList.remove("hidden");
        drawer.classList.add("flex");

        // 2. Animasikan masuk
        requestAnimationFrame(() => {
          backdrop.classList.remove("opacity-0");
          panel.classList.remove("translate-y-full");
        });
        
        document.body.style.overflow = "hidden";
      });
    });

    // Event listener penutup
    document.querySelectorAll('.drawer-overlay').forEach(drawer => {
      const backdrop = drawer.querySelector('[data-drawer-backdrop]');
      const panel = drawer.querySelector('[data-drawer-panel]') as HTMLElement;

      const close = () => {
        backdrop?.classList.add("opacity-0");
        panel.classList.add("translate-y-full");
        
        setTimeout(() => {
          drawer.classList.add("hidden");
          drawer.classList.remove("flex");
          document.body.style.overflow = "";
        }, 300);
      };

      backdrop?.addEventListener('click', close);
    });
  };

  initDrawers();
</script>