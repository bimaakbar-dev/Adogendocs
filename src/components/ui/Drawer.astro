---
// src/components/ui/Drawer.astro
interface Props {
  id: string;
}
const { id } = Astro.props;
---

<dialog 
  id={id} 
  class="drawer-dialog m-0 h-full max-h-none w-full max-w-none bg-transparent p-0 backdrop:bg-(--bg-strong)/80 backdrop:backdrop-blur-sm"
>
  <aside 
    data-drawer-panel 
    class="absolute bottom-0 left-0 right-0 flex h-[85vh] w-full flex-col rounded-t-2xl border-t border-(--border-subtle) bg-(--bg) shadow-2xl transition-transform duration-300 ease-out will-change-transform"
  >
    <div 
      data-drag-handle 
      class="flex w-full cursor-grab items-center justify-center pb-6 pt-4 touch-none active:cursor-grabbing"
    >
      <div class="h-1.5 w-12 rounded-full bg-(--border-strong)"></div>
    </div>
    
    <div data-drawer-content class="flex flex-1 flex-col overflow-y-auto px-4 pb-4">
      <slot />
    </div>
  </aside>
</dialog>

<script>
  (() => {
    const initDrawers = () => {
      const triggers = document.querySelectorAll('[data-drawer-trigger]');
      
      const openDrawer = (dialog: HTMLDialogElement) => {
        dialog.showModal();
        document.body.style.overflow = "hidden";
      };

      const closeDrawer = (dialog: HTMLDialogElement) => {
        const panel = dialog.querySelector('[data-drawer-panel]') as HTMLElement;
        panel.classList.add("translate-y-full");
        
        setTimeout(() => {
          dialog.close();
          panel.classList.remove("translate-y-full");
          document.body.style.overflow = "";
        }, 300);
      };

      document.querySelectorAll('.drawer-dialog').forEach(el => {
        const dialog = el as HTMLDialogElement;
        const panel = dialog.querySelector('[data-drawer-panel]') as HTMLElement;
        const content = dialog.querySelector('[data-drawer-content]') as HTMLElement;

        dialog.addEventListener('click', (e) => {
          if (e.target === dialog) closeDrawer(dialog);
        });

        let startY = 0;
        panel.addEventListener('touchstart', (e) => {
          if (content && content.scrollTop > 0) return;
          startY = e.touches[0].clientY;
          panel.style.transition = 'none';
        }, { passive: true });

        panel.addEventListener('touchmove', (e) => {
          const deltaY = e.touches[0].clientY - startY;
          if (deltaY > 0) panel.style.transform = `translateY(${deltaY}px)`;
        }, { passive: true });

        panel.addEventListener('touchend', (e) => {
          const deltaY = e.changedTouches[0].clientY - startY;
          panel.style.transition = '';
          if (deltaY > 150) closeDrawer(dialog);
          else panel.style.transform = '';
        });
      });

      triggers.forEach(trigger => {
        trigger.addEventListener('click', () => {
          const targetId = trigger.getAttribute('data-drawer-trigger');
          const dialog = document.getElementById(targetId || "") as HTMLDialogElement;
          if (dialog) openDrawer(dialog);
        });
      });
    };

    document.addEventListener("astro:page-load", initDrawers);
  })();
</script>