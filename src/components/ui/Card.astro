---
// src/components/ui/Card.astro
import type { HTMLAttributes } from "astro/types";

type CardPadding = "none" | "sm" | "md" | "lg";
type CardRadius = "sm" | "md" | "lg";
type CardVariant =
  | "default"
  | "outline"
  | "ghost"
  | "primary"
  | "secondary"

interface Props extends HTMLAttributes<"div"> {
  variant?: CardVariant;
  hover?: boolean;
  padding?: CardPadding;
  radius?: CardRadius;
}

const {
  variant = "default",
  hover = false,
  padding = "md",
  radius = "md",
  class: className,
  ...rest
} = Astro.props;

const variantClasses: Record<CardVariant, string> = {
  default: "ring-1 ring-(--border-subtle) bg-transparent",
  outline: "ring-1 ring-(--border-subtle) bg-transparent",
  ghost: "ring-1 ring-transparent bg-(--bg-subtle)",
  primary: "ring-1 ring-(--border-subtle) bg-(--bg)/8-",
  secondary: "ring-1 ring-(--border-subtle) bg-(--bg-subtle)",
};

const paddingMap: Record<CardPadding, string> = {
  none: "p-0",
  sm: "p-2",
  md: "p-3",
  lg: "p-4",
};

const radiusMap: Record<CardRadius, string> = {
  sm: "rounded-md",
  md: "rounded-lg",
  lg: "rounded-xl",
};

const cardClasses = [
  "min-w-0",
  variantClasses[variant],
  paddingMap[padding],
  radiusMap[radius],
  hover && "cursor-pointer hover:shadow-(--shadow-md)",
  className,
];
---

<div class:list={cardClasses} {...(rest as HTMLAttributes<"div">)}>
  <slot />
</div>