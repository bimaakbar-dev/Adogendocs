const { 
  name,
  size = '24',
  fill = false,
  class: className ='w-5 h-5',
  id
} = Astro.props;

const svgFill = fill ? 'currentColor' : 'none';
const svgStroke = fill ? 'none' : 'currentColor';
const svgStrokeWidth = fill ? '0' : '2';

const fallbackPath = icons.logo;
const innerSvgHtml = icons[name as IconName] || fallbackPath;
---

<svg
  id={id}
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill={svgFill}
  stroke={svgStroke}
  stroke-width={svgStrokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  class:list={[
    "block items-center justify-center shrink-0 aspect-square",
    className
  ]}
  set:html={innerSvgHtml}
/>
