---
// src/components/SidebarLink.astro
interface Props {
  href: string;
  isActive?: boolean;
}

const { 
  href, 
  isActive = false 
} = Astro.props;

const $ = {
  wrapper: "relative flex items-center text-body-13 font-medium",
}
---
<ul class:list={[
  "relative ml-4 border-l",
  isActive ? "border-(--accent)" : "border-(--border-subtle)",
  ]}>
  <li class="px-2 py-1.5 -ml-2 pl-4 rounded">
    <a
      href={href}
      class:list={[
        $.wrapper,
        isActive
          ? "bg-(--bg-muted) text-(--fg-strong)"
          : "text-(--fg) hover:bg-(--bg-muted) active:bg-(--bg-muted)"
      ]}>
      <slot />
    </a>
  </li>
</ul>