---
// src/components/SidebarLink.astro
interface Props {
  href: string;
  isActive?: boolean;
}

const { 
  href, 
  isActive = false 
} = Astro.props;

const $ = {
  wrapper: "flex items-center text-body-13 px-2 py-1.5 font-medium rounded",
}
---
<ul>
  <li class="ml-4 pl-3 border-l border-(--border-subtle)">
    <a
      href={href}
      class:list={[
        $.wrapper,
        isActive
          ? "bg-(--bg-subtle) text-(--accent)"
          : "text-(--fg) hover:bg-(--bg-muted) active:bg-(--bg-muted)"
      ]}>
      <slot />
    </a>
  </li>
</ul>