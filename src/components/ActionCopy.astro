---
import Icon from "@ui/Icons.astro";

interface Props {
  label?: string;
  class?: string;
  rawMarkdown?: string;
}

const { 
  label = "Copy Page", 
  class: className, 
  rawMarkdown = "" 
} = Astro.props;

const s = {
  ActionWrapper: 'copy-dropdown-wrapper relative inline-flex items-stretch rounded-md border border-(--border-subtle) bg-(--bg) shadow-sm hover:shadow transition-shadow duration-200',
  actionGroup: 'flex items-center gap-1.5 px-2 py-1.5 text-xs md:text-sm font-medium hover:bg-(--bg-muted) active:bg-(--bg-muted)/80 rounded-l-md text-(--fg-strong) transition-colors cursor-pointer',
  actionPrefix: 'relative flex items-center justify-center w-4 h-4',
  actionSuffix: 'copy-trigger flex items-center justify-center px-1.5 text-(--fg-muted) hover:text-(--fg-strong) hover:bg-(--bg-muted) active:bg-(--bg-muted)/80 rounded-r-md transition-opacity border-l border-(--border-subtle) cursor-pointer',
  actionDropdown: 'copy-menu hidden absolute right-0 top-[calc(100%+0.5rem)] min-w-[13rem] z-50 rounded-lg border border-(--border-subtle) bg-(--bg) shadow-lg p-1 animate-in fade-in slide-in-from-top-2 origin-top-right',
  actionDropdownItems: 'w-full flex items-center gap-2 px-3 py-2 text-xs md:text-sm text-(--fg) rounded-md hover:bg-(--bg-muted) hover:text-(--fg-strong) transition-colors cursor-pointer'
}
---

<div class:list={[s.ActionWrapper, className]}>
  <template class="raw-markdown-data">{rawMarkdown}</template>
  <button data-action="copy-default" aria-label="Copy page URL" class={s.actionGroup}>
    <div class={s.actionPrefix}>
      <span class="icon-copy transition-opacity duration-200">
        <Icon name="copy" class="w-4 h-4" />
      </span>
      <span class="icon-check hidden absolute inset-0 text-(--success) transition-opacity duration-200">
        <Icon name="check" class="w-4 h-4" />
      </span>
    </div>
    <span>{label}</span>
  </button>
  
  <button aria-label="More copy options" class={s.actionSuffix}>
    <Icon name="chevron-down" class="w-4 h-4" />
  </button>
  
  <div class={s.actionDropdown}>
    <button data-action="url" class={s.actionDropdownItems}>
      <Icon name="link" class="w-4 h-4 opacity-70" /> Copy as URL
    </button>
    <button data-action="markdown" class={s.actionDropdownItems}>
      <Icon name="file" class="w-4 h-4 opacity-70" /> Copy as Markdown
    </button>
    
    <div class="h-px bg-(--border-subtle) my-1.5 mx-1"></div>
    
    <button data-action="agent" class={s.actionDropdownItems}>
      <Icon name="ai-agent" class="w-4 h-4 opacity-70" /> Open in Agent
    </button>
  </div>
</div>

<script>
  function setupCopyButton() {
    document.querySelectorAll('.copy-dropdown-wrapper').forEach(wrapper => {
      const primaryBtn = wrapper.querySelector('[data-action="copy-default"]');
      const trigger = wrapper.querySelector('.copy-trigger');
      const menu = wrapper.querySelector('.copy-menu');
      const iconCopy = wrapper.querySelector('.icon-copy');
      const iconCheck = wrapper.querySelector('.icon-check');
      const template = wrapper.querySelector('.raw-markdown-data');

      if (!primaryBtn || !trigger || !menu) return;

      const showCheckmark = () => {
        iconCopy?.classList.add('hidden');
        iconCheck?.classList.remove('hidden');
        setTimeout(() => {
          iconCopy?.classList.remove('hidden');
          iconCheck?.classList.add('hidden');
        }, 2000);
      };

      primaryBtn.addEventListener('click', async () => {
        await navigator.clipboard.writeText(window.location.href);
        showCheckmark();
      });

      trigger.addEventListener('click', (e) => {
        e.stopPropagation();

        document.querySelectorAll('.copy-menu').forEach(m => {
          if (m !== menu) m.classList.add('hidden');
        });
        menu.classList.toggle('hidden');
      });

      menu.querySelectorAll('button').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          e.stopPropagation();
          menu.classList.add('hidden');
          
          const action = btn.getAttribute('data-action');
          
          if (action === 'url') {
            await navigator.clipboard.writeText(window.location.href);
            showCheckmark();
          }
          
          if (action === 'markdown') {
            const rawContent = template?.innerHTML || "";
            if (rawContent) {
              await navigator.clipboard.writeText(rawContent);
              showCheckmark();
            }
          }
          
          if (action === 'agent') {
            window.location.href = `/agent?page=${window.location.pathname}`;
          }
        });
      });
    });

    document.addEventListener('click', () => {
      document.querySelectorAll('.copy-menu').forEach(m => m.classList.add('hidden'));
    });
  }

  setupCopyButton();
</script>
