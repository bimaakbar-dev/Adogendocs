---
import Button from "@ui/Button.astro";
import Badge from "./ui/Badge.astro";

const tagline = "the Astro docs framework you love.";
const description = "Adogen excellent documentation, your";
---

<section class="hero-container relative flex flex-col w-full border border-(--border-subtle) rounded-xl items-center justify-center overflow-hidden px-4 py-24 bg-(--bg)">
  
  <div class="pointer-events-none absolute inset-0 z-0 opacity-20">
    <svg viewBox="0 0 800 400" class="h-full w-full" preserveAspectRatio="none">
      <path d="M0 50h800M0 150h800M0 250h800M0 350h800M50 0v400M200 0v400M400 0v400M600 0v400" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 4" />
      
      <g class="module-blueprint">
        <rect x="100" y="100" width="120" height="80" fill="none" stroke="currentColor" stroke-width="1" />
        <text x="110" y="120" fill="currentColor" font-size="10" font-family="monospace">BLOG [ANIME, GAME]</text>
      </g>
      
      <g class="module-blueprint">
        <rect x="340" y="180" width="120" height="80" fill="none" stroke="currentColor" stroke-width="1" />
        <text x="350" y="200" fill="currentColor" font-size="10" font-family="monospace">DOCS [CORE]</text>
      </g>

      <g class="module-blueprint">
        <rect x="580" y="100" width="120" height="80" fill="none" stroke="currentColor" stroke-width="1" />
        <text x="590" y="120" fill="currentColor" font-size="10" font-family="monospace">NOVELS</text>
      </g>

      <path d="M160 180 L400 180 M640 180 L460 180" stroke="currentColor" stroke-width="1" stroke-dasharray="6 4" />
    </svg>
  </div>

  <div class="z-10 flex flex-col items-center gap-6 text-center">
    <Badge variant="accent">{tagline}</Badge>
    <h1 class="max-w-md text-heading-32 md:text-heading-48 font-medium text-(--fg-muted)">
      {description} <span class='text-(--accent)'>style</span>.
    </h1>
    <div class="flex gap-4">
      <Button variant="primary" size="md" href="/docs" class="rounded-full!">Get Started</Button>
    </div>
  </div>
</section>

<style>
  .module-blueprint {
    transition: transform 0.5s ease;
  }
  .hero-container:hover .module-blueprint {
    stroke: var(--accent);
    transform: translateY(-5px);
  }
</style>