---
import Button from "@ui/Button.astro";
import Badge from "./ui/Badge.astro";

const tagline = "the Astro docs framework you love.";
const description = "Adogen excellent documentation, your";
---

<section class="hero-container relative flex flex-col w-full border border-(--border-subtle) rounded-xl items-center justify-center overflow-hidden px-4 py-32 bg-(--bg)">
  
  <div class="pointer-events-none absolute inset-0 z-0">
    <svg viewBox="0 0 800 400" class="h-full w-full opacity-30" preserveAspectRatio="xMidYMid slice">
      <defs>
        <pattern id="dot-grid" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
          <circle cx="2" cy="2" r="1" fill="currentColor" class="opacity-20" />
        </pattern>
      </defs>

      <rect width="100%" height="100%" fill="url(#dot-grid)" />

      <path d="M 0 200 L 800 200 M 400 0 L 400 400" stroke="currentColor" stroke-width="0.5" class="opacity-10" />

      <g class="circuit-paths" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M 120 140 L 220 140 L 260 200 L 360 200" class="opacity-20" />
        <path d="M 120 140 L 220 140 L 260 200 L 360 200" class="data-flow stroke-(--accent)" stroke-width="2" />
        
        <path d="M 160 280 L 260 280 L 300 220 L 360 220" class="opacity-20" />
        <path d="M 160 280 L 260 280 L 300 220 L 360 220" class="data-flow stroke-(--accent)" stroke-width="2" style="animation-delay: -2s;" />

        <path d="M 680 170 L 580 170 L 540 210 L 440 210" class="opacity-20" />
        <path d="M 680 170 L 580 170 L 540 210 L 440 210" class="data-flow data-flow-reverse stroke-(--accent)" stroke-width="2" style="animation-delay: -1s;" />
      </g>

      <g class="node float-1" transform="translate(120, 140)">
        <circle cx="0" cy="0" r="12" fill="var(--bg)" stroke="currentColor" stroke-width="2" />
        <circle cx="0" cy="0" r="4" fill="currentColor" class="pulse-opacity" />
        <text x="0" y="-20" fill="currentColor" font-size="10" font-family="monospace" text-anchor="middle" class="tracking-widest font-semibold">BLOG_API</text>
      </g>

      <g class="node float-2" transform="translate(160, 280)">
        <rect x="-10" y="-10" width="20" height="20" fill="var(--bg)" stroke="currentColor" stroke-width="2" transform="rotate(45)" />
        <circle cx="0" cy="0" r="3" fill="currentColor" class="pulse-opacity" style="animation-delay: 1s;" />
        <text x="0" y="30" fill="currentColor" font-size="10" font-family="monospace" text-anchor="middle" class="tracking-widest font-semibold">GAMES_DB</text>
      </g>

      <g class="node float-1" transform="translate(680, 170)">
        <rect x="-12" y="-12" width="24" height="24" rx="4" fill="var(--bg)" stroke="currentColor" stroke-width="2" />
        <circle cx="0" cy="0" r="4" fill="currentColor" class="pulse-opacity" style="animation-delay: 0.5s;" />
        <text x="0" y="-22" fill="currentColor" font-size="10" font-family="monospace" text-anchor="middle" class="tracking-widest font-semibold">NOVEL_REG</text>
      </g>

      <g class="node float-center" transform="translate(400, 200)">
        <circle cx="0" cy="0" r="48" fill="none" stroke="currentColor" stroke-width="1" class="opacity-10 pulse-ring" />
        <circle cx="0" cy="0" r="38" fill="var(--bg)" stroke="currentColor" stroke-width="1.5" class="opacity-30" />
        
        <g transform="translate(-24, -24) scale(2)" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none">
          <path d="M6 5h14v12l-2 2h-12l-2 -2v-10z" />
          <path d="M7 10h2" />
          <path d="M7 12.5v.01" />
          <path d="M12 10h2" />
          <path d="M12 12.5v.01" />
        </g>
        <text x="0" y="52" fill="currentColor" font-size="11" font-family="monospace" text-anchor="middle" class="tracking-widest font-bold">DOCS_CORE</text>
      </g>
    </svg>
  </div>

  <div class="z-10 flex flex-col items-center gap-6 text-center">
    <Badge variant="accent">{tagline}</Badge>
    <h1 class="max-w-xl text-heading-32 md:text-heading-48 font-medium text-(--fg-muted) leading-tight tracking-tight">
      {description} <span class='text-(--fg-strong)'>style</span>.
    </h1>
    <div class="flex gap-4 mt-2">
      <Button variant="primary" size="md" href="/docs" class="rounded-full!">Get Started</Button>
      <Button variant="secondary" size="md" href="/blog" class="rounded-full!">Read Blog</Button>
    </div>
  </div>
</section>

<style>
  @keyframes dashFlow {
    0% { stroke-dasharray: 4, 120; stroke-dashoffset: 124; opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { stroke-dasharray: 4, 120; stroke-dashoffset: 0; opacity: 0; }
  }

  @keyframes dashFlowReverse {
    0% { stroke-dasharray: 4, 120; stroke-dashoffset: 0; opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { stroke-dasharray: 4, 120; stroke-dashoffset: 124; opacity: 0; }
  }

  .data-flow {
    animation: dashFlow 4s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }
  .data-flow-reverse {
    animation: dashFlowReverse 4s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  
  .float-1 { animation: float 6s ease-in-out infinite; }
  .float-2 { animation: float 7s ease-in-out infinite; animation-delay: 1s; }
  
  @keyframes floatCenter {
    0%, 100% { transform: translate(400px, 200px) translateY(0); }
    50% { transform: translate(400px, 200px) translateY(-4px); }
  }
  .float-center { animation: floatCenter 8s ease-in-out infinite; }

  @keyframes pulseOpacity {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.2); }
  }
  
  @keyframes pulseRing {
    0% { transform: scale(0.9); opacity: 0.5; }
    100% { transform: scale(1.3); opacity: 0; }
  }

  .pulse-opacity {
    animation: pulseOpacity 3s ease-in-out infinite;
  }
  .pulse-ring {
    animation: pulseRing 3s cubic-bezier(0.2, 0, 0.2, 1) infinite;
  }
</style>