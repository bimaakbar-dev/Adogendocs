---
// src/components/ui/DocsHeader.astro

import Breadcrumb from "@components/Breadcrumb.astro";
import ActionCopy from "../ActionCopy.astro";

interface Props {
  title: string;
  description?: string;
  breadcrumb?: { label: string; href: string }[];
  content?: string;
}

const { title, description, breadcrumb = [], content = "" } = Astro.props;

const Header = "mb-6 pb-4 space-y-4";
const Title = "text-heading-32 md:text-heading-40 leading-tight font-semibold tracking-tight text-(--fg-strong) flex-1 mb-4";
const Description = "text-body-16 max-w-3xl leading-relaxed text-(--fg-muted)";
---

<header class={Header}>
  <div class="flex justify-between items-center gap-2 mb-6" data-pagefind-ignore>
    <div class="flex items-center">
      {breadcrumb.length > 0 && (
        <Breadcrumb items={breadcrumb} separator="chevron" />
      )}
    </div>
    <div class="flex items-center">
      <ActionCopy rawMarkdown={content} />
    </div>
  </div>
  { title && (<h1 data-pagefind-meta="title" class={Title}>{title}</h1>) }
  { description && (<p data-pagefind-meta="description" class={Description}>{description}</p>)}
</header>
