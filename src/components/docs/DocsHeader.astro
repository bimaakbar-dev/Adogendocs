---
// src/components/ui/DocsHeader.astro
import { 
  formatDate, 
  getReadingTime 
} from "@lib/utils";

import Breadcrumb from "@components/Breadcrumb.astro";
import Icon from "@ui/Icon.astro";
import ActionCopy from "../ActionCopy.astro";

interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  content?: string;
  breadcrumb?: { label: string; href: string }[];
}

const { title, description, pubDate, content = "", breadcrumb = [] } = Astro.props;

const readingTime = getReadingTime(content);

const Header = "mb-6 pb-4 space-y-4";
const Title = "text-heading-32 md:text-heading-40 leading-tight font-semibold tracking-tight text-(--fg-strong) flex-1 mb-4";
const itemGroup = "text-body-14 flex items-center gap-2 text-(--fg-muted)";
const Meta = "flex items-center gap-1.5";
const Icons = "w-4 h-4 text-muted";
const Text = "text-(--fg-muted)/80";
const Spacer = 'text-(--fg-muted)/60';
const Description = "text-body-16 max-w-3xl leading-relaxed text-(--fg-muted)";
---

<header class={Header}>
  <div class="flex justify-between items-center gap-2 mb-2">
    <div class="flex items-center">
      {breadcrumb.length > 0 && (
        <Breadcrumb items={breadcrumb} separator="chevron" />
      )}
    </div>
    <div class="flex items-center"><ActionCopy /></div>
  </div>
  { title && (<h1 data-pagefind-meta="title" class={Title}>{title}</h1>) }
  { description && (<p data-pagefind-meta="description" class={Description}>{description}</p>)}
</header>