---
// src/components/DocsNavbar.astro
import { getCollection } from "astro:content";
import { SITE, NAV, ROUTES } from "@/consts";

import Container from "../ui/Container.astro";
import Icon from "../ui/Icon.astro";
import Theme from "../Theme.astro";
import DocsSidebarMobile from "./DocsSidebarMobile.astro";

const currentPath = Astro.url.pathname;

const docs = await getCollection("docs");
const sidebarItems = docs.sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0),
);
const primaryRootId = "overview";
const cleanSlug = Astro.params.slug;
---

<header
  class="sticky top-0 z-50 border-b border-(--border-subtle)/40 bg-(--bg-subtle)"
>
  <Container size="full">
    <div
      class="mx-auto flex h-(--header-height) w-full items-center justify-between"
    >
      <div class="flex items-center gap-4">
        <a
          href={ROUTES.home}
          aria-label={SITE.name}
          class="inline-flex shrink-0 items-center gap-1.5 text-2xl font-medium text-(--fg) transition-opacity hover:opacity-80"
        >
          <Icon name="logo" className="h-6 w-6" />
          <span class="hidden w-0!">{SITE.name}</span>
        </a>
        <nav class="hidden items-center gap-2 text-[14px] font-medium lg:flex">
          {
            NAV.navBar.map((item) => (
              <a
                href={item.href}
                class:list={[
                  "rounded-md px-2 py-1 transition-colors",
                  currentPath === item.href
                    ? "text-(--fg-strong)"
                    : "text-(--fg-muted) hover:bg-(--bg-muted) hover:text-(--fg)",
                ]}
                target={item.isExternal ? "_blank" : undefined}
                rel={item.isExternal ? "noopener noreferrer" : undefined}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
      <div class="flex items-center gap-3">
        <Theme />
        <DocsSidebarMobile {sidebarItems} {primaryRootId} {cleanSlug} />
      </div>
    </div>
  </Container>
</header>
