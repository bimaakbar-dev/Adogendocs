---
// src/components/ui/DocsPager.astro
import type { CollectionEntry } from "astro:content";
import Icon from "@ui/Icon.astro";

interface Props {
  prev?: CollectionEntry<"docs"> | null;
  next?: CollectionEntry<"docs"> | null;
  primaryRootId: string;
}

const { prev, next, primaryRootId } = Astro.props;

const getHref = (item: CollectionEntry<"docs">) => {
  const isRoot = item.id === primaryRootId;
  return isRoot ? "/docs" : `/docs/${item.data.slug || item.id}`;
};
---

{
  (prev || next) && (
    <nav
      aria-label="Docs pagination"
      class="border-t border-(--border-subtle)/80 pt-8"
    >
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        {prev ? (
          <div class="shrink-0 items-center text-left">
            <a
              href={getHref(prev)}
              class="group flex flex-col gap-1.5 rounded-md border border-(--border)/50 p-4 no-underline hover:bg-(--bg-muted) active:bg-(--bg-muted)"
            >
              <span class="text-label-14 flex items-center justify-start gap-1.5 font-medium text-(--fg-muted)">
                <span class="h-4 w-4 transition-transform group-hover:-translate-x-0.5 group-active:-translate-x-0.5">
                  <Icon name="arrow-left" className="w-full h-full" />
                </span>
                Previous
              </span>
              <span class="truncate text-[14px] font-semibold text-(--fg-strong)">
                {prev.data.title}
              </span>
            </a>
          </div>
        ) : (
          <div />
        )}
        {next ? (
          <div class="shrink-0 items-center text-right">
            <a
              href={getHref(next)}
              class="group flex flex-col gap-1.5 rounded-md border border-(--border)/50 p-4 no-underline hover:bg-(--bg-muted) active:bg-(--bg-muted)"
            >
              <span class="text-label-14 flex items-center justify-end gap-1.5 font-medium text-(--fg-muted)">
                Next
                <span class="h-4 w-4 transition-transform group-hover:translate-x-0.5 group-active:translate-x-0.5">
                  <Icon name="arrow-right" className="w-full h-full" />
                </span>
              </span>
              <span class="truncate text-[14px] font-semibold text-(--fg-strong)">
                {next.data.title}
              </span>
            </a>
          </div>
        ) : (
          <div />
        )}
      </div>
    </nav>
  )
}
