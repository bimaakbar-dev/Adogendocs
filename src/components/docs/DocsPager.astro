---
// src/components/ui/DocsPager.astro
import type { CollectionEntry } from "astro:content";
import Icon from "@ui/Icons.astro";

interface Props {
  prev?: CollectionEntry<"docs"> | null;
  next?: CollectionEntry<"docs"> | null;
  root: string;
}

const { 
  prev, 
  next, 
  root 
} = Astro.props;

const getHref = (item: CollectionEntry<"docs">) => {
  const isRoot = item.id === root;
  return isRoot ? "/docs" : `/docs/${item.data.slug || item.id}`;
};

const aria = "Docs pagination";

const $ = {
  wrapper: 'items-center justify-center shrink-0 pb-(--safe-bottom)',
  peginationGroup: 'grid grid-cols-1 gap-4 sm:grid-cols-2 items-center justify-center',
    
  pegination: [
    'group flex flex-col shrink-0 gap-2 rounded ring-1 p-4 font-medium',
    'ring-(--border-subtle) hover:bg-(--bg-muted)/40 active:bg-(--bg-muted)/40',
    'no-underline'
  ].join(" "),

  header: 'flex items-center gap-1 text-(--fg-strong)',
  Icon: 'block shrink-0 items-center justify-center size-4',
  Label: 'text-label-13 font-semibold',
  SubLabel: 'text-label-14 text-(--fg-muted) truncate'
};
---

{
  (prev || next) && (
    <nav 
      data-pagefind-ignore 
      aria-label={aria} 
      class={$.wrapper}
    >
      <div class={$.peginationGroup}>
        {prev ? (
          <a href={getHref(prev)} 
            class:list={[
              "text-start justify-start",
              $.pegination
            ]}>
            <span class:list={[
              "justify-start",
              $.header
            ]}>
              <Icon name="chevron-left" class={$.Icon} />
              <span class={$.Label}>{prev.data.title}</span>
            </span>
            <span class={$.SubLabel}>
              {prev.data.description}
            </span>
          </a>
        ) : (
          <div />
        )}
        {next ? (
          <a href={getHref(next)} 
            class:list={[
              "text-end justify-end",
              $.pegination
            ]}>
            <span class:list={[
              "justify-end",
              $.header
            ]}>
              <span class={$.Label}>{next.data.title}</span>
              <Icon name="chevron-right" class={$.Icon} />
            </span>
            <span class={$.SubLabel}>
              {next.data.description}
            </span>
          </a>
        ) : (
          <div />
        )}
      </div>
    </nav>
  )
}