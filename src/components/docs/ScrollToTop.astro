---
import Icon from "@ui/Icon.astro";
import Button from "@ui/Button.astro";

interface Props {
  label?: string;
  class?: string;
}

const { label = "Scroll to top", class: className = "" } = Astro.props;
---

<Button
  type="button"
  id="scroll-to-top-btn"
  variant="ghost"
  size="sm"
  aria-label={label}
  prefix={<Icon name="arrow-move-up" className="h-4 w-4" />}
  class:list={[
    "cursor-pointer",
    className,
  ]}
  ><span>{label}</span>
</Button>

<script>
  const initBackToTop = () => {
    const button = document.getElementById("scroll-to-top-btn");
    if (!button) return;

    button.addEventListener("click", (e) => {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  };
  initBackToTop();
</script>
