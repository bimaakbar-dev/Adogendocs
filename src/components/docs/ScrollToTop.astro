---
import Icon from "@ui/Icon.astro";

interface Props {
  label?: string;
  class?: string;
}

const { label = "Scroll to top", class: className = "" } = Astro.props;
---

<button
  type="button"
  id="scroll-to-top-btn"
  aria-label={label}
  class:list={[
    "inline-flex w-full cursor-pointer items-center gap-2 px-1.5 py-1 text-[13px] font-medium text-(--fg-muted) no-underline transition-colors hover:text-(--fg-strong) focus:outline-none",
    className,
  ]}
>
  <span class="shrink-o inline-flex h-4 w-4 items-center">
    <Icon name="arrow-move-up" className="h-full w-full" />
  </span>
  <span>{label}</span>
</button>

<script>
  const initBackToTop = () => {
    const button = document.getElementById("scroll-to-top-btn");
    if (!button) return;

    button.addEventListener("click", (e) => {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  };

  initBackToTop();
  document.addEventListener("astro:page-load", initBackToTop);
  document.addEventListener("astro:after-swap", initBackToTop);
</script>
