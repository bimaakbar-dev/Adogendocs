---
// src/components/MobileNav.astro
import { NAV, ROUTES } from "../consts";

import Button from "./ui/Button.astro";
import Icon from "./ui/icons/Icon.astro";
import Logo from "@ui/Logo.astro";
import Footer from "@/components/Footer.astro";

const links = [
  ...NAV.mobileNavBar.map((item) => ({
    label: item.label,
    href: item.href,
    icon: item.icon,
  })),
];
---

<Button
  id="mobile-menu-open"
  aria-label="Open menu"
  variant="icon"
  size="md"
  class="inline-flex shrink-0 cursor-pointer justify-center items-center p-1.5 sm:hidden border border-(--border)"
>
  <Icon name="menu" className="h-full w-full" />
</Button>

<div id="mobile-menu-drawer" class="pointer-events-none invisible fixed inset-0 z-50 flex flex-col bg-(--bg) opacity-0 transition-all duration-300 pb-(--safe-bottom)">
  <header class="flex h-(--header-height) shrink-0 items-center justify-between border-b border-(--border-subtle)/40 px-4">
    <Logo />
    <Button
      type="button"
      aria-label="Close menu"
      id="mobile-menu-close"
      variant="icon"
      size="md"
      class="inline-flex shrink-0 cursor-pointer items-center justify-center p-1.5 border border-(--border-subtle)"
    >
      <Icon name="close" className="h-full w-full" />
    </Button>
  </header>
  <nav class="flex-1 overflow-y-auto px-2 py-3">
    <div class="grid grid-cols-1 gap-2">
      {
        links.map((item) => (
          <a
            aria-label={item.label}
            href={item.href}
            class="mobile-nav-link flex items-center gap-3 rounded-md px-4 py-3 text-md font-medium text-(--fg) transition-colors hover:bg-(--bg-muted) active:bg-(--bg-muted)"
          >
            <span class="inline-flex items-center justify-center w-5 h-5">
              <Icon name={item.icon as any} className="w-full h-full" />
            </span>
            {item.label}
          </a>
        ))
      }
    </div>
    <Footer />
  </nav>
  
</div>

<script>
  function initMobileNav() {
    const openBtn = document.getElementById("mobile-menu-open");
    const closeBtn = document.getElementById("mobile-menu-close");
    const drawer = document.getElementById("mobile-menu-drawer");
    const links = document.querySelectorAll(".mobile-nav-link");

    if (!openBtn || !closeBtn || !drawer) return;

    if (drawer.parentElement !== document.body) {
      document.body.appendChild(drawer);
    }

    const openMenu = () => {
      drawer.classList.remove("opacity-0", "pointer-events-none", "invisible");
      drawer.classList.add("opacity-100", "pointer-events-auto", "visible");
      document.body.style.overflow = "hidden";
    };

    const closeMenu = () => {
      drawer.classList.remove("opacity-100", "pointer-events-auto", "visible");
      drawer.classList.add("opacity-0", "pointer-events-none", "invisible");
      document.body.style.overflow = "";
    };

    openBtn.onclick = openMenu;
    closeBtn.onclick = closeMenu;
    links.forEach((link) => {
      (link as HTMLElement).onclick = closeMenu;
    });

    const mq = window.matchMedia("(min-width: 640px)");
    mq.onchange = (e) => {
      if (e.matches) closeMenu();
    };
  }

  document.addEventListener("astro:page-load", initMobileNav);
  if (document.readyState !== "loading") initMobileNav();
</script>
