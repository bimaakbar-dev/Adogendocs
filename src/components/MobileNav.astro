---
// src/components/MobileNav.astro
import { NAV } from "../consts";
import Button from "./ui/Button.astro";
import Icon from "./ui/icons/Icon.astro";
import Socials from "./Socials.astro";
import Theme from "./Theme.astro";

const links = [
  ...NAV.mobileNavBar.map((item) => ({
    label: item.label,
    href: item.href,
    icon: item.icon,
  })),
];
---

<Button
  id="mobile-menu-open"
  aria-label="Open menu"
  variant="icon"
  size="md"
  thisIcon
  class="sm:hidden"
>
  <span id="mobile-chevron" class="inline-flex transition-transform duration-300">
    <Icon name="chevron-down" className="h-5 w-5" />
  </span>
</Button>

<div
  id="mobile-menu-panel"
  class="fixed left-0 right-0 z-40 overflow-hidden transition-all duration-300 ease-in-out"
  style="top: var(--header-height, 64px); max-height: 0; opacity: 0; pointer-events: none;"
>
  <div class="bg-(--bg) rounded-b-xl border-b border-(--border-subtle)/80 shadow-lg">
    <nav class="px-4 py-3 space-y-2">
      <div class="grid grid-cols-1 gap-2">
        {
          links.map((item) => (
            <a
              aria-label={item.label}
              href={item.href}
              class="mobile-nav-link flex items-center gap-3 rounded-md p-2 text-sm font-medium text-(--fg) transition-colors hover:bg-(--bg-muted) active:bg-(--bg-muted)"
            >
              <span class="inline-flex items-center justify-center w-5 h-5">
                <Icon name={item.icon as any} className="w-full h-full" />
              </span>
              {item.label}
            </a>
          ))
        }
      </div>
      <div class="flex items-center p-1 justify-between rounded-md bg-(--bg-muted)">
        <Socials />
        <Theme />
      </div>
    </nav>
  </div>
</div>

<script>
  function initMobileNav() {
    const toggleBtn = document.getElementById("mobile-menu-open");
    const chevron = document.getElementById("mobile-chevron");
    const panel = document.getElementById("mobile-menu-panel");
    const links = document.querySelectorAll(".mobile-nav-link");

    if (!toggleBtn || !chevron || !panel) return;

    let isOpen = false;

    const openMenu = () => {
      panel.style.transition = 'none';
      panel.style.maxHeight = 'auto';
      panel.style.opacity = '1';
      panel.style.pointerEvents = 'auto';
      
      const content = panel.querySelector('div');
      const height = content ? content.offsetHeight : 500;
      
      panel.style.maxHeight = '0';
      panel.style.opacity = '0';
      
      panel.offsetHeight;
      
      panel.style.transition = '';
      
      requestAnimationFrame(() => {
        panel.style.maxHeight = height + 'px';
        panel.style.opacity = '1';
        panel.style.pointerEvents = 'auto';
      });
      
      chevron.style.transform = 'rotate(180deg)';
      document.body.style.overflow = 'hidden';
      isOpen = true;
    };

    const closeMenu = () => {
      panel.style.maxHeight = '0';
      panel.style.opacity = '0';
      panel.style.pointerEvents = 'none';
      
      chevron.style.transform = 'rotate(0deg)';
      document.body.style.overflow = '';
      isOpen = false;
    };

    toggleBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (isOpen && !panel.contains(target) && target !== toggleBtn) {
        closeMenu();
      }
    });

    const mq = window.matchMedia('(min-width: 640px)');
    mq.addEventListener('change', (e) => {
      if (e.matches) closeMenu();
    });

    links.forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    let resizeTimeout: number;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(() => {
        if (isOpen) {
          const content = panel.querySelector('div');
          const height = content ? content.offsetHeight : 500;
          panel.style.maxHeight = height + 'px';
        }
      }, 200);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMobileNav);
  } else {
    initMobileNav();
  }
</script>

<style is:global>
  #mobile-menu-panel {
    transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.25s ease-in-out;
  }

  #mobile-chevron {
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: center;
  }

  #mobile-menu-open {
    border-color: var(--border);
  }
</style>
