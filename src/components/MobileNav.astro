---
// src/components/MobileNav.astro
import { NAV, ROUTES } from "../consts";

import Button from "./ui/Button.astro";
import Icon from "./ui/icons/Icon.astro";

const links = [
  { label: "Home", href: ROUTES.home },
  ...NAV.mobileNavBar.map((item) => ({
    label: item.label,
    href: item.href,
  })),
];
---

<Button
  id="mobile-menu-open"
  aria-label="Open menu"
  variant="icon"
  size="md"
  class="inline-flex shrink-0 cursor-pointer items-center p-1.5 rounded-md sm:hidden"
>
  <Icon name="menu" className="h-full w-full" />
</Button>

<div
  id="mobile-menu-drawer"
  class="pointer-events-none invisible fixed inset-0 z-50 flex flex-col bg-(--bg) opacity-0 transition-all duration-300"
>
  <header
    class="flex h-(--header-height) shrink-0 items-center justify-between border-b border-(--border-subtle) px-4"
  >
    <span class="text-sm font-semibold text-(--fg-strong)"></span>
    <Button
      type="button"
      aria-label="Close menu"
      id="mobile-menu-close"
      variant="icon"
      size="md"
      class="inline-flex shrink-0 cursor-pointer items-center p-1.5"
    >
      <Icon name="close" className="h-full w-full" />
    </Button>
  </header>

  <nav class="flex-1 overflow-y-auto px-4 py-6">
    <div class="grid grid-cols-1 gap-2">
      {
        links.map((link) => (
          <a
            aria-label={link.label}
            href={link.href}
            class="mobile-nav-link flex items-center gap-3 rounded-lg px-4 py-3 text-sm font-medium text-(--fg) transition-colors hover:bg-(--bg-muted)"
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </nav>
</div>

<script>
  function initMobileNav() {
    const openBtn = document.getElementById("mobile-menu-open");
    const closeBtn = document.getElementById("mobile-menu-close");
    const drawer = document.getElementById("mobile-menu-drawer");
    const links = document.querySelectorAll(".mobile-nav-link");

    if (!openBtn || !closeBtn || !drawer) return;

    if (drawer.parentElement !== document.body) {
      document.body.appendChild(drawer);
    }

    const openMenu = () => {
      drawer.classList.remove("opacity-0", "pointer-events-none", "invisible");
      drawer.classList.add("opacity-100", "pointer-events-auto", "visible");
      document.body.style.overflow = "hidden";
    };

    const closeMenu = () => {
      drawer.classList.remove("opacity-100", "pointer-events-auto", "visible");
      drawer.classList.add("opacity-0", "pointer-events-none", "invisible");
      document.body.style.overflow = "";
    };

    openBtn.onclick = openMenu;
    closeBtn.onclick = closeMenu;
    links.forEach((link) => {
      (link as HTMLElement).onclick = closeMenu;
    });

    const mq = window.matchMedia("(min-width: 640px)");
    mq.onchange = (e) => {
      if (e.matches) closeMenu();
    };
  }

  document.addEventListener("astro:page-load", initMobileNav);
  if (document.readyState !== "loading") initMobileNav();
</script>
