---
// Misalnya: src/components/novels/ReadingSidebar.astro
import type { CollectionEntry } from "astro:content";

import Icon from "@ui/Icons.astro";
import Sidebar from "@/components/ui/Sidebar.astro";
import Footer from "../Footer.astro";
import Badge from "../ui/Badge.astro";
import NovelNavigation from "./NovelNavigation.astro";

type NovelEntry = CollectionEntry<"novels">;
type ChapterEntry = CollectionEntry<"chapters">;

interface Props {
  novel: NovelEntry;
  chapters: ChapterEntry[];
  currentPath: string;
  slug: string;
}

const { novel, chapters, currentPath, slug } = Astro.props;
---

<Sidebar id="novel-sidebar">
  <div class="flex h-full flex-col">
    
    <div class="shrink-0">
      <div class="mb-3">
        <a
          href={`/novel/${slug}`}
          class="inline-flex items-center text-sm rounded-md p-1 gap-1.5 hover:bg-(--bg-subtle)"
          aria-label="Back to novel"
        >
          <Icon name="arrow-left" class="w-4 h-4 text-(--fg-muted)" /> Back
        </a>
      </div>

      <div class="rounded-md border border-(--border-subtle) bg-(--bg-subtle) p-3">
        <div class="flex gap-3">
          <img
            src={novel.data.cover || "/default-cover.jpg"}
            alt={novel.data.title}
            loading="lazy"
            class="aspect-2/3 w-12 rounded-sm object-cover shrink-0"
          />
          <div class="min-w-0 flex-1">
            <h2 class="truncate text-sm font-semibold text-(--fg-strong)">
              {novel.data.title}
            </h2>
            <p class="mt-1 truncate text-[11px] text-(--fg-muted)">
              {novel.data.author}
            </p>
            <div class="mt-2 flex flex-wrap gap-1">
              <Badge variant="accent" class="text-xs">
                {novel.data.status}
              </Badge>
              {novel.data.genre?.[0] && (
                <span class="rounded bg-(--bg) px-1.5 py-0.5 text-[10px] text-(--fg-muted)">
                  {novel.data.genre[0]}
                </span>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-4 flex-1 flex flex-col min-h-0">
      <NovelNavigation 
        chapters={chapters} 
        currentPath={currentPath} 
      />
    </div>

    <div class="mt-auto pt-2 shrink-0">
      <Footer />
    </div>
    
  </div>
</Sidebar>