---
// src/components/novel/NovelSidebar.astro
import type { CollectionEntry } from 'astro:content';
import Icon from "@ui/Icon.astro";
import Theme from '../Theme.astro';

// ===== Tipe Props =====
type NovelEntry = CollectionEntry<'novels'>;
type ChapterEntry = CollectionEntry<'chapters'>;

interface Props {
  novel: NovelEntry;
  chapters: ChapterEntry[];
  currentPath: string;
  slug: string;
}

const { novel, chapters, currentPath, slug } = Astro.props;

// Grouping berdasarkan volume (default 1 jika tidak ada)
const groupedByVolume = chapters.reduce((acc, ch) => {
  const vol = ch.data.volume ?? 1;
  if (!acc[vol]) acc[vol] = [];
  acc[vol].push(ch);
  return acc;
}, {} as Record<number, ChapterEntry[]>);

const sortedVolumes = Object.keys(groupedByVolume)
  .map(Number)
  .sort((a, b) => a - b);

const getChapterClass = (isActive: boolean) => {
  const base = "block px-3 py-1.5 rounded-md text-sm transition hover:bg-(--bg-subtle)";
  if (isActive) {
    return `${base} bg-(--bg-muted) text-(--fg-strong) font-medium`;
  }
  return `${base} text-(--fg-muted) hover:text-(--fg-strong)`;
};

const s = {
  wrapper: 'h-full overflow-y-auto flex flex-col',
  header: 'flex-shrink-0 p-3 border border-(--border-subtle) bg-(--bg-subtle) rounded-md',
  main: 'flex-1 overflow-y-auto p-2 space-y-3',
  footer: 'flex-shrink-0 p-3 border-t border-(--border-subtle) bg-(--surface) flex justify-end',
};
---

<div id="novel-sidebar" class={s.wrapper}>
  <div class="flex items-center justify-between mb-2">
    <a href={`/novel/${slug}`} class="p-1 rounded-md hover:bg-(--bg-subtle) transition" title="Kembali ke Detail Novel">
      <Icon name="chevron-left" className="w-5 h-5 text-(--fg-muted)" />
    </a>
    <!-- Logo bisa ditambahkan di sini jika diperlukan -->
  </div>

  <div class={s.header}>
    <div class="flex items-start gap-2">
      <img 
        src={novel.data.cover || '/default-cover.jpg'} 
        alt={novel.data.title}
        class="aspect-2/3 w-12 h-auto object-cover rounded-sm shadow-sm shrink-0"
        loading="lazy"
      />
      <div class="flex-1 min-w-0">
        
        <h3 class="font-semibold text-sm leading-tight truncate mb-2" title={novel.data.title}>
          {novel.data.title}
        </h3>
        <p class="text-[10px] text-(--fg-muted) truncate">
          {novel.data.author}
        </p>
        <div class="flex flex-wrap items-center gap-1.5 mb-0.5">
          <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200">
            {novel.data.status}
          </span>
          {novel.data.genre?.[0] && (
            <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-(--bg-subtle) text-(--fg-muted)">
              {novel.data.genre[0]}
            </span>
          )}
        </div>
      </div>
    </div>
  </div>
  <div class={s.main}>
    {sortedVolumes.length === 0 ? (
      <p class="text-sm text-(--fg-muted) px-2">Belum ada bab</p>
    ) : sortedVolumes.length === 1 ? (
      <ul class="space-y-0.5">
        {groupedByVolume[sortedVolumes[0]].map((ch) => {
          const isActive = ch.id === currentPath;
          return (
            <li>
              <a
                href={`/novel/${ch.id}`}
                class={getChapterClass(isActive)}
                aria-current={isActive ? "page" : undefined}
              >
                {ch.data.title}
              </a>
            </li>
          );
        })}
      </ul>
    ) : (
      sortedVolumes.map((vol) => {
        const chapterList = groupedByVolume[vol];
        const hasActive = chapterList.some(ch => ch.id === currentPath);
        
        return (
          <details class="group" open={hasActive}>
            <summary class="flex items-center justify-between list-none cursor-pointer select-none rounded-md hover:bg-(--bg-subtle) active:bg-(--bg-subtle) px-2 py-1.5 [&::-webkit-details-marker]:hidden">
              <span class="text-xs font-bold text-(--fg-muted) uppercase tracking-wider">
                Volume {vol}
              </span>
              <Icon name="chevron-right" className="w-4 h-4 transition-transform duration-200 group-open:rotate-90 text-(--fg-muted)" />
            </summary>
            <ul class="relative flex flex-col mt-1 overflow-hidden transition-all duration-300 ease-in-out max-h-0 group-open:max-h-[2000px] group-open:opacity-100 opacity-0">
              {chapterList.map((ch) => {
                const isActive = ch.id === currentPath;
                return (
                  <li class="relative border-l border-(--border) px-2 ml-4">
                    <a
                      href={`/novel/${ch.id}`}
                      class={getChapterClass(isActive)}
                      aria-current={isActive ? "page" : undefined}
                    >
                      {ch.data.title}
                    </a>
                  </li>
                );
              })}
            </ul>
          </details>
        );
      })
    )}
  </div>
  <div class={s.footer}>
    <Theme />
  </div>
</div>

<style is:global>
  /* Scrollbar */
  #novel-sidebar {
    scrollbar-width: thin;
    scrollbar-color: var(--border-subtle) transparent;
  }
  #novel-sidebar::-webkit-scrollbar {
    width: 4px;
  }
  #novel-sidebar::-webkit-scrollbar-track {
    background: transparent;
  }
  #novel-sidebar::-webkit-scrollbar-thumb {
    background: var(--border-subtle);
    border-radius: 9999px;
  }

  /* Animasi Accordion */
  #novel-sidebar details > ul {
    max-height: 0;
    opacity: 0;
    transition: max-height 0.3s ease-in-out, opacity 0.3s ease-in-out;
    margin-top: 0;
  }
  #novel-sidebar details[open] > ul {
    max-height: 2000px;
    opacity: 1;
    margin-top: 0.25rem;
  }
  #novel-sidebar details > ul > li {
    transition: opacity 0.2s ease-in-out;
  }
  #novel-sidebar details:not([open]) > ul > li {
    opacity: 0;
  }
  #novel-sidebar details[open] > ul > li {
    opacity: 1;
  }
</style>

<script>
  (function() {
    const sidebar = document.getElementById('novel-sidebar');
    if (sidebar) {
      const detailsElements = sidebar.querySelectorAll('details');
      detailsElements.forEach((details, index) => {
        const storageKey = `novel-sidebar-vol-${index}`;
        const stored = localStorage.getItem(storageKey);
        if (stored === 'collapsed') details.open = false;
        else if (stored === 'expanded') details.open = true;

        details.addEventListener('toggle', function() {
          localStorage.setItem(storageKey, this.open ? 'expanded' : 'collapsed');
        });
      });
    }
  })();
</script>