---
// src/components/novel/NovelChapterList.astro

import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";

import NovelVolume from "./NovelVolume.astro";
import NovelChapterItem from "./NovelChapterItem.astro";

interface Props {
  chapters: CollectionEntry<"chapters">[];
  currentPath?: string;
}

const {
  chapters,
  currentPath = "",
} = Astro.props;

const groupedByVolume = chapters.reduce((acc, chapter) => {
  const volId = chapter.data.volume?.id || 'unassigned';
  if (!acc[volId]) acc[volId] = [];
  acc[volId].push(chapter);
  return acc;
}, {} as Record<string, CollectionEntry<"chapters">[]>);

const volumeKeys = Object.keys(groupedByVolume);
const isMultiVolume = volumeKeys.length > 1;

const hasRealVolumes = volumeKeys.some(id => id !== 'unassigned');

let allVolumes: CollectionEntry<"volumes">[] = [];
if (hasRealVolumes) {
  try {
    allVolumes = (await getCollection("volumes")) || [];
  } catch (e) {
    allVolumes = [];
  }
}

const volumesData = volumeKeys.map((volId) => {
  const items = groupedByVolume[volId].sort((a, b) => a.data.chapterNumber - b.data.chapterNumber);
  const volumeData = allVolumes.find(v => v.id === volId);
  const volumeNumber = volumeData?.data.volumeNumber || 1;
  return { id: volId, volumeNumber, items };
}).sort((a, b) => a.volumeNumber - b.volumeNumber);

const $ = {
  wrapper: "mt-10",
  header: "mb-6",
  title: "text-heading-24 font-semibold text-(--fg-strong)",
  subtitle: "mt-2 text-body-15 text-(--fg-muted)",
  list: "space-y-4",
  single: "space-y-3",
};

const checkIsActive = (chapterId: string) => {
  return currentPath === chapterId || currentPath.includes(`/${chapterId}`);
};
---

<section id="chapters" class={$.wrapper} aria-labelledby="novel-chapters">
  <header class={$.header}>
    <h2 id="novel-chapters" class={$.title}>Chapters</h2>
    <p class={$.subtitle}>{chapters.length} Chapters Available</p>
  </header>

  {
    !isMultiVolume ? (
      <div class={$.single}>
        {volumesData[0]?.items.map((chapter) => (
          <NovelChapterItem
            chapter={chapter}
            active={checkIsActive(chapter.id)}
          />
        ))}
      </div>
    ) : (
      <div class={$.list}>
        {volumesData.map((vol) => (
          <NovelVolume
            volume={vol.volumeNumber}
            chapters={vol.items}
            currentPath={currentPath}
            defaultOpen={vol.items.some(chapter => checkIsActive(chapter.id))}
          />
        ))}
      </div>
    )
  }
</section>