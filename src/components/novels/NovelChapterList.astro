---
// src/components/novel/NovelChapterList.astro

import type { CollectionEntry } from "astro:content";

import NovelVolume from "./NovelVolume.astro";
import NovelChapterItem from "./NovelChapterItem.astro";

interface Props {
  chapters: CollectionEntry<"chapters">[];
  currentPath?: string;
}

const {
  chapters,
  currentPath = "",
} = Astro.props;

const grouped = chapters.reduce(
  (acc, chapter) => {
    const volume = chapter.data.volume ?? 1;

    if (!acc[volume]) {
      acc[volume] = [];
    }

    acc[volume].push(chapter);

    return acc;
  },
  {} as Record<number, CollectionEntry<"chapters">[]>,
);

const volumes = Object.keys(grouped)
  .map(Number)
  .sort((a, b) => a - b);

const singleVolume = volumes.length === 1;

const $ = {
  wrapper: "mt-10",

  header: "mb-6",

  title:
    "text-heading-24 font-semibold text-(--fg-strong)",

  subtitle:
    "mt-2 text-body-15 text-(--fg-muted)",

  list:
    "space-y-4",

  single:
    "space-y-3",
};
---

<section
  id="chapters"
  class={$.wrapper}
  aria-labelledby="novel-chapters"
>
  <header class={$.header}>
    <h2
      id="novel-chapters"
      class={$.title}
    >
      Chapters
    </h2>

    <p class={$.subtitle}>
      {chapters.length} Chapters Available
    </p>
  </header>

  {
    singleVolume ? (
      <div class={$.single}>
        {grouped[volumes[0]].map((chapter) => (
          <NovelChapterItem
            chapter={chapter}
            active={chapter.id === currentPath}
          />
        ))}
      </div>
    ) : (
      <div class={$.list}>
        {volumes.map((volume) => (
          <NovelVolume
            volume={volume}
            chapters={grouped[volume]}
            currentPath={currentPath}
            defaultOpen={
              grouped[volume].some(
                (chapter) => chapter.id === currentPath,
              )
            }
          />
        ))}
      </div>
    )
  }
</section>