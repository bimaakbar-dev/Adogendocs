---
// src/components/novels/NovelNavigation.astro
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import SidebarLink from '@/components/ui/SidebarLink.astro';

type ChapterEntry = CollectionEntry<"chapters">;

interface Props {
  chapters: ChapterEntry[];
  currentPath: string;
}

const { chapters, currentPath } = Astro.props;

const checkIsActive = (href: string) => {
  return currentPath === href || currentPath === `${href}/`;
};

const groupedByVolume = chapters.reduce((acc, chapter) => {
  const volId = chapter.data.volume?.id || 'unassigned';
  if (!acc[volId]) acc[volId] = [];
  acc[volId].push(chapter);
  return acc;
}, {} as Record<string, ChapterEntry[]>);

const volumeKeys = Object.keys(groupedByVolume);
const isMultiVolume = volumeKeys.length > 1;

const hasRealVolumes = volumeKeys.some(id => id !== 'unassigned');

let allVolumes: CollectionEntry<"volumes">[] = [];
if (hasRealVolumes) {
  try {
    allVolumes = (await getCollection("volumes")) || [];
  } catch (e) {
    allVolumes = [];
  }
}

const volumesData = volumeKeys.map((volId) => {
  const items = groupedByVolume[volId].sort(
    (a, b) => a.data.chapterNumber - b.data.chapterNumber
  );
  const volumeData = allVolumes.find(v => v.id === volId);
  const volumeNumber = volumeData?.data.volumeNumber || 1;
  
  return { 
    id: volId, 
    volumeNumber, 
    showVolumeLabel: volId !== 'unassigned' && isMultiVolume,
    chapters: items 
  };
}).sort((a, b) => a.volumeNumber - b.volumeNumber);
---

<nav class="flex-1 overflow-y-auto space-y-3 pb-2 px-2 scrollbar-hide w-full">
  {
    volumesData.length === 0 ? (
      <p class="px-2 text-sm text-(--fg-muted)">No chapters available.</p>
    ) : !isMultiVolume ? (
      <div class="flex flex-col space-y-0.5">
        {volumesData[0]?.chapters.map((chapter) => {
          const href = `/novel/${chapter.id}`;
          return (
            <SidebarLink href={href} isActive={checkIsActive(href)}>
              Chapter {chapter.data.chapterNumber}: {chapter.data.title}
            </SidebarLink>
          );
        })}
      </div>
    ) : (
      volumesData.map((vol) => (
        <div class="mb-3 last:mb-0">
          {vol.showVolumeLabel && (
            <div class="px-2 mb-1.5 mt-2 text-[10px] font-bold text-(--fg-muted) uppercase tracking-wider select-none">
              Volume {vol.volumeNumber}
            </div>
          )}
          <div class="flex flex-col space-y-0.5 ml-1.5 pl-2 border-l border-(--border)">
            {vol.chapters.map((chapter) => {
              const href = `/novel/${chapter.id}`;
              return (
                <SidebarLink href={href} isActive={checkIsActive(href)}>
                  Chapter {chapter.data.chapterNumber}: {chapter.data.title}
                </SidebarLink>
              );
            })}
          </div>
        </div>
      ))
    )
  }
</nav>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>