---
// src/components/Header.astro
import Container from "./ui/Container.astro";
import Socials from "./Socials.astro";
import Mobile from "./MobileNav.astro";
import Theme from "./Theme.astro";
import Logo from "./ui/Logo.astro";
import SearchBar from "./ui/SearchBar.astro";
import NavLink from "./NavLink.astro";

const $ = {
  header: "sticky top-0 z-50 w-full bg-transparent border-b border-(--border-subtle)/40 lg:border-transparent h-full pt-(--safe-top) transition-opacity duration-(--duration) ease-out",
  wrapper: "mx-auto flex h-(--header-height) w-full items-center justify-between",
  left: "flex items-center shrink-0 gap-4",
  right: "flex items-center shrink-0 gap-0.5"
}
---
<header id="main-header" class={$.header}>
  <Container size="full">
    <div class={$.wrapper}>
      <div class={$.left}>
        <Logo />
        <NavLink />
      </div>
      <div class={$.right}>
        <div class="items-center flex md:hidden">
          <SearchBar iconOnly />
        </div>
        <div class="items-center hidden md:flex gap-2">
          <SearchBar />
          <Socials />
          <Theme />
        </div>
        <Mobile />
      </div>
    </div>
  </Container>
</header>

<script is:inline>
  (() => {
    const header = document.getElementById("main-header");
    if (!header) return;

    const toggleHeader = () => {
      if (window.scrollY > 10) {
        header.classList.add(
          "bg-(--bg)/80",
          "backdrop-blur-md",
          "lg:border-(--border-subtle)/40",
          "shadow-sm"
        );
        header.classList.remove(
          "bg-transparent",
          "lg:border-transparent"
        );
      } else {
        header.classList.remove(
          "bg-(--bg)/80",
          "backdrop-blur-md",
          "lg:border-(--border-subtle)/40",
          "shadow-sm"
        );
        header.classList.add(
          "bg-transparent",
          "lg:border-transparent"
        );
      }
    };

    window.removeEventListener("scroll", toggleHeader);
    window.addEventListener("scroll", toggleHeader, { passive: true });
    
    toggleHeader();
  })();
</script>
