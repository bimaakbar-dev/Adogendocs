---
// src/components/Theme.astro
import Button from "@ui/Button.astro";
import Icon from "@ui/Icon.astro";
---

<Button
  class="theme-toggle"
  variant="icon"
  size="sm"
  aria-label="Toggle tema"
>
  <Icon name="moon" className="block h-4 w-4 dark:hidden" />
  <Icon name="sun" className="hidden h-4 w-4 dark:block" />
</Button>

<script is:inline>
  (() => {
    const html = document.documentElement;

    function updateTheme(isDark) {
      if (isDark) {
        html.classList.add("dark");
        html.style.colorScheme = "dark";
      } else {
        html.classList.remove("dark");
        html.style.colorScheme = "light";
      }
      localStorage.setItem("a0-theme", isDark ? "dark" : "light");
    }

    document.addEventListener("click", (e) => {
      const btn = e.target.closest(".theme-toggle");
      if (!btn) return;

      const isDark = html.classList.contains("dark");
      updateTheme(!isDark);
      
      window.dispatchEvent(new CustomEvent("theme-changed", { detail: { isDark: !isDark } }));
    });

    window.addEventListener("storage", (e) => {
      if (e.key === "a0-theme") updateTheme(e.newValue === "dark");
    });

    window.addEventListener("theme-changed", (e) => updateTheme(e.detail.isDark));

    const stored = localStorage.getItem("a0-theme");
    const isDark = stored ? stored === "dark" : window.matchMedia("(prefers-color-scheme: dark)").matches;
    updateTheme(isDark);
  })();
</script>
