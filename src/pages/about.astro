---
// src/pages/about.astro
import Layout from "@/layouts/Layout.astro";
import Icon from "@/components/ui/Icon.astro";
import {
  SITE,
  ROUTES,
  buildMeta,
  schemaWebPage,
  schemaBreadcrumb,
  schemaOrganization,
} from "@/consts";

const meta = buildMeta({
  title: "About",
  description:
    "Adogen adalah alat gratis bertenaga AI untuk kontributor Adobe Stock — dibuat untuk menghemat waktu, menjaga privasi, dan menghasilkan metadata profesional tanpa kerumitan.",
  canonical: `${SITE.url}${ROUTES.about}`,
  ogType: "website",
});

const schemas = [
  schemaWebPage({
    title: `About | ${SITE.name}`,
    description: meta.description,
    url: `${SITE.url}${ROUTES.about}`,
    type: "AboutPage",
  }),
  schemaBreadcrumb([
    { name: "Home", url: SITE.url },
    { name: "About", url: `${SITE.url}${ROUTES.about}` },
  ]),
  schemaOrganization,
];

const values = [
  {
    icon: "shield",
    label: "Privacy",
    title: "Zero Server Storage",
    desc: "Kunci API dan gambar tidak pernah menyentuh server kami. Semua pemrosesan terjadi di browser Anda — tidak ada yang kami simpan.",
  },
  {
    icon: "clock",
    label: "Efficiency",
    title: "Batch at Scale",
    desc: "Metadata untuk 50+ gambar dalam hitungan menit. Tidak ada lagi keywording manual yang menguras waktu dan energi.",
  },
  {
    icon: "sparkles",
    label: "Quality",
    title: "Commercial-Grade Output",
    desc: "Judul SEO-optimized, 50 kata kunci terurut relevansi, dan kategori Adobe Stock yang tepat — setiap saat.",
  },
  {
    icon: "lock",
    label: "BYOK",
    title: "Bring Your Own Key",
    desc: "Tidak ada biaya tersembunyi. Bayar langsung ke provider AI pilihan Anda. Kami hanya menyediakan antarmukanya.",
  },
  {
    icon: "layers",
    label: "Resilience",
    title: "Multi-Engine Fallback",
    desc: "Groq, Mistral, OpenRouter, Cloudflare, atau endpoint kustom — fallback otomatis jika satu engine gagal.",
  },
  {
    icon: "code",
    label: "Transparency",
    title: "No Black Boxes",
    desc: "Anda tahu persis ke mana data Anda pergi. Langsung ke engine AI pilihan Anda, tanpa perantara tersembunyi.",
  },
];

const engines = [
  {
    id: "groq",
    name: "Groq",
    model: "Llama 4 Scout · Mixtral 8x7B",
    badge: "Fastest",
    color: "text-orange-400",
    dot: "bg-orange-400",
  },
  {
    id: "mistral",
    name: "Mistral AI",
    model: "Mistral Medium · Pixtral 12B",
    badge: "Multimodal",
    color: "text-violet-400",
    dot: "bg-violet-400",
  },
  {
    id: "openrouter",
    name: "OpenRouter",
    model: "GPT-4o Mini · Qwen VL Plus",
    badge: "Multi-model",
    color: "text-sky-400",
    dot: "bg-sky-400",
  },
  {
    id: "cf",
    name: "Cloudflare Workers",
    model: "LLaVA 1.5 7B · Phi 3.5 Vision",
    badge: "Free Tier",
    color: "text-amber-400",
    dot: "bg-amber-400",
  },
  {
    id: "custom",
    name: "Custom Endpoint",
    model: "Any OpenAI-compatible API",
    badge: "Self-hosted",
    color: "text-(--fg-muted)",
    dot: "bg-(--fg-muted)",
  },
];

const stats = [
  { value: "50+", label: "Gambar per batch" },
  { value: "5", label: "Engine AI" },
  { value: "0", label: "Data di server" },
  { value: "21", label: "Kategori Stock" },
];
---

<Layout {meta} schema={schemas}>
  <div
    class="relative flex w-full flex-1 flex-col items-center overflow-hidden bg-(--bg) selection:bg-(--fg-strong) selection:text-(--bg)"
  >
    <div class="pointer-events-none fixed inset-0 z-0 flex justify-center">
      <div
        class="animate-pulse-slow absolute top-[-10%] h-150 w-[80vw] rounded-full bg-(--brand-blue) opacity-[0.06] mix-blend-normal blur-[150px] dark:mix-blend-screen"
      >
      </div>
      <div
        class="animate-grid-scroll absolute inset-0 bg-[radial-gradient(var(--border-strong)_1px,transparent_1px)] mask-[linear-gradient(to_bottom,black_30%,transparent_100%)] bg-size-[32px_32px] opacity-40"
      >
      </div>
    </div>
    <div
      class="relative z-10 hidden h-0 w-full border-b border-(--border-strong)"
    >
      <div
        class="text-mono-label-12 mx-auto flex max-w-300 items-center gap-1.5 px-4 py-3 tracking-widest text-(--fg-subtle) uppercase sm:px-6"
      >
        <a
          href={ROUTES.home}
          class="transition-colors duration-150 hover:text-(--fg-strong)"
          >Home</a
        >
        <span class="opacity-40">/</span>
        <span class="text-(--fg-muted)">About</span>
      </div>
    </div>
    <section
      class="relative z-10 mx-auto flex w-full max-w-300 flex-col items-center px-4 pt-28 pb-20 text-center sm:px-6"
    >
      <div
        class="animate-in fade-in slide-in-from-bottom-4 fill-mode-both text-label-12 mb-10 inline-flex items-center gap-2.5 rounded-full border border-(--border-strong) bg-(--surface-subtle)/80 px-3 py-1.5 text-(--fg-muted) shadow-sm backdrop-blur-md duration-700 ease-out"
      >
        <span class="relative flex h-2 w-2">
          <span
            class="absolute inline-flex h-full w-full animate-ping rounded-full bg-(--brand-blue) opacity-75"
          ></span>
          <span
            class="relative inline-flex h-2 w-2 rounded-full bg-(--brand-blue)"
          ></span>
        </span>
        About <span class="ml-1 text-(--fg-strong)">{SITE.name}</span>
      </div>
      <h1
        class="animate-in fade-in slide-in-from-bottom-6 fill-mode-both text-display-64 sm:text-display-80 lg:text-display-96 mb-6 text-balance text-(--fg-strong) drop-shadow-sm delay-150 duration-1000 ease-out"
      >
        Built for<br />
        <span
          class="bg-linear-to-b from-(--fg-strong) to-(--fg-muted) bg-clip-text text-transparent"
          >Contributors.</span
        >
      </h1>
      <p
        class="animate-in fade-in slide-in-from-bottom-4 fill-mode-both text-body-18 sm:text-body-20 mb-14 max-w-2xl text-balance text-(--fg-muted) delay-300 duration-1000 ease-out"
      >
        Adogen lahir dari frustrasi nyata: menulis metadata untuk ratusan aset
        secara manual itu melelahkan. Kami membangun solusi yang menghargai <strong
          class="text-(--fg-strong)">waktu dan privasi Anda.</strong
        >
      </p>
      <div
        class="animate-in fade-in zoom-in-95 fill-mode-both grid w-full max-w-2xl grid-cols-2 divide-x divide-(--border-strong) overflow-hidden rounded-2xl border border-(--border-strong) bg-(--surface-elevated)/90 shadow-[0_20px_40px_-15px_rgba(0,0,0,0.15)] backdrop-blur-xl delay-500 duration-1000 ease-out sm:grid-cols-4"
      >
        {
          stats.map((s, i) => (
            <div
              class:list={[
                "flex flex-col items-center justify-center gap-1 py-6",
                i % 2 === 0 && i > 1
                  ? "border-t border-(--border-strong) sm:border-t-0"
                  : "",
              ]}
            >
              <span class="text-heading-40 font-black tracking-tighter text-(--fg-strong) tabular-nums">
                {s.value}
              </span>
              <span class="text-mono-label-12 tracking-widest text-(--fg-subtle) uppercase">
                {s.label}
              </span>
            </div>
          ))
        }
      </div>
    </section>
    <section class="relative z-10 mx-auto w-full max-w-300 px-4 pb-24 sm:px-6">
      <div
        class="mb-12 flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end"
      >
        <div>
          <p
            class="text-overline-12 mb-3 tracking-widest text-(--fg-muted) uppercase"
          >
            Core Principles
          </p>
          <h2 class="text-heading-40 sm:text-heading-56 text-(--fg-strong)">
            Engineered with <span
              class="bg-linear-to-r from-(--fg-subtle) to-(--fg-strong) bg-clip-text text-transparent"
              >intent.</span
            >
          </h2>
        </div>
        <p class="text-body-16 max-w-[38ch] text-(--fg-muted) sm:text-right">
          Enam prinsip yang menjadi fondasi setiap keputusan desain dan teknis.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-4 sm:gap-6 lg:grid-cols-12">
        <div
          class="group animate-in fade-in slide-in-from-bottom-4 fill-mode-both relative flex flex-col justify-between overflow-hidden rounded-2xl border border-(--border-strong) bg-(--surface) p-8 transition-all duration-300 duration-700 hover:border-(--fg-subtle) hover:shadow-lg sm:p-10 lg:col-span-5"
        >
          <div
            class="pointer-events-none absolute right-0 bottom-0 h-2/3 w-2/3 translate-x-6 translate-y-6 opacity-10 transition-transform duration-700 group-hover:translate-x-3"
          >
            <div
              class="flex h-full w-full items-center justify-center rounded-tl-xl border border-(--border-strong) bg-(--surface-elevated)"
            >
              <Icon name="shield" className="h-24 w-24 text-(--fg-dim)" />
            </div>
          </div>
          <div class="relative z-10">
            <div class="mb-8 flex items-center justify-between">
              <div
                class="inline-flex h-14 w-14 items-center justify-center rounded-xl border border-(--border-strong) bg-(--surface-elevated) text-(--fg-strong) shadow-sm transition-transform duration-300 group-hover:scale-110 group-hover:text-(--brand-blue)"
              >
                <Icon name="shield" className="h-6 w-6" />
              </div>
              <span
                class="text-overline-11 tracking-widest text-(--fg-dim) uppercase"
                >01</span
              >
            </div>
            <span
              class="text-mono-label-12 mb-3 block tracking-widest text-(--brand-blue) uppercase"
              >{values[0].label}</span
            >
            <h3 class="text-heading-32 mb-4 text-(--fg-strong)">
              {values[0].title}
            </h3>
            <p class="text-body-16 text-(--fg-muted)">{values[0].desc}</p>
          </div>
        </div>
        <div class="flex flex-col gap-4 sm:gap-6 lg:col-span-7">
          {
            values.slice(1, 3).map((v, i) => (
              <div
                class:list={[
                  "group animate-in fade-in slide-in-from-bottom-4 fill-mode-both relative flex items-start gap-6 overflow-hidden rounded-2xl border border-(--border-strong) bg-(--surface) p-7 transition-all duration-300 hover:border-(--fg-subtle) hover:shadow-lg",
                  `duration-${700 + i * 100}`,
                ]}
              >
                <div class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-(--border-strong) bg-(--surface-elevated) text-(--fg-strong) shadow-sm transition-transform duration-300 group-hover:scale-110 group-hover:text-(--brand-blue)">
                  <Icon name={v.icon as any} className="w-5 h-5" />
                </div>
                <div>
                  <div class="mb-2 flex items-center gap-3">
                    <span class="text-mono-label-12 tracking-widest text-(--brand-blue) uppercase">
                      {v.label}
                    </span>
                    <span class="text-overline-11 text-(--fg-dim)">
                      0{i + 2}
                    </span>
                  </div>
                  <h3 class="text-heading-20 mb-2 text-(--fg-strong)">
                    {v.title}
                  </h3>
                  <p class="text-body-14 text-(--fg-muted)">{v.desc}</p>
                </div>
              </div>
            ))
          }
        </div>
        {
          values.slice(3).map((v, i) => (
            <div
              class:list={[
                "group animate-in fade-in slide-in-from-bottom-4 fill-mode-both relative flex flex-col gap-5 overflow-hidden rounded-2xl border border-(--border-strong) bg-(--surface) p-7 transition-all duration-300 hover:border-(--brand-blue) hover:shadow-lg lg:col-span-4",
                `duration-${800 + i * 100}`,
              ]}
            >
              <div class="flex items-center justify-between">
                <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl border border-(--border-strong) bg-(--surface-elevated) text-(--fg-strong) shadow-sm transition-transform duration-300 group-hover:scale-110 group-hover:text-(--brand-blue)">
                  <Icon name={v.icon as any} className="w-5 h-5" />
                </div>
                <span class="text-overline-11 text-(--fg-dim)">0{i + 4}</span>
              </div>
              <div>
                <span class="text-mono-label-12 mb-2 block tracking-widest text-(--brand-blue) uppercase">
                  {v.label}
                </span>
                <h3 class="text-heading-18 mb-2 text-(--fg-strong)">
                  {v.title}
                </h3>
                <p class="text-body-14 text-(--fg-muted)">{v.desc}</p>
              </div>
            </div>
          ))
        }
      </div>
    </section>
    <section
      class="relative z-10 w-full border-t border-(--border-strong) bg-(--surface-subtle)/50 py-24"
    >
      <div class="mx-auto max-w-300 px-4 sm:px-6">
        <div class="mb-12">
          <p
            class="text-overline-12 mb-3 tracking-widest text-(--fg-muted) uppercase"
          >
            Workflow
          </p>
          <h2 class="text-heading-40 sm:text-heading-56 text-(--fg-strong)">
            Three steps. <span
              class="bg-linear-to-r from-(--fg-subtle) to-(--fg-strong) bg-clip-text text-transparent"
              >Zero friction.</span
            >
          </h2>
        </div>

        <div
          class="w-full overflow-hidden rounded-2xl border border-(--border-strong) bg-(--surface-elevated)/90 shadow-[0_30px_60px_-15px_rgba(0,0,0,0.2)] ring-1 ring-(--border-subtle) backdrop-blur-xl"
        >
          <div
            class="flex items-center gap-2 border-b border-(--border) bg-(--surface-subtle) px-4 py-3"
          >
            <div class="mr-2 flex gap-1.5">
              <div
                class="h-3 w-3 rounded-full bg-(--border-strong) transition-colors hover:bg-[#ff5f56]"
              >
              </div>
              <div
                class="h-3 w-3 rounded-full bg-(--border-strong) transition-colors hover:bg-[#ffbd2e]"
              >
              </div>
              <div
                class="h-3 w-3 rounded-full bg-(--border-strong) transition-colors hover:bg-[#27c93f]"
              >
              </div>
            </div>
            <span
              class="text-mono-label-12 tracking-widest text-(--fg-muted) uppercase"
              >adogen — workflow</span
            >
          </div>

          <div class="divide-y divide-(--border-strong)">
            {
              [
                {
                  n: "01",
                  tag: "UPLOAD",
                  title: "Unggah Gambar",
                  desc: "Seret & lepas satu atau banyak gambar ke area upload. Gambar dikonversi ke base64 di browser — tidak ada yang dikirim ke server kami.",
                  log: "> Reading file buffer... [OK]\n> Converting to base64... [OK]\n> Queued for processing [42 files]",
                },
                {
                  n: "02",
                  tag: "CONFIGURE",
                  title: "Pilih Engine & Konfigurasi",
                  desc: "Masukkan kunci API, pilih model AI, atur panjang judul, jumlah kata kunci, dan preferensi lainnya di panel pengaturan.",
                  log: "> Engine: Groq / llama-4-scout\n> Max keywords: 50\n> Title length: 200 chars",
                },
                {
                  n: "03",
                  tag: "EXPORT",
                  title: "Generate & Ekspor ke CSV",
                  desc: "Klik Generate. AI menganalisis gambar secara visual dan menghasilkan judul, kata kunci, dan kategori. Ekspor hasil ke CSV — siap upload ke Adobe Stock.",
                  log: "> Payload received (38ms)\n> Writing metadata... [OK]\n> CSV export ready ✓",
                },
              ].map((s, i) => (
                <div class="group flex flex-col items-start gap-6 px-8 py-8 transition-colors duration-200 hover:bg-(--surface-subtle)/50 sm:flex-row sm:gap-10">
                  <div class="flex shrink-0 items-center gap-5 sm:w-64">
                    <span class="text-display-64 leading-none font-black text-(--border-strong) tabular-nums transition-colors duration-300 select-none group-hover:text-(--brand-blue)">
                      {s.n}
                    </span>
                    <div>
                      <span class="text-overline-10 mb-1 block tracking-widest text-(--brand-blue) uppercase">
                        {s.tag}
                      </span>
                      <h3 class="text-heading-18 text-(--fg-strong)">
                        {s.title}
                      </h3>
                    </div>
                  </div>
                  <div class="flex flex-1 flex-col gap-6 sm:flex-row">
                    <p class="text-body-14 max-w-[44ch] flex-1 text-(--fg-muted)">
                      {s.desc}
                    </p>
                    <div class="wrap text-code-12 shrink-0 rounded-xl border border-(--border) bg-(--bg) p-3 font-mono leading-relaxed text-(--fg-muted) sm:w-56">
                      {s.log.split("\n").map((line) => (
                        <div
                          class:list={[
                            line.includes("[OK]") || line.includes("✓")
                              ? "text-(--success)"
                              : line.includes("[") && !line.includes("[OK]")
                                ? "text-(--brand-blue)"
                                : "",
                          ]}
                        >
                          {line}
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>
    <section class="relative z-10 mx-auto w-full max-w-300 px-4 py-24 sm:px-6">
      <div
        class="mb-12 flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end"
      >
        <div>
          <p
            class="text-overline-12 mb-3 tracking-widest text-(--fg-muted) uppercase"
          >
            Compatibility
          </p>
          <h2 class="text-heading-40 sm:text-heading-56 text-(--fg-strong)">
            Five engines. <span
              class="bg-linear-to-r from-(--fg-subtle) to-(--fg-strong) bg-clip-text text-transparent"
              >One interface.</span
            >
          </h2>
        </div>
        <p class="text-body-16 max-w-[36ch] text-(--fg-muted) sm:text-right">
          Tidak terikat ke satu provider. Fallback otomatis jika engine utama
          gagal.
        </p>
      </div>

      <div
        class="overflow-hidden rounded-2xl border border-(--border-strong) bg-(--surface-elevated)/90 shadow-[0_30px_60px_-15px_rgba(0,0,0,0.2)] ring-1 ring-(--border-subtle) backdrop-blur-xl"
      >
        <div
          class="grid grid-cols-[auto_1fr_auto] items-center border-b border-(--border) bg-(--surface-subtle) px-6 py-3 sm:grid-cols-[auto_1fr_1fr_auto]"
        >
          <span
            class="text-overline-11 w-28 tracking-widest text-(--fg-subtle) uppercase"
            >Engine</span
          >
          <span
            class="text-overline-11 hidden tracking-widest text-(--fg-subtle) uppercase sm:block"
            >Models</span
          >
          <span
            class="text-overline-11 hidden tracking-widest text-(--fg-subtle) uppercase sm:block"
            >Keterangan</span
          >
          <span
            class="text-overline-11 text-right tracking-widest text-(--fg-subtle) uppercase"
            >Status</span
          >
        </div>

        {
          engines.map((e, i) => (
            <div
              class:list={[
                "group grid grid-cols-[auto_1fr_auto] items-center px-6 py-4 transition-colors duration-150 hover:bg-(--surface-subtle)/60 sm:grid-cols-[auto_1fr_1fr_auto]",
                i < engines.length - 1 ? "border-b border-(--border)" : "",
              ]}
            >
              <div class="flex w-28 items-center gap-3">
                <span class:list={["h-2 w-2 shrink-0 rounded-full", e.dot]} />
                <span class:list={["text-label-14 font-semibold", e.color]}>
                  {e.name}
                </span>
              </div>
              <span class="text-body-13 hidden pr-4 text-(--fg-muted) sm:block">
                {e.model}
              </span>
              <span class="text-body-13 hidden text-(--fg-subtle) sm:block" />
              <div class="ml-auto flex items-center gap-2">
                <span
                  class:list={[
                    "text-mono-label-12 inline-flex items-center rounded-md border px-2.5 py-1 tracking-widest uppercase",
                    e.id === "cf"
                      ? "border-(--success)/20 bg-(--success)/10 text-(--success)"
                      : "border-(--border) bg-(--surface) text-(--fg-subtle)",
                  ]}
                >
                  {e.badge}
                </span>
              </div>
            </div>
          ))
        }
      </div>
    </section>
    <section
      class="relative z-10 w-full border-t border-(--border-strong) bg-(--surface-subtle)/50 py-20"
    >
      <div class="mx-auto max-w-300 px-4 sm:px-6">
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-12">
          <div class="flex flex-col justify-center gap-4 lg:col-span-5">
            <p
              class="text-overline-12 tracking-widest text-(--fg-muted) uppercase"
            >
              Security
            </p>
            <h2 class="text-heading-40 text-(--fg-strong)">
              Privacy by<br />
              <span
                class="bg-linear-to-r from-(--fg-subtle) to-(--fg-strong) bg-clip-text text-transparent"
                >architecture.</span
              >
            </h2>
            <p class="text-body-16 max-w-[40ch] text-(--fg-muted)">
              Bukan sekadar janji privasi — ini adalah keputusan arsitektur.
              Server kami tidak bisa menyimpan data Anda karena kami tidak
              pernah menerimanya.
            </p>
          </div>
          <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:col-span-7">
            {
              [
                {
                  icon: "shield",
                  title: "Zero Server Storage",
                  desc: "Gambar dikonversi base64 di browser, dikirim langsung ke engine AI.",
                },
                {
                  icon: "lock",
                  title: "API Key di Browser",
                  desc: "Tersimpan di localStorage Anda — tidak pernah dikirim ke server kami.",
                },
                {
                  icon: "eyeClose",
                  title: "Tanpa Cookie Pelacakan",
                  desc: "Tidak ada analitik pihak ketiga, tidak ada pixel tracking.",
                },
                {
                  icon: "askAIAgent",
                  title: "Langsung ke AI Engine",
                  desc: "Data mengalir dari browser Anda langsung ke provider pilihan Anda.",
                },
              ].map((p) => (
                <div class="group flex items-start gap-4 rounded-2xl border border-(--border-strong) bg-(--surface) p-5 transition-colors duration-200 hover:border-(--brand-blue)">
                  <div class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-(--border-strong) bg-(--surface-elevated) text-(--fg-strong) shadow-sm transition-colors duration-200 group-hover:text-(--brand-blue)">
                    <Icon name={p.icon as any} className="w-4 h-4" />
                  </div>
                  <div>
                    <h3 class="text-heading-14 mb-1 text-(--fg-strong)">
                      {p.title}
                    </h3>
                    <p class="text-body-13 text-(--fg-muted)">{p.desc}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>
    <section
      class="relative z-10 w-full overflow-hidden border-t border-(--border-strong) bg-(--bg) py-32 sm:py-40"
    >
      <div
        class="absolute top-0 left-0 h-px w-full bg-linear-to-r from-transparent via-(--fg-subtle) to-transparent opacity-30"
      >
      </div>
      <div
