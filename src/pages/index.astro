---
// src/pages/index.astro
import {
  buildMeta,
  SITE,
  ROUTES,
  UI_TEXT,
  schemaSoftwareApplication,
} from "@/consts";

import Layout from "@/layouts/Layout.astro";
import Container from "@/components/ui/Container.astro";
import Icon from "@/components/ui/Icon.astro";
import Alert from "@/components/ui/Alert.astro";
import Card from "@/components/ui/Card.astro";
import Button from "@/components/ui/Button.astro";
import Section from "@/components/ui/Section.astro";
import heroImage from "@/assets/images/Adogen-hero.jpeg";
import { Image } from "astro:assets";

const meta = buildMeta({
  title: `${SITE.name} — Ship Metadata. Outpace the Algorithm.`,
  description: SITE.description,
  canonical: SITE.url,
  ogType: "website",
  keywords: [
    "Adobe Stock",
    "metadata generator",
    "image upscaler",
    "AI",
    "microstock",
    "automation",
  ],
});

const jsonLd = schemaSoftwareApplication({
  name: SITE.name,
  description: SITE.description,
  url: SITE.url,
  image: SITE.ogImage,
  applicationCategory: "MultimediaApplication",
  operatingSystem: "All",
  price: "0",
  priceCurrency: "USD",
});
---

<Layout {meta} isHome>
  <div class="relative flex w-full flex-1 flex-col items-center bg-(--bg)">
    <Alert
      title="ADOGEN ALERT"
      message="Image Upscale masih tahap uji coba."
      icon="askAIAgent"
      actionLabel="VIEW EVENTS"
    />
    <div class="pointer-events-none fixed inset-0 z-0 hidden justify-center">
      <div
        class="animate-grid-scroll absolute inset-0 bg-[radial-gradient(var(--border)_1px,transparent_1px)] mask-[linear-gradient(to_bottom,black_30%,transparent_100%)] bg-size-[32px_32px] opacity-40"
      >
      </div>
    </div>

    <Section size="md" class="w-full">
      <Container
        size="lg"
        class="relative z-10 mx-auto flex w-full flex-col items-center pt-[calc(var(--header-height)+1rem)] text-center"
      >
        <h1
          class="animate-in fade-in slide-in-from-bottom-6 fill-mode-both text-heading-40 md:text-display-64 balance text-wrap text-(--fg-strong) drop-shadow-sm delay-150 duration-1000 ease-out"
        >
          Generate. <span
            class="bg-linear-to-b from-(--fg-strong) to-(--fg-muted) bg-clip-text text-transparent"
            >Scale.</span
          >
          <br />
          Dominate Stock.
        </h1>

        <p
          class="animate-in fade-in slide-in-from-bottom-4 fill-mode-both text-body-16 sm:text-body-18 mt-8 max-w-2xl text-balance text-(--fg-muted) delay-300 duration-1000 ease-out"
        >
          Industrial-grade AI for microstock contributors. Extract metadata and
          upscale images locally. <strong class="text-(--fg-strong)"
            >Zero cost. Zero retention.</strong
          >
        </p>

        <div
          class="animate-in fade-in zoom-in-95 fill-mode-both group relative mt-12 w-full max-w-2xl cursor-text delay-500 duration-1000 ease-out"
          onclick="window.location.href='/metadata'"
        >
          <div
            class="absolute -inset-2 rounded-full bg-linear-to-r from-(--accent) to-(--success) opacity-0 blur-xl transition-opacity duration-700 group-hover:opacity-20 group-active:opacity-20"
          >
          </div>
          <div
            class="relative flex items-center justify-between rounded-full border border-(--border) bg-(--surface) p-2 pl-6 shadow-[0_20px_40px_-15px_rgba(0,0,0,0.1)] group-hover:border-(--accent) group-active:border-(--accent)"
          >
            <div class="flex w-full items-center gap-4 overflow-hidden">
              <Icon
                name="askAIAgent"
                className="h-5 w-5 shrink-0 text-(--fg-muted)"
              />
              <span
                class="text-body-14 md:text-body-16 animate-typing-infinite overflow-hidden border-r-2 border-(--accent) whitespace-nowrap text-(--fg-strong)"
              >
                Extract commercial metadata for DSC_0094.dng...
              </span>
            </div>
            <Button
              variant="icon-outline"
              size="md"
              class="ml-2 flex h-12 w-12 shrink-0 items-center justify-center shadow-md transition-transform hover:scale-95 hover:bg-(--accent) active:scale-95 active:bg-(--accent)"
            >
              <Icon name="arrow-right" className="h-5 w-5" />
            </Button>
          </div>
        </div>
      </Container>
    </Section>

    <Section size="md" class="w-full">
      <Container
        size="lg"
        class="animate-in fade-in slide-in-from-bottom-12 fill-mode-both relative z-10 w-full delay-700 duration-1000 ease-out"
      >
        <div
          class="flex h-auto w-full flex-col-reverse overflow-hidden rounded-lg border border-(--border) bg-(--surface-elevated)/90 shadow-[0_30px_60px_-15px_rgba(0,0,0,0.2)] backdrop-blur-2xl lg:h-150 lg:flex-row"
        >
          <div
            class="flex w-full flex-col border-b border-(--border) bg-(--surface-subtle) lg:w-72 lg:border-r lg:border-b-0"
          >
            <div
              class="flex items-center gap-2 border-b border-(--border) px-4 py-3"
            >
              <div class="mr-2 flex gap-1.5 sm:flex">
                <div
                  class="h-3 w-3 rounded-full bg-(--border-strong) hover:bg-[#ff5f56]"
                >
                </div>
                <div
                  class="h-3 w-3 rounded-full bg-(--border-strong) hover:bg-[#ffbd2e]"
                >
                </div>
                <div
                  class="h-3 w-3 rounded-full bg-(--border-strong) hover:bg-[#27c93f]"
                >
                </div>
              </div>
              <span
                class="text-mono-label-12 tracking-widest text-(--fg-muted) uppercase"
                >Queue (42)</span
              >
            </div>
            <div
              class="relative flex flex-1 flex-col gap-2 overflow-hidden p-3"
            >
              <div
                class="absolute right-0 bottom-0 left-0 z-10 h-24 bg-linear-to-t from-(--surface-subtle) to-transparent"
              >
              </div>
              <div
                class="relative flex items-center gap-3 overflow-hidden rounded-lg border border-(--accent)/30 bg-(--surface) p-2 shadow-sm"
              >
                <div
                  class="h-10 w-10 shrink-0 overflow-hidden rounded border border-(--border) bg-(--bg)"
                >
                  <Image
                    width={1200}
                    height={630}
                    loading="eager"
                    fetchpriority="low"
                    decoding="async"
                    src={heroImage}
                    alt="extraction"
                    class="h-full w-full object-cover"
                  />
                </div>
                <div class="flex min-w-0 flex-col">
                  <span class="text-label-12 mb-1 truncate text-(--fg-strong)"
                    >RAW_1042.dng</span
                  >
                  <span class="text-mono-label-12 animate-pulse text-(--accent)"
                    >Extracting...</span
                  >
                </div>
              </div>
              {
                [1043, 1044, 1045, 1046, 1047].map((num) => (
                  <div class="flex items-center gap-3 rounded-lg border border-transparent p-2 opacity-60 transition-colors hover:bg-(--surface)">
                    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded border border-(--border) bg-(--bg)">
                      <Icon
                        name="image"
                        className="w-4 h-4 text-(--fg-muted)"
                      />
                    </div>
                    <div class="flex min-w-0 flex-col">
                      <span class="text-label-12 truncate text-(--fg-strong)">
                        RAW_{num}.jpeg
                      </span>
                      <span class="text-caption-11 text-(--fg-muted)">
                        Queued
                      </span>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
          <div class="relative flex flex-1 flex-col bg-(--bg)">
            <div
              class="flex items-center justify-between border-b border-(--border) px-6 py-3"
            >
              <div class="flex flex-wrap items-center gap-3">
                <span class="text-label-13 text-(--fg-strong)">Workspace</span>
                <span
                  class="text-mono-label-12 rounded border border-(--border) bg-(--surface-subtle) px-2 py-0.5 text-(--fg-muted)"
                  >Mistral-8x7B</span
                >
              </div>
              <div class="flex gap-2">
                <div
                  class="text-label-12 flex h-7 items-center rounded-md border border-(--border) bg-(--surface-subtle) px-3 text-(--fg-strong)"
                >
                  Generate
                </div>
                <div
                  class="text-label-12 flex h-7 cursor-pointer items-center rounded-md px-3 text-(--fg-muted) hover:text-(--fg-strong)"
                >
                  Export
                </div>
              </div>
            </div>
            <div
              class="flex flex-1 flex-col gap-6 overflow-y-auto p-6 lg:flex-row"
            >
              <div class="flex w-full flex-col gap-4 lg:w-1/2">
                <div
                  class="group relative aspect-square w-full overflow-hidden rounded-xl border border-(--border) bg-(--surface-muted) sm:aspect-video lg:aspect-square"
                >
                  <Image
                    width={1200}
                    height={630}
                    loading="eager"
                    fetchpriority="high"
                    decoding="async"
                    src={heroImage}
                    alt="Processing"
                    class="h-full w-full object-cover opacity-90 transition-transform duration-700 group-hover:scale-105 group-active:scale-105"
                  />
                  <div
                    class="absolute inset-0 bg-linear-to-t from-(--bg)/80 to-transparent"
                  >
                  </div>
                  <div
                    class="animate-scan absolute top-0 left-0 z-20 h-0.5 w-full bg-(--accent) shadow-[0_0_20px_3px_var(--accent)]"
                  >
                  </div>
                  <div
                    class="absolute top-[20%] left-[20%] h-[60%] w-[60%] rounded-lg border border-(--accent)/50 bg-(--accent)/10 opacity-0 transition-opacity duration-500 group-hover:opacity-100 group-active:opacity-100"
                  >
                    <span
                      class="text-overline-10 absolute -top-3 left-2 rounded-sm bg-(--accent) px-1.5 py-0.5 text-white"
                      >Subject</span
                    >
                  </div>
                </div>

                <Card
                  variant="secondary"
                  padding="md"
                  radius="md"
                  class="text-code-12 relative h-32 overflow-hidden text-(--fg-muted)"
                >
                  <div
                    class="absolute inset-x-0 bottom-0 z-10 h-10 bg-linear-to-t from-(--surface-subtle) to-transparent"
                  >
                  </div>
                  <div
                    class="animate-log-scroll text-code-12 flex flex-col gap-1"
                  >
                    <div>
                      > Connecting to Groq API... <span class="text-(--success)"
                        >[OK]</span
                      >
                    </div>
                    <div>
                      > Analyzing tensor dimensions... <span
                        class="text-(--success)">[OK]</span
                      >
                    </div>
                    <div>
                      > Extracting dominant colors... <span
                        class="text-(--accent)">[PROCESSING]</span
                      >
                    </div>
                    <div>> Injecting LLM context...</div>
                    <div class="text-(--success)">
                      > Payload received (42ms)
                    </div>
                  </div>
                </Card>
              </div>
              <div class="flex w-full flex-col gap-6 lg:w-1/2">
                <div class="space-y-3">
                  <div class="flex items-center justify-between pb-2">
                    <span class="text-overline-12 font-mono text-(--fg-muted)"
                      >Optimized Title</span
                    >
                  </div>

                  <Card
                    variant="outline"
                    padding="md"
                    radius="md"
                    class="text-body-14 font-medium text-(--fg-strong) shadow-sm transition-colors hover:border-(--accent) active:border-(--accent)"
                  >
                    Abstract fluid <span
                      class="rounded bg-(--accent)/10 px-1 text-(--accent)"
                      >topographic landscape</span
                    > with glowing neon contours, 3d render.
                  </Card>
                </div>

                <div class="flex-1 space-y-3">
                  <div class="flex items-center justify-between pb-2">
                    <span class="text-overline-12 font-mono text-(--fg-muted)"
                      >Optimized Keywords</span
                    >
                    <span class="text-caption-12 text-(--accent)"
                      >100% Relevance</span
                    >
                  </div>

                  <Card variant="outline" padding="md" radius="md">
                    <div class="flex flex-wrap gap-2">
                      {
                        [
                          "abstract",
                          "topography",
                          "neon",
                          "fluid",
                          "3d",
                          "render",
                          "landscape",
                          "glow",
                          "futuristic",
                          "texture",
                          "cyberpunk",
                          "dark",
                          "light",
                          "design",
                          "art",
                        ].map((kw, i) => (
                          <span
                            class="animate-in fade-in zoom-in-50 fill-mode-both text-label-13 cursor-pointer rounded-md border border-(--border) bg-(--surface) px-2.5 py-1 text-(--fg-subtle) transition-colors duration-500 hover:border-(--accent) hover:bg-(--surface-subtle) hover:text-(--fg-strong) active:border-(--accent) active:bg-(--surface-subtle) active:text-(--fg-strong)"
                            style={`animation-delay: ${800 + i * 50}ms;`}
                          >
                            {kw}
                          </span>
                        ))
                      }
                      <span
                        class="text-mono-label-13 animate-pulse rounded-md border border-dashed border-(--border) px-2.5 py-1 text-(--fg-muted)"
                      >
                        ...
                      </span>
                    </div>
                  </Card>
                </div>
              </div>
            </div>
          </div>
        </div>
      </Container>
    </Section>

    <Section size="lg" class="w-full">
      <Container size="xl" class="relative z-10 w-full">
        <div
          class="mx-auto mb-16 flex max-w-3xl flex-col items-center text-center"
        >
          <h2 class="text-heading-32 sm:text-heading-48 text-(--fg-strong)">
            Unfair <span
              class="bg-linear-to-r from-(--fg-subtle) to-(--fg-strong) bg-clip-text text-transparent"
              >Advantage.</span
            >
          </h2>
          <p
            class="text-body-16 md:text-body-18 mt-4 text-pretty text-(--fg-muted)"
          >
            Engineered to automate your stock portfolio. High performance, zero
            bloat.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-6 sm:gap-8 lg:grid-cols-12">
          <div
            class="group relative flex flex-col justify-between overflow-hidden rounded-lg border border-(--border) bg-(--surface) p-8 transition-all duration-300 sm:p-10 lg:col-span-8"
          >
            <div
              class="pointer-events-none absolute right-0 bottom-0 h-2/3 w-2/3 translate-x-10 translate-y-10 opacity-20 transition-transform duration-700 group-hover:translate-x-5 group-active:translate-x-5"
            >
              <div
                class="flex h-full w-full flex-col divide-y divide-(--border-strong) rounded-tl-xl border border-(--border-strong) bg-(--surface-elevated)"
              >
                <div class="flex h-8 items-center gap-4 px-4">
                  <div class="h-2 w-20 rounded bg-(--border-strong)"></div><div
                    class="h-2 w-32 rounded bg-(--border-strong)"
                  >
                  </div>
                </div>
                <div class="flex h-8 items-center gap-4 px-4">
                  <div class="h-2 w-20 rounded bg-(--accent)"></div><div
                    class="h-2 w-40 rounded bg-(--border-strong)"
                  >
                  </div>
                </div>
                <div class="flex h-8 items-center gap-4 px-4">
                  <div class="h-2 w-20 rounded bg-(--border-strong)"></div><div
                    class="h-2 w-24 rounded bg-(--border-strong)"
                  >
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div
            class="group relative flex flex-col justify-between overflow-hidden rounded-lg border border-(--border) bg-(--surface) p-8 transition-all duration-300 sm:p-10 lg:col-span-4"
          >
            <div
              class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI0IiBoZWlnaHQ9IjQiPgo8cmVjdCB3aWR0aD0iNCIgaGVpZ2h0PSI0IiBmaWxsPSIjMDAwIiBmaWxsLW9wYWNpdHk9IjEiLz4KPC9zdmc+')] opacity-[0.03] mix-blend-overlay"
            >
            </div>
          </div>
        </div>
      </Container>
    </Section>

    <Section
      size="md"
      class="w-full border-t border-dashed border-(--border-subtle)"
    >
      <Container size="lg" class="relativez-10">
        <Section size="lg">
          <div
            class="relative mx-auto flex flex-col items-center px-6 text-center"
          >
            <h2
              class="text-heading-32 sm:text-heading-48 relative z-10 mb-6 font-black tracking-tighter text-balance text-(--fg-strong) drop-shadow-sm"
            >
              Ready to <b class="text-(--accent)">automate</b> your <b
                class="text-chart-5">portfolio?</b
              >
            </h2>

            <p
              class="text-body-16 md:text-body-18 relative z-10 mb-12 max-w-lg tracking-tight text-pretty text-(--fg-muted)"
            >
              Stop wasting time on manual keywording. Adogen provides the unfair
              advantage your portfolio needs. <b>No sign-ups</b>, just raw
              power.
            </p>

            <div class="relative z-10 flex items-center gap-4">
              <Button
                variant="primary"
                size="md"
                class="text-button-14"
              >
                Launch Tools
              </Button>
              <Button
                href={ROUTES.docs}
                variant="secondary"
                size="md"
                class="text-button-14"
              >
                Read Docs
              </Button>
            </div>
          </div>
        </Section>
      </Container>
    </Section>
  </div>
</Layout>

<style is:global>
  @keyframes text-shimmer {
    0% {
      background-position: 100% 50%;
    }
    100% {
      background-position: -100% 50%;
    }
  }
  .animate-text-shimmer {
    animation: text-shimmer 6s ease-in-out infinite alternate;
  }

  @keyframes grid-scroll {
    0% {
      transform: translateY(0);
    }
    100% {
      transform: translateY(32px);
    }
  }
  .animate-grid-scroll {
    animation: grid-scroll 10s linear infinite;
  }

  @keyframes pulse-slow {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.04;
    }
    50% {
      transform: scale(1.05);
      opacity: 0.08;
    }
  }
  .animate-pulse-slow {
    animation: pulse-slow 8s ease-in-out infinite;
  }

  @keyframes typing-infinite {
    0%,
    10% {
      width: 0;
    }
    40%,
    60% {
      width: 100%;
    }
    90%,
    100% {
      width: 0;
    }
  }
  .animate-typing-infinite {
    display: inline-block;
    animation: typing-infinite 8s steps(40, end) infinite;
  }

  @keyframes border-spin-fast {
    100% {
      transform: rotate(360deg);
    }
  }
  .animate-border-spin-fast {
    animation: border-spin-fast 3s linear infinite;
  }

  @keyframes scan {
    0% {
      top: -10%;
      opacity: 0;
    }
    15% {
      opacity: 1;
    }
    85% {
      opacity: 1;
    }
    100% {
      top: 110%;
      opacity: 0;
    }
  }
  .animate-scan {
    animation: scan 2.5s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  @keyframes log-scroll {
    0% {
      transform: translateY(10px);
      opacity: 0;
    }
    5% {
      transform: translateY(0);
      opacity: 1;
    }
    100% {
      transform: translateY(-30%);
      opacity: 1;
    }
  }
  .animate-log-scroll {
    animation: log-scroll 6s linear infinite;
  }
</style>
