---
// src/pages/novel/[slug].astro
import { getCollection } from "astro:content";

import Layout from "@/layouts/Layout.astro";

import Container from "@ui/Container.astro";
import Section from "@ui/Section.astro";

import NovelHero from "@/components/novels/NovelHero.astro";
import NovelSynopsis from "@/components/novels/NovelSynopsis.astro";
import NovelChapterList from "@/components/novels/NovelChapterList.astro";

export async function getStaticPaths() {
  const novels = await getCollection("novels");

  return novels.map((novel) => {
    const slug = novel.id.split("/")[0];
    
    return {
      params: { slug },
      // Kirim slug juga sebagai props agar bisa digunakan untuk pencocokan
      props: { novel, slug }, 
    };
  });
}

const { novel, slug } = Astro.props;
const allChapters = await getCollection("chapters");

// ==========================================
// FIX: Pencocokan ID yang dioptimalkan
// ==========================================
const chapters = allChapters
  .filter((chapter) => {
    // Menghapus akhiran /_meta (jika ada) dari target referensi
    const targetId = chapter.data.novel.id.replace("/_meta", "");
    const novelBaseId = novel.id.replace("/_meta", "");
    
    // Cocokkan dengan slug folder atau ID novel aslinya
    return targetId === slug || targetId === novelBaseId;
  })
  .sort((a, b) => a.data.chapterNumber - b.data.chapterNumber);

const uniqueVolumes = new Set(
  chapters.map((chapter) => chapter.data.volume?.id || "unassigned")
);
const totalVolumes = uniqueVolumes.size;

const meta = {
  title: `${novel.data.title}`,
  description: novel.data.synopsis,
};
---

<Layout meta={meta}>
  <main id="main-content" class="w-full min-w-0 flex-1">
    <Section size="md">
      <Container size="lg">
        <div class="space-y-10">
          
          <NovelHero
            novel={novel}
            totalChapters={chapters.length}
            totalVolumes={totalVolumes}
            firstChapterUrl={chapters.length > 0 ? `/novel/${chapters[0].id}` : "#chapters"}
          />
          
          <NovelSynopsis
            synopsis={novel.data.synopsis}
          />
          
          <NovelChapterList
            chapters={chapters}
            currentPath={Astro.url.pathname} 
          />
          
        </div>
      </Container>
    </Section>
  </main>
</Layout>