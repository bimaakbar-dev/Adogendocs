---
import { getCollection } from "astro:content";

import Layout from "@/layouts/Layout.astro";

import Container from "@ui/Container.astro";
import Section from "@ui/Section.astro";

import NovelHero from "@/components/novels/NovelHero.astro";
import NovelSynopsis from "@/components/novels/NovelSynopsis.astro";
import NovelChapterList from "@/components/novels/NovelChapterList.astro";

export async function getStaticPaths() {
  const novels = await getCollection("novels");

  return novels.map((novel) => ({
    params: {
      slug: novel.id.split("/")[0],
    },
    props: {
      slug: novel.id.split("/")[0],
    },
  }));
}

interface Props {
  slug: string;
}

const { slug } = Astro.props;

const novels = await getCollection("novels");

const novel = novels.find(
  (item) => item.id.split("/")[0] === slug,
);

if (!novel) {
  return new Response(null, {
    status: 404,
    statusText: "Not Found",
  });
}

const chapters = (await getCollection("chapters"))
  .filter((chapter) => {
    const chapterSlug = chapter.id.split("/")[0];

    return (
      chapterSlug === slug &&
      !chapter.id.includes("_meta")
    );
  })
  .sort(
    (a, b) =>
      a.data.chapterNumber - b.data.chapterNumber,
  );

const groupedVolumes = chapters.reduce(
  (acc, chapter) => {
    const volume = chapter.data.volume ?? 1;

    if (!acc[volume]) {
      acc[volume] = [];
    }

    acc[volume].push(chapter);

    return acc;
  },
  {} as Record<number, typeof chapters>,
);

const totalVolumes =
  Object.keys(groupedVolumes).length;

const firstChapter = chapters[0];

const meta = {
  title: `${novel.data.title}`,
  description: novel.data.synopsis,
};
---

<Layout meta={meta}>
  <Section size="lg">
    <Container size="lg">
      <div class="space-y-10">

        <NovelHero
          novel={novel}
          totalChapters={chapters.length}
          totalVolumes={totalVolumes}
          firstChapterHref={
            firstChapter
              ? `/novel/${firstChapter.id}`
              : undefined
          }
        />

        <NovelSynopsis
          synopsis={novel.data.synopsis}
        />

        <NovelChapterList
          chapters={chapters}
        />

      </div>
    </Container>
  </Section>
</Layout>