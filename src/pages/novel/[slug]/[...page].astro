---
// src/pages/novel/[slug]/[...page].astro

import { getCollection, render } from "astro:content";

import NovelLayout from "@/layouts/NovelLayout.astro";

import { components } from "@/components/mdx/MDXComponents";

import MobileToc from "@/components/MobileToc.astro";
import Toc from "@/components/Toc.astro";

import ScrollToTop from "@/components/docs/ScrollToTop.astro";

import NovelFooter from "@/components/novel/NovelFooter.astro";

import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";

export async function getStaticPaths() {
  const chapters = await getCollection("chapters");

  return chapters
    .filter((chapter) => !chapter.id.includes("_meta"))
    .map((chapter) => {
      const segments = chapter.id.split("/");

      return {
        params: {
          slug: segments[0],
          page: segments.slice(1).join("/"),
        },
        props: {
          chapterId: chapter.id,
        },
      };
    });
}

interface Props {
  chapterId: string;
}

const { chapterId } = Astro.props;

const chapters = await getCollection("chapters");

const currentChapter = chapters.find(
  (chapter) => chapter.id === chapterId,
);

if (!currentChapter) {
  return new Response(null, {
    status: 404,
    statusText: "Not Found",
  });
}

const { Content, headings } = await render(currentChapter);

const slug = currentChapter.id.split("/")[0];

const novels = await getCollection("novels");

const novel = novels.find(
  (item) => item.id.split("/")[0] === slug,
);

if (!novel) {
  return new Response(null, {
    status: 404,
    statusText: "Not Found",
  });
}

const novelChapters = chapters
  .filter((chapter) => {
    return (
      chapter.id.split("/")[0] === slug &&
      !chapter.id.includes("_meta")
    );
  })
  .sort(
    (a, b) =>
      a.data.chapterNumber -
      b.data.chapterNumber,
  );

const currentIndex = novelChapters.findIndex(
  (chapter) => chapter.id === currentChapter.id,
);

const prevChapter =
  currentIndex > 0
    ? novelChapters[currentIndex - 1]
    : null;

const nextChapter =
  currentIndex < novelChapters.length - 1
    ? novelChapters[currentIndex + 1]
    : null;

const meta = {
  title: `${currentChapter.data.title} - ${novel.data.title}`,
  description: `Baca ${currentChapter.data.title} dari novel ${novel.data.title}`,
};
---

<NovelLayout
  novel={novel}
  chapters={novelChapters}
  currentPath={currentChapter.id}
  slug={slug}
  meta={meta}
>
  <MobileToc
    title={currentChapter.data.title}
    headings={headings}
  />

  <Fragment>
    <div class="mx-auto w-full min-w-0 px-0 lg:px-4 pb-(--safe-bottom)">
      <Section size="md">
        <Container size="full">
          <article class="prose">
            <Content components={components} />
          </article>

          <NovelFooter
            prev={prevChapter}
            next={nextChapter}
            current={currentChapter.data.chapterNumber}
            total={novelChapters.length}
            lastUpdated={currentChapter.data.publishedDate}
          />
        </Container>
      </Section>
    </div>
  </Fragment>

  <Fragment slot="right" class="flex items-center gap-4">
    <div class="sticky top-0 right-0 space-y-2">
      <ScrollToTop label="Scroll to top" />
    </div>

    <div class="fixed top-1/2 right-2 z-40 lg:block -translate-y-1/2">
      <Toc headings={headings} />
    </div>
  </Fragment>
</NovelLayout>