---
// src/pages/novel/genre/index.astro
import { getCollection } from "astro:content";

import Layout from "@/layouts/Layout.astro";
import Container from "@ui/Container.astro";
import Section from "@ui/Section.astro";
import Icon from "@ui/Icons.astro";

const allNovels = await getCollection("novels");

const genreCounts = allNovels.reduce((acc, novel) => {
  if (novel.data.genre) {
    novel.data.genre.forEach((g) => {
      acc[g] = (acc[g] || 0) + 1;
    });
  }
  return acc;
}, {} as Record<string, number>);

const sortedGenres = Object.keys(genreCounts).sort();

const slugify = (text: string) => text.toLowerCase().replace(/\s+/g, '-');

const meta = {
  title: "Genres | Library Directory",
  description: "Browse all available novel categories and genres.",
};

const $ = {
  header: "mb-10 flex flex-col items-start gap-4 border-b border-(--border-subtle) pb-8",
  backLink: "inline-flex items-center gap-1.5 text-label-13 text-(--fg-muted) transition-colors hover:text-(--fg-strong)",
  title: "text-heading-32 font-semibold tracking-tight text-(--fg-strong)",
  subtitle: "text-body-16 text-(--fg-muted)",
  
  grid: "grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4",
  
  card: "group flex items-center justify-between rounded-lg border border-(--border-subtle) bg-(--bg-subtle) p-4 transition-colors hover:border-(--fg-muted)",
  genreName: "text-body-15 font-medium text-(--fg-strong) transition-colors group-hover:text-(--accent)",
  countBadge: "rounded-md border border-(--border-subtle) bg-(--bg) px-2 py-0.5 text-label-12 text-(--fg-muted)",
};
---

<Layout meta={meta}>
  <main id="main-content" class="w-full min-w-0 flex-1">
    <Section size="md">
      <Container size="lg">
        
        <header class={$.header}>
          <a href="/novel" class={$.backLink}>
            <Icon name="arrow-left" class="size-4" /> 
            Back to Library
          </a>
          <div class="mt-2">
            <h1 class={$.title}>Genres</h1>
            <p class={$.subtitle}>Filter and discover series across {sortedGenres.length} categories.</p>
          </div>
        </header>

        <div class={$.grid}>
          {sortedGenres.map((genre) => {
            const count = genreCounts[genre];
            const genreUrl = `/novel/genre/${slugify(genre)}`;
            
            return (
              <a href={genreUrl} class={$.card}>
                <span class={$.genreName}>
                  {genre}
                </span>
                <span class={$.countBadge}>
                  {count} {count > 1 ? 'Items' : 'Item'}
                </span>
              </a>
            );
          })}
        </div>

      </Container>
    </Section>
  </main>
</Layout>