---
// src/pages/[slug].astro
import { 
  getCollection, 
  render 
} from "astro:content";

import { 
  buildMeta, 
  schemaWebPage, 
  SITE 
} from "../consts";

import { formatDate } from '@lib/utils';
import { components } from "@/components/mdx/MDXComponents";

import Layout from "@/layouts/Layout.astro";
import Section from "@ui/Section.astro";
import Container from "@ui/Container.astro";

export async function getStaticPaths() {
  const legalEntries = await getCollection("legal");
  return legalEntries.map((entry) => ({
    params: { slug: entry.data.slug || entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;

if (!entry) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

const { Content } = await render(entry);

const currentSlug = Astro.params.slug;
const currentUrl = `${SITE.url}/${currentSlug}`;

const metaProps = buildMeta({
  title: entry.data.title,
  description: entry.data.description || SITE.description,
  canonical: currentUrl,
});

const pageSchema = schemaWebPage({
  title: entry.data.title,
  description: entry.data.description || SITE.description,
  url: currentUrl,
});

const $ = {
  main: "flex flex-col min-h-[calc(100vh-var(--header-height))] flex-1 mx-auto pb-(--safe-bottom)",
  divider: "bg-none border-t border-dashed border-(--border-subtle)/80 my-6 md:my-8",
  header: "mb-6 md:mb-8",
  title: "mb-4 text-heading-32 md:text-heading-40 lg:text-heading-48 font-semibold text-(--fg-strong)",
  meta: "justify-center items-center gap-4 space-y-2 text-sm text-(--fg-muted)",
  description: "text-sm text-(--fg-muted)"
}
---

<Layout meta={metaProps} schema={pageSchema}>
  <div data-pagefind-weight="1" class="hidden" />
  <main id="main-content" class={$.main}>
    <article data-pagefind-body data-pagefind-filter="type:legal">
      <Section size="lg">
        <Container size="md">
          <header data-pagefind-ignore class={$.header}>
            <h1 data-pagefind-meta="title" class={$.title}>
              {entry.data.title}
            </h1>
            <div class={$.meta}>
              {entry.data.lastUpdated && (
                <p>
                  <time data-pagfind-meta="date" data-pagefind-sort="date" datetime={entry.data.lastUpdated.toISOString()}>
                    Last updated: {formatDate(entry.data.lastUpdated)}
                  </time>
                </p>
              )}
              <p data-pagefind-meta="description" class={$.description}>
                {entry.data.description}
              </p>
            </div>
          </header>
        </Container>
        <div class={$.divider} />
        <Container size="md">
          <div class="prose">
            <Content components={components} />
          </div>
        </Container>
      </Section>
    </article>
  </main>
</Layout>
