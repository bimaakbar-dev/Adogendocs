---
// src/pages/[slug].astro
import { 
  getCollection, 
  render 
} from "astro:content";

import { 
  buildMeta, 
  schemaWebPage, 
  SITE 
} from "../consts";

import { formatDate } from '@lib/utils';
import { components } from "@/components/mdx/MDXComponents";

import Layout from "@/layouts/Layout.astro";
import Container from "@/components/ui/Container.astro";

export async function getStaticPaths() {
  const legalEntries = await getCollection("legal");
  return legalEntries.map((entry) => ({
    params: { slug: entry.data.slug || entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;

if (!entry) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

const { Content } = await render(entry);

const currentSlug = Astro.params.slug;
const currentUrl = `${SITE.url}/${currentSlug}`;

const metaProps = buildMeta({
  title: entry.data.title,
  description: entry.data.description || SITE.description,
  canonical: currentUrl,
});

const pageSchema = schemaWebPage({
  title: entry.data.title,
  description: entry.data.description || SITE.description,
  url: currentUrl,
});
---

<Layout meta={metaProps} schema={pageSchema}>
  <main>
    <article data-pagefind-body data-pagefind-filter="type:legal">
      <Container size="md">
        <div class="py-12 md:py-16">
          <header class="mb-8">
            <h1 data-pagefind-meta="title" class="mb-3 text-3xl font-bold tracking-tight text-(--fg-strong) sm:text-4xl">
              {entry.data.title}
            </h1>
            <div class="mt-2 flex flex-wrap items-center gap-4 text-xs text-(--fg-muted)">
              <p data-pagefind-meta="description" class="mb-0 border-b border-none pb-0 text-sm text-(--fg-muted)">
                {entry.data.description}
              </p>
              <div class="flex items-center gap-1.5 rounded-md border border-(--border)/60 bg-(--bg-subtle) px-2.5 py-1 font-medium">
                {entry.data.lastUpdated && (
                  <span>Last updated:</span>
                  <time data-pagefind-sort="date" datetime={entry.data.lastUpdated.toISOString()}>
                    {formatDate(entry.data.lastUpdated)}
                  </time>
                )}
              </div>
            </div>
          </header>
          <div class="my-6 h-px bg-(--border)/60"></div>
          <div class="prose">
            <Content components={components} />
          </div>
        </div>
      </Container>
    </article>
  </main>
</Layout>
