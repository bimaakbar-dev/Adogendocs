---
// src/pages/docs/[...slug].astro
import { 
  getCollection, 
  render 
} from "astro:content";

import { 
  buildMeta, 
  schemaWebPage, 
  SITE 
} from "@/consts";

import { components } from "@components/mdx/MDXComponents";

import DocsLayout from "@/layouts/DocsLayout.astro";
import Container from "@ui/Container.astro";
import Section from "@ui/Section.astro";
import Toc from "@components/Toc.astro";
import MobileToc from "@components/MobileToc.astro";
import DocsHeader from "@docs/DocsHeader.astro";
import ScrollToTop from "@docs/ScrollToTop.astro";
import DocsFooter from "@docs/DocsFooter.astro";
import CopyCode from "@/components/CopyCode.astro";

export async function getStaticPaths() {
  const docsEntries = await getCollection("docs");

  const sorted = [...docsEntries].sort(
    (a, b) => (a.data.order ?? 999) - (b.data.order ?? 999),
  );
  const primaryRootId = sorted[0]?.id;

  return docsEntries.map((entry) => {
    const currentSlug = entry.data.slug || entry.id;
    const isRoot = entry.id === primaryRootId;

    return {
      params: { slug: isRoot ? undefined : currentSlug },
      props: { entry, primaryRootId },
    };
  });
}

const { entry, primaryRootId } = Astro.props;

if (!entry) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

const { Content, headings } = await render(entry);

const allDocs = await getCollection("docs");
const sidebarItems = allDocs.sort(
  (a, b) => (a.data.order ?? 999) - (b.data.order ?? 999),
);

const currentPath = Astro.url.pathname;

const mappedSidebarItems = sidebarItems.map((item) => {
  const slugParts = (item.data.slug || item.id).split("/");
  const folderName = slugParts.length > 1 ? slugParts[0] : null;
  const category = item.data.category || folderName || "General";

  const isRoot = item.id === primaryRootId;
  
  return {
    id: item.id,
    title: item.data.title,
    href: isRoot ? "/docs" : `/docs/${item.data.slug || item.id}`,
    category: category,
    order: item.data.order ?? 999,
  };
});

const sidebarProps = {
  items: mappedSidebarItems,
  currentPath: currentPath,
  storagePrefix: "docs",
};

const breadcrumbItems = [
  { label: "Docs", href: "/docs" }
];

if (entry.data.category) {
  breadcrumbItems.push({
    label: entry.data.category,
    href: `/docs?category=${encodeURIComponent(entry.data.category)}`,
  });
}

const cleanSlug = Astro.params.slug;
const currentUrl = `${SITE.url}/docs${cleanSlug ? `/${cleanSlug}` : ""}`;

const currentIndex = sidebarItems.findIndex((item) => item.id === entry.id);
const prevEntry = currentIndex > 0 ? sidebarItems[currentIndex - 1] : null;
const nextEntry =
  currentIndex < sidebarItems.length - 1
    ? sidebarItems[currentIndex + 1]
    : null;

const metaProps = buildMeta({
  title: entry.data.seo.title,
  description: entry.data.seo.description ?? entry.data.description,
  canonical: currentPath,
  ogImage: entry.data.seo.ogImage,
  ogType: "article",
  datePublished: entry.data.pubDate?.toISOString(),
  dateModified: entry.data.lastUpdated?.toISOString(),
  authorName: "Bima Akbar",
});

const pageSchema = schemaWebPage({
  title: entry.data.title,
  description: entry.data.description || SITE.description,
  url: currentUrl,
});

const markdown = `---
title: "${entry.data.title}"
description: "${entry.data.description || ""}"
category: "${entry.data.category}"
lastUpdated: "${entry.data.lastUpdated}"
---

${entry.body}`;

const fullMarkdownContent = markdown;
---

<DocsLayout meta={metaProps} schema={pageSchema}>
  <MobileToc title={entry.data.title} headings={headings} />
  <Fragment>
    <div class="mx-auto w-full min-w-0 p-0 lg:p-4 m-2 pb-(--safe-bottom) rounded-xl">
      <Section size="md">
        <article>
          <Container size="full">
            <DocsHeader
              title={entry.data.title}
              description={entry.data.description}
              breadcrumb={breadcrumbItems}
              content={fullMarkdownContent}
            />
          </Container>
          <div class="bg-none border-t border-dashed border-(--border-subtle)/80 my-6 md:my-8" />
          <Container size="full">
            <div data-pagefind-body class="prose">
              <Content components={components} />
            </div>
          </Container>
          <div class="bg-none border-t border-dashed border-(--border-subtle)/80 mt-6 md:mt-8" />
          <Container size="full">
            <DocsFooter 
              lastUpdated={entry.data.lastUpdated}
              prev={prevEntry}
              next={nextEntry}
              primaryRootId={primaryRootId} />
          </Container>
        </article>
      </Section>
    </div>
  </Fragment>
  <Fragment slot="right" class="flex items-center gap-4">
    <div class="sticky top-0 right-0 space-y-2">
      <ScrollToTop label="Scroll to top" />
    </div>
    <div class="fixed top-1/2 right-2 z-40 hidden -translate-y-1/2 lg:block">
      <Toc headings={headings} />
    </div>
  </Fragment>
</DocsLayout>
