---
// src/pages/docs/[...slug].astro
import { 
  getCollection, 
  render 
} from "astro:content";

import { 
  buildMeta, 
  schemaWebPage, 
  SITE 
} from "@/consts";

import { components } from "@components/mdx/MDXComponents";

import DocsLayout from "@/layouts/DocsLayout.astro";
import Container from "@ui/Container.astro";
import Section from "@ui/Section.astro";
import Toc from "@components/Toc.astro";
import MobileToc from "@components/MobileToc.astro";
import DocsHeader from "@docs/DocsHeader.astro";
import ScrollToTop from "@docs/ScrollToTop.astro";
import DocsFooter from "@docs/DocsFooter.astro";
import Select from "@/components/ui/Select.astro";

export async function getStaticPaths() {
  const docsEntries = await getCollection("docs");

  const sorted = [...docsEntries].sort(
    (a, b) => (a.data.order ?? 999) - (b.data.order ?? 999),
  );
  const primaryRootId = sorted[0]?.id;

  return docsEntries.map((entry) => {
    const currentSlug = entry.data.slug || entry.id;
    const isRoot = entry.id === primaryRootId;

    return {
      params: { slug: isRoot ? undefined : currentSlug },
      props: { entry, primaryRootId },
    };
  });
}

const { entry, primaryRootId } = Astro.props;

if (!entry) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

const { Content, headings } = await render(entry);

const allDocs = await getCollection("docs");
const sidebarItems = allDocs.sort(
  (a, b) => (a.data.order ?? 999) - (b.data.order ?? 999),
);

const currentPath = Astro.url.pathname;

const mappedSidebarItems = sidebarItems.map((item) => {
  const slugParts = (item.data.slug || item.id).split("/");
  const category = slugParts.length > 1 ? slugParts[0] : "General";
  const isRoot = item.id === primaryRootId;
  
  return {
    id: item.id,
    title: item.data.title,
    href: isRoot ? "/docs" : `/docs/${item.data.slug || item.id}`,
    category: category,
    order: item.data.order ?? 999,
  };
});

const sidebarProps = {
  items: mappedSidebarItems,
  currentPath: currentPath,
  storagePrefix: "docs",
};

const cleanSlug = Astro.params.slug;
const currentUrl = `${SITE.url}/docs${cleanSlug ? `/${cleanSlug}` : ""}`;

const currentIndex = sidebarItems.findIndex((item) => item.id === entry.id);
const prevEntry = currentIndex > 0 ? sidebarItems[currentIndex - 1] : null;
const nextEntry =
  currentIndex < sidebarItems.length - 1
    ? sidebarItems[currentIndex + 1]
    : null;

const copyItems = [
  { label: "Copy as Markdown", value: "md", icon: "file" },
  { label: "Copy Page URL", value: "url", icon: "link" },
  { label: "Open in AI Agent", value: "ai", icon: "sparkles" },
];

const metaProps = buildMeta({
  title: entry.data.title,
  description: entry.data.description || SITE.description,
  canonical: currentUrl,
});

const pageSchema = schemaWebPage({
  title: entry.data.title,
  description: entry.data.description || SITE.description,
  url: currentUrl,
});
---

<DocsLayout meta={metaProps} schema={pageSchema} sidebarProps={sidebarProps}>
  <MobileToc title={entry.data.title} headings={headings} />
  <Fragment>
    <div class="mx-auto w-full min-w-0 px-0 lg:px-4 pb-(--pb-safe-bottom)">
      <Section size="md">
        <Container size="full">
          <DocsHeader
            title={entry.data.title}
            description={entry.data.description}
            pubDate={entry.data.pubDate}
            content={entry.body}
          />
          <article class="prose">
            <Content components={components} />
          </article>
          <DocsFooter 
            lastUpdated={entry.data.lastUpdated}
            prev={prevEntry}
            next={nextEntry}
            primaryRootId={primaryRootId} />
        </Container>
      </Section>
    </div>
  </Fragment>
  <Fragment slot="right" class="flex items-center gap-4">
    <div class="sticky top-0 right-0 space-y-2">
      <Select 
        size="md"
        options={copyItems}
        placeholder="Copy page"
        prefix="copy"
        suffix="chevron-down"
      />
      <ScrollToTop label="Scroll to top" />
    </div>
    <div class="fixed top-1/2 right-2 z-40 hidden -translate-y-1/2 lg:block">
      <Toc headings={headings} />
    </div>
  </Fragment>
</DocsLayout>
