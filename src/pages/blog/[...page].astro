---
import { getCollection } from "astro:content";

import {
  buildMeta,
  ROUTES,
  schemaWebPage,
  SITE,
} from "@/consts";

import Layout from "@/layouts/Layout.astro";
import Container from "@ui/Container.astro";
import Section from "@ui/Section.astro";
import BlogCard from "@/components/blog/BlogCard.astro";
import Pagination from "@/components/blog/BlogPagination---
// src/pages/blog/[...page].astro

import { getCollection } from "astro:content";
import {
  buildMeta,
  ROUTES,
  schemaWebPage,
  SITE,
  PAGINATION,
} from "@/consts";
import Layout from "@/layouts/Layout.astro";
import Container from "@ui/Container.astro";
import Section from "@ui/Section.astro";
import BlogCard from "@/components/blog/BlogCard.astro";
import Pagination from "@/components/blog/BlogPagination.astro";
import Icon from "@/components/ui/Icons.astro";
import Button from "@/components/ui/Button.astro";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");

  const publishedPosts = allPosts
    .filter((post) => !post.data.draft)
    .sort(
      (a, b) =>
        (b.data.pubDate?.getTime() ?? 0) -
        (a.data.pubDate?.getTime() ?? 0)
    );

  const totalPosts = publishedPosts.length;
  const totalPages = Math.ceil(totalPosts / PAGINATION.postsPerPage);

  const paths = [];

  for (let page = 1; page <= totalPages; page++) {
    const start = (page - 1) * PAGINATION.postsPerPage;
    const end = start + PAGINATION.postsPerPage;
    const postsForThisPage = publishedPosts.slice(start, end);
    const params = { page: page === 1 ? undefined : String(page) };

    paths.push({
      params,
      props: {
        posts: postsForThisPage,
        currentPage: page,
        totalPages,
      },
    });
  }

  return paths;
}

const { posts: pagePosts, currentPage, totalPages } = Astro.props;

const meta = buildMeta({
  title: "Blog",
  description: "Latest articles, tutorials and updates.",
  canonical: "/blog",
});

const schema = schemaWebPage({
  title: "Blog",
  description: "Latest articles, tutorials and updates.",
  url: `${SITE.url}/blog`,
});
---

<Layout meta={meta} schema={schema}>
  <Section size="md">
    <Container size="lg">
      <header class="flex items-center mb-8 space-y-3 w-full justify-between">
        <h1 class="text-heading-40 font-semibold text-(--fg-strong)">
          Blog
        </h1>
        <Button
          aria-label="RSS Feed"
          variant="icon"
          size="md"
          href={ROUTES.rss}
          thisIcon
          class="rounded-full!"
        >
          <Icon name="rss" class="size-5" />
        </Button>
      </header>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {pagePosts.map((post, index) => (
          <BlogCard entry={post} index={index} />
        ))}
      </div>
      {totalPages > 1 && (
        <div class="mt-10">
          <Pagination
            currentPage={currentPage}
            totalPages={totalPages}
            href={(page) =>
              page === 1
                ? "/blog"
                : `/blog/${page}`
            }
          />
        </div>
      )}
    </Container>
  </Section>
</Layout>.astro";
import Icon from "@/components/ui/Icons.astro";
import Button from "@/components/ui/Button.astro";

const POSTS_PER_PAGE = 9;

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort(
    (a, b) =>
      (b.data.pubDate?.getTime() ?? 0) -
      (a.data.pubDate?.getTime() ?? 0),
  );

const totalPosts = posts.length;
const totalPages = Math.ceil(totalPosts / POSTS_PER_PAGE);

const currentPage = 1;

const pagePosts = posts.slice(0, POSTS_PER_PAGE);

const meta = buildMeta({
  title: "Blog",
  description: "Latest articles, tutorials and updates.",
  canonical: "/blog",
});

const schema = schemaWebPage({
  title: "Blog",
  description: "Latest articles, tutorials and updates.",
  url: `${SITE.url}/blog`,
});
---

<Layout meta={meta} schema={schema}>
  <Section size="md">
    <Container size="full">
      <header class="flex items-center mb-8 space-y-3 w-full justify-between">
        <h1 class="text-heading-40 font-semibold text-(--fg-strong)">
          Blog
        </h1>
        <Button 
          variant="icon" 
          size="md" 
          href={ROUTES.rss} 
          thisIcon 
          class="rounded-full!"
        >
          <Icon name="rss" class="size-5" />
        </Button>
      </header>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {pagePosts.map((post, index) => (
          <BlogCard entry={post} index={index} />
        ))}
      </div>
      {totalPages > 1 && (
        <div class="mt-10">
            <Pagination
                currentPage={currentPage}
                totalPages={totalPages}
                href={(page) =>
                page === 1
                    ? "/blog"
                    : `/blog/page/${page}`
                }
            />
        </div>
      )}
    </Container>
  </Section>
</Layout>
