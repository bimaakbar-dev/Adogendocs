---
// src/pages/docs/[...slug].astro
import { 
  getCollection, 
  render 
} from "astro:content";

import { 
  buildMeta, 
  schemaWebPage, 
  SITE 
} from "@/consts";

import { components } from "@components/mdx/MDXComponents";

import BlogLayout from "@/layouts/BlogLayout.astro";
import Container from "@ui/Container.astro";
import Section from "@ui/Section.astro";
import Toc from "@components/Toc.astro";
import MobileToc from "@components/MobileToc.astro";
import ScrollToTop from "@docs/ScrollToTop.astro";
import BlogFooter from "@/components/blog/BlogFooter.astro";
import BlogHeader from "@/components/blog/BlogHeader.astro";
import CopyCode from "@/components/CopyCode.astro";

export async function getStaticPaths() {
  const entries = await getCollection("blog");

  return entries.map((entry) => ({
    params: {
      slug: entry.data.slug || entry.id,
    },
    props: { entry },
  }));
}

const { entry } = Astro.props;

if (!entry) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

const { Content, headings } = await render(entry);

const allPosts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort(
    (a, b) =>
      (b.data.pubDate?.getTime() ?? 0) -
      (a.data.pubDate?.getTime() ?? 0),
  );

const currentIndex = allPosts.findIndex((item) => item.id === entry.id);

const prevEntry =
  currentIndex < allPosts.length - 1
    ? allPosts[currentIndex + 1]
    : null;

const nextEntry =
  currentIndex > 0
    ? allPosts[currentIndex - 1]
    : null;

const currentPath = Astro.url.pathname;

const breadcrumbItems = [
  {label: "Blog", href: "/blog",},
];

if (entry.data.category) {
  breadcrumbItems.push({
    label: entry.data.category, href: "/blog"
  });
}

const cleanSlug = Astro.params.slug;
const currentUrl = `${SITE.url}/blog/${cleanSlug}`;

const metaProps = buildMeta({
  title: entry.data.seo.title,
  description: entry.data.seo.description ?? entry.data.description,
  canonical: currentPath,
  ogImage: entry.data.seo.ogImage,
  ogType: "article",
  datePublished: entry.data.pubDate?.toISOString(),
  dateModified: entry.data.lastUpdated?.toISOString(),
  authorName: entry.data.author.name,
});

const pageSchema = schemaWebPage({
  title: entry.data.title,
  description: entry.data.description || SITE.description,
  url: currentUrl,
});
---

<BlogLayout meta={metaProps} schema={pageSchema}>
  <MobileToc title={entry.data.title} headings={headings} />
  <Fragment>
    <div class="mx-auto w-full min-w-0 p-0 lg:p-4 m-2 pb-(--safe-bottom) rounded-xl">
      <Section size="sm">
        <article data-pagefind-body data-pagefind-filter="type:blog">
          <Container size="md">
            <BlogHeader
              title={entry.data.title}
              description={entry.data.description}
              pubDate={entry.data.pubDate}
              content={entry.body}
              breadcrumb={breadcrumbItems}
              cover={entry.data.cover}
              author={entry.data.author}
            />
          </Container>
          <div class="bg-none border-none border-(--border-subtle)/80 my-6 md:my-8" />
          <Container size="md">
            <div class="prose">
              <Content components={components} />
            </div>
          </Container>  
          <Container size="md">
            <div class="bg-none border-t border-dashed border-(--border-subtle)/80 mt-6 md:mt-8" />
            <BlogFooter 
              tags={entry.data.tags}
              lastUpdated={entry.data.lastUpdated}
              prev={prevEntry}
              next={nextEntry} />
          </Container>
        </article>
      </Section>
    </div>
  </Fragment>
  <Fragment slot="right" class="flex items-center gap-4">
    <div class="sticky top-0 right-0 space-y-2">
      <ScrollToTop label="Scroll to top" />
    </div>
    <div class="fixed top-1/2 right-2 z-40 hidden -translate-y-1/2 lg:block">
      <Toc headings={headings} />
    </div>
  </Fragment>
  <CopyCode />
</BlogLayout>