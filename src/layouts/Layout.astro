---
// src/layouts/Layout.astro
import { SITE, type buildMeta as BuildMetaFn } from "@/consts";

import Head from "@components/Head.astro";
import Header from "@components/Header.astro";
import SkipLink from "@components/SkipLink.astro";
import ThemeProvider from "@components/ThemeProvider.astro";

interface Props {
  meta?: Partial<ReturnType<typeof BuildMetaFn>>;
  schema?: object | object[];
  isHome?: boolean;
  canonical?: string;
  hideHeader?: boolean;
}

const {
  meta,
  schema,
  isHome = false,
  canonical,
  hideHeader = false,
} = Astro.props;
---

<!doctype html>
<html lang={SITE.lang} dir={SITE.dir}>
  <Head {meta} {schema} {isHome} {canonical}>
    <ThemeProvider />
  </Head>
  <body>
    <SkipLink />
    <div class="min-h-screen flex-col">
      {!hideHeader && <Header />}
      <main
        id="main-content"
        class="flex min-h-[calc(100vh-var(--header-height))] flex-1"
      >
        <slot />
      </main>
    </div>
  </body>
</html>
